<script asp-add-nonce src="~/lib/chartjs/chart.js" asp-append-version="true"></script>
<partial name="_DataTableScripts" />
<script asp-add-nonce>
    // 1. Initialize a global dictionary to hold multiple chart instances
    window.myCharts = window.myCharts || {};

    // Static chart palette matching the reference dashboard design -
    // deliberately NOT derived from the active theme: chart colors stay
    // identical no matter which body.theme-* class is applied. Order matters;
    // the first N series take the first N colors, cycling for long palettes.
    $.ThemeChartColors = (function () {
        var PALETTE = [
            '#2563eb', // royal blue
            '#38bdf8', // sky
            '#10b981', // emerald
            '#fb923c', // orange
            '#8b5cf6', // violet
            '#cbd5e1', // slate (neutral / "others")
            '#f43f5e', // rose
            '#14b8a6', // teal
            '#f59e0b', // amber
            '#6366f1'  // indigo
        ];

        function hexToRgb(hex) {
            hex = (hex || '').trim().replace('#', '');
            if (hex.length === 3) {
                hex = hex.split('').map(function (c) { return c + c; }).join('');
            }
            var num = parseInt(hex, 16);
            if (isNaN(num)) {
                return { r: 37, g: 99, b: 235 }; // Fallback: palette's lead blue
            }
            return { r: (num >> 16) & 255, g: (num >> 8) & 255, b: num & 255 };
        }

        // Converts any hex color to an rgba() string at the given alpha, for
        // translucent fills (line/radar area).
        function hexToRgba(hex, alpha) {
            var rgb = hexToRgb(hex);
            return 'rgba(' + rgb.r + ', ' + rgb.g + ', ' + rgb.b + ', ' + alpha + ')';
        }

        function generate(count) {
            var palette = [];
            for (var i = 0; i < count; i++) {
                palette.push(PALETTE[i % PALETTE.length]);
            }
            return palette;
        }

        return { generate: generate, hexToRgba: hexToRgba };
    })();

    // Fills in backgroundColor for any dataset the server left uncolored,
    // using the static palette above. Datasets that already carry an
    // explicit color (single hex string or a populated array) are left
    // untouched, so this stays safe even if some report configs set their
    // own colors deliberately.
    //
    // Whether a chart needs one color per data POINT (Pie/Doughnut/Polar
    // Area) or one color per DATASET (Bar/Line/Radar/Horizontal Bar) is
    // decided from chartRenderType here — not from whether the incoming
    // backgroundColor happens to be a JSON array. The server's `Dataset`
    // class (used for any 2-column report, regardless of chart type)
    // always serializes BackgroundColor as an array, even when empty, so
    // that shape can't reliably tell us which family a chart belongs to.
    var PER_POINT_CHART_TYPES = ['pie', 'doughnut', 'polarArea'];

    // Datasets whose label IS a semantic status name (e.g. a RAG breakdown
    // query with Green/Amber/Red columns) get fixed status colors - static
    // like the rest of the palette, and a green segment is always green.
    var SEMANTIC_LABEL_COLORS = {
        'green': '#10b981',
        'amber': '#f59e0b',
        'red': '#ef4444'
    };

    function semanticColorForLabel(label) {
        return SEMANTIC_LABEL_COLORS[(label || '').trim().toLowerCase()] || null;
    }

    $.ApplyThemeChartColors = function (chartRenderType, datasets) {
        if (!Array.isArray(datasets) || datasets.length === 0) {
            return datasets;
        }

        var isPerPoint = PER_POINT_CHART_TYPES.indexOf(chartRenderType) !== -1;

        if (!isPerPoint) {
            datasets.forEach(function (ds) {
                var hasColor = Array.isArray(ds.backgroundColor) ? ds.backgroundColor.length > 0 : !!ds.backgroundColor;
                if (!hasColor) {
                    var semantic = semanticColorForLabel(ds.label);
                    if (semantic) {
                        ds.backgroundColor = semantic;
                    }
                }
            });
        }

        var colorsNeeded = 0;
        datasets.forEach(function (ds) {
            colorsNeeded += isPerPoint ? Math.max((ds.data || []).length, 1) : 1;
        });

        var palette = $.ThemeChartColors.generate(Math.max(colorsNeeded, 6));
        var cursor = 0;

        datasets.forEach(function (ds) {
            var hasColor = Array.isArray(ds.backgroundColor) ? ds.backgroundColor.length > 0 : !!ds.backgroundColor;
            if (hasColor) {
                return;
            }

            if (isPerPoint) {
                ds.backgroundColor = (ds.data || []).map(function () {
                    return palette[cursor++ % palette.length];
                });
            } else {
                ds.backgroundColor = palette[cursor++ % palette.length];
            }
        });

        return datasets;
    };

    // Line and Radar charts read poorly with a flat, fully-opaque fill the
    // way Bar/Pie slices do. This keeps the same theme-derived color but
    // turns it into a solid border + a soft translucent fill instead.
    $.ApplyChartTypeStyling = function (chartRenderType, datasets) {
        if (!Array.isArray(datasets) || (chartRenderType !== 'line' && chartRenderType !== 'radar')) {
            return datasets;
        }

        datasets.forEach(function (ds) {
            var solidColor = Array.isArray(ds.backgroundColor) ? null : ds.backgroundColor;
            if (!solidColor) {
                return;
            }

            ds.borderColor = solidColor;
            ds.backgroundColor = $.ThemeChartColors.hexToRgba(solidColor, chartRenderType === 'radar' ? 0.25 : 0.15);
            ds.borderWidth = ds.borderWidth || 2;
            ds.pointBackgroundColor = solidColor;
            ds.pointRadius = ds.pointRadius != null ? ds.pointRadius : 3;

            if (chartRenderType === 'line') {
                // Only Line needs the Filler plugin's fill:true — Radar already
                // draws a filled polygon natively from backgroundColor, and
                // routing it through Filler as well crashes chart.js (Filler
                // resolves fill targets against a cartesian x/y boundary,
                // which doesn't map onto Radar's polar scale).
                ds.fill = true;
                ds.tension = ds.tension != null ? ds.tension : 0.35;
            }
        });

        return datasets;
    };

    // Configuration factory: per-chart-type option overrides layered on top of
    // the shared base config in $.BuildChart. Keyed by the Chart.js render type
    // (not the backend ReportChartType constant), so new backend chart types
    // just need a case in the switch below mapping to one of these keys - or to
    // 'bar'/'pie'/etc. if they need no special options at all.
    $.ChartTypeOptionsFactory = {
        bar: function (indexAxis) {
            return { indexAxis: indexAxis };
        },
        stackedBar: function (indexAxis) {
            return {
                indexAxis: indexAxis,
                scales: {
                    x: { stacked: true },
                    y: { stacked: true }
                }
            };
        },
        line: function () {
            return {};
        },
        radar: function () {
            return {};
        },
        pie: function () {
            return {};
        },
        doughnut: function () {
            return {};
        },
        polarArea: function () {
            return {};
        },
        // Bubble/Scatter plot raw (x, y) coordinates rather than category
        // labels, so both axes need an explicit linear scale.
        bubble: function () {
            return {
                scales: {
                    x: { type: 'linear', position: 'bottom' },
                    y: { type: 'linear' }
                }
            };
        },
        scatter: function () {
            return {
                scales: {
                    x: { type: 'linear', position: 'bottom' },
                    y: { type: 'linear' }
                }
            };
        }
    };

    // Inline plugin: prints the summed total at the end of each stack for
    // stacked bar charts (e.g. "28" after a Green+Amber+Red RAG bar).
    // Registered per-chart (not globally) so ordinary charts are untouched.
    var stackedTotalsPlugin = {
        id: 'stackedTotals',
        afterDatasetsDraw: function (chart) {
            var datasets = chart.data.datasets || [];
            if (datasets.length === 0) {
                return;
            }
            var horizontal = chart.options.indexAxis === 'y';
            var categoryCount = (chart.data.labels || []).length;
            var ctx = chart.ctx;
            ctx.save();
            ctx.font = '700 11px ' + (getComputedStyle(document.body).fontFamily || 'sans-serif');
            ctx.fillStyle = '#1e293b'; // static, matching the static chart palette

            for (var index = 0; index < categoryCount; index++) {
                var total = 0;
                var anchor = null;
                for (var d = 0; d < datasets.length; d++) {
                    if (!chart.isDatasetVisible(d)) {
                        continue;
                    }
                    total += Number(datasets[d].data[index]) || 0;
                    var meta = chart.getDatasetMeta(d);
                    if (meta.data && meta.data[index]) {
                        anchor = meta.data[index];
                    }
                }
                if (!anchor) {
                    continue;
                }
                if (horizontal) {
                    ctx.textAlign = 'left';
                    ctx.textBaseline = 'middle';
                    ctx.fillText(total, anchor.x + 6, anchor.y);
                } else {
                    ctx.textAlign = 'center';
                    ctx.textBaseline = 'bottom';
                    ctx.fillText(total, anchor.x, anchor.y - 4);
                }
            }
            ctx.restore();
        }
    };

    $(document).ready(function () {
        $.BuildChart = function (chartContainer, reportName, charType, columnHeaders, dataSetResult, displayLegend, isPercentage, reportId, drillDownReportId) {

            let chartRenderType = '';
            let indexAxis = 'x';
            let isStacked = false;
            switch (charType) {
                case "@FBSC.ODMS.Core.Constants.ReportChartType.HorizontalBar":
                    chartRenderType = 'bar';
                    indexAxis = 'y';
                    break;
                case "@FBSC.ODMS.Core.Constants.ReportChartType.StackedHorizontalBar":
                    chartRenderType = 'bar';
                    indexAxis = 'y';
                    isStacked = true;
                    break;
                case "@FBSC.ODMS.Core.Constants.ReportChartType.Bar":
                    chartRenderType = 'bar';
                    break;           
                case "@FBSC.ODMS.Core.Constants.ReportChartType.Pie":
                    chartRenderType = 'pie';
                    break;
                case "@FBSC.ODMS.Core.Constants.ReportChartType.Doughnut":
                    chartRenderType = 'doughnut';
                    break;          
                case "@FBSC.ODMS.Core.Constants.ReportChartType.PolarArea":
                    chartRenderType = 'polarArea';
                    break;
                case "@FBSC.ODMS.Core.Constants.ReportChartType.Line":
                    chartRenderType = 'line';
                    break;
                case "@FBSC.ODMS.Core.Constants.ReportChartType.Radar":
                    chartRenderType = 'radar';
                    break;
                case "@FBSC.ODMS.Core.Constants.ReportChartType.Bubble":
                    chartRenderType = 'bubble';
                    break;
                case "@FBSC.ODMS.Core.Constants.ReportChartType.Scatter":
                    chartRenderType = 'scatter';
                    break;
                case "@FBSC.ODMS.Core.Constants.ReportChartType.Table":
                    chartRenderType = 'table-custom';
                    break;
                case "@FBSC.ODMS.Core.Constants.ReportChartType.CustomHtml":
                    chartRenderType = 'html-custom';
                    break;
                default:
                    break;
            }

            if (chartRenderType != '') {
                if (charType == '@FBSC.ODMS.Core.Constants.ReportChartType.Table') {
                    if (dataSetResult != '' && dataSetResult != null) {
                        // Destroy existing DataTable if it exists before recreating
                        if ($.fn.DataTable.isDataTable('#' + chartContainer)) {
                            $('#' + chartContainer).DataTable().destroy();
                            $('#' + chartContainer).empty();
                        }

                        var table = $('#' + chartContainer).DataTable({
                            data: dataSetResult,
                            columns: columnHeaders,
                            dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DashboardDataTableDOMLayOut)',
                            buttons: [
                                {
                                    extend: 'excel',
                                    text: '<i class="fa fa-file-excel" title="Export to Excel"></i>',
                                    className: 'btn btn-success text-light',
                                    title: reportName,
                                    customize: function (xlsx) {
                                        var sheet = xlsx.xl.worksheets['sheet1.xml'];
                                        $('row c[r^="A"]', sheet).attr('s', '2');
                                    }
                                },
                                {
                                    extend: 'pdf',
                                    text: '<i class="fa fa-file-pdf" title="Export to PDF"></i>',
                                    className: 'btn btn-danger text-light',
                                    title: reportName,
                                    orientation: 'landscape',
                                    customize: function (doc) {
                                        doc.content[0].text = reportName;
                                    }
                                },
                                {
                                    extend: 'pageLength',
                                    className: 'btn btn-primary',
                                    titleAttr: '@Localizer["Rows per page"]'
                                }
                            ]
                        });
                    }
                }
                else if (charType == '@FBSC.ODMS.Core.Constants.ReportChartType.CustomHtml') {
                    return; 
                }
                else {
                    $.ApplyThemeChartColors(chartRenderType, dataSetResult);
                    $.ApplyChartTypeStyling(chartRenderType, dataSetResult);

                    const data = {
                        labels: columnHeaders,
                        datasets: dataSetResult
                    };
                    const ctx = document.getElementById(chartContainer).getContext('2d');

                    // 2. Destroy the specific chart instance if it already exists to prevent canvas ghosting
                    if (window.myCharts[chartContainer]) {
                        window.myCharts[chartContainer].destroy();
                    }

                    // 3. Build type-specific option overrides from the factory (e.g.
                    // indexAxis for Bar, linear x/y scales for Bubble/Scatter).
                    // Stacked bars share Chart.js render type 'bar' but need their
                    // own factory entry for the stacked scales.
                    var factoryKey = isStacked ? 'stackedBar' : chartRenderType;
                    var typeOptions = ($.ChartTypeOptionsFactory[factoryKey] || function () { return {}; })(indexAxis);

                    var chartOptions = {
                        responsive: false,
                        ...typeOptions,
                        plugins: {
                            legend: {
                                display: displayLegend,
                                position: 'bottom',
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        // Bubble/Scatter points don't carry a category
                                        // label - fall back to the dataset's own label.
                                        var label = context.label || context.dataset.label || '';
                                        var value = (chartRenderType === 'bubble' || chartRenderType === 'scatter')
                                            ? '(' + context.raw.x + ', ' + context.raw.y + ')'
                                            : (context.raw || 0);
                                        return label + ': ' + value + (isPercentage == 'true' ? '%' : "");
                                    }
                                }
                            },
                        },
                        elements: {
                            arc: {
                                borderWidth: 0
                            }
                        }
                    };

                    // 4. Drill-down: only wired up when this widget's report has a
                    // DrillDownReportId configured (Report Setup > Drill-Down Report).
                    // Clicking a data point (bar segment, pie slice, line point, bubble,
                    // etc.) navigates to that OTHER report's detail page, passing along
                    // the clicked category/point label as the filter.
                    if (drillDownReportId) {
                        chartOptions.onClick = function (event, elements, chart) {
                            if (!elements || elements.length === 0) {
                                return;
                            }

                            var element = elements[0];
                            var dataset = chart.data.datasets[element.datasetIndex];

                            // clickedLabelKey identifies which underlying query column the
                            // clicked value came from, matching ReportDataHelper's own column
                            // naming convention (the "Label" column backs category-based
                            // charts, "X" backs Bubble/Scatter points). The drill-down target
                            // report's own query filter FieldName must match this key for the
                            // forced filter to take effect server-side.
                            var isPointChart = (chartRenderType === 'bubble' || chartRenderType === 'scatter');
                            var clickedLabelKey = isPointChart ? 'X' : 'Label';
                            var clickedLabelValue;

                            if (isPointChart) {
                                var point = dataset.data[element.index];
                                clickedLabelValue = (point && point.x !== undefined) ? point.x : dataset.label;
                            } else {
                                var label = chart.data.labels && chart.data.labels[element.index];
                                clickedLabelValue = (label !== undefined && label !== null) ? label : dataset.label;
                            }

                            if (clickedLabelValue === undefined || clickedLabelValue === null) {
                                return;
                            }

                            var url = '/ODMS/Report/Index?id=' + encodeURIComponent(drillDownReportId) + '&fieldName=' + encodeURIComponent(clickedLabelKey) + '&filterValue=' + encodeURIComponent(clickedLabelValue);
                            window.location.href = url;
                        };

                        // Pointer cursor over clickable elements as an affordance for drill-down.
                        chartOptions.onHover = function (event, elements) {
                            event.native.target.style.cursor = elements.length ? 'pointer' : 'default';
                        };
                    }

                    // 5. Create a new chart instance and assign it to the dictionary using its unique ID
                    window.myCharts[chartContainer] = new Chart(ctx, {
                        type: chartRenderType,
                        data: data,
                        options: chartOptions,
                        plugins: isStacked ? [stackedTotalsPlugin] : []
                    });
                }
            }
        };
    });
</script>