@page
@model RegisterModel
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
    var privacyPolicyUrl = Configuration.GetValue<string>("PrivacyPolicyUrl");
}

<div class="auth-page-wrapper">
    <div class="container d-flex justify-content-center align-items-center auth-viewport-height">
        <div class="card shadow-lg o-hidden border-0 my-5 overflow-hidden auth-card-max-width auth-card-rounded">
            <div class="card-body p-0">
                <div class="row g-0">
                    <div class="col-lg-5 d-none d-lg-flex">
                        <div class="flex-grow-1 bg-login-image auth-min-height-image">
                           
                        </div>
                    </div>

                    <div class="col-lg-7 d-flex align-items-center">
                        <div class="p-5 text-center w-100">
                            <p class="color-transparent">
                                -------------------------------------------------------------------------------------------------
                            </p>
                            <div class="text-center mb-4">
                                <h4 class="text-dark fw-bold mb-1">Create an Account</h4>
                                <p class="text-muted small">Join our platform to access your dashboard and reports.</p>
                            </div>

                            <form asp-route-returnUrl="@Model.ReturnUrl" method="post" class="user">
                                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                                <div class="mb-3">
                                    <label asp-for="Input!.Name" class="form-label ms-1">Full Name</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="fas fa-user text-primary small"></i>
                                        </span>
                                        <input asp-for="Input!.Name" class="form-control border-start-0" placeholder="John Doe">
                                    </div>
                                    <span asp-validation-for="Input!.Name" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Input!.Email" class="form-label ms-1">Email Address</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="fas fa-envelope text-primary small"></i>
                                        </span>
                                        <input asp-for="Input!.Email" class="form-control border-start-0" placeholder="email@example.com">
                                    </div>
                                    <span asp-validation-for="Input!.Email" class="text-danger small"></span>
                                </div>

                                <div class="row g-2 mb-3">
                                    <div class="col-md-6">
                                        <label asp-for="Input!.Password" class="form-label ms-1">Password</label>
                                        <input asp-for="Input!.Password" type="password" class="form-control" placeholder="*******">
                                        <span asp-validation-for="Input!.Password" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Input!.ConfirmPassword" class="form-label ms-1">Confirm</label>
                                        <input asp-for="Input!.ConfirmPassword" type="password" class="form-control" placeholder="*******">
                                        <span asp-validation-for="Input!.ConfirmPassword" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mb-4 ms-1">
                                    <div class="form-check custom-checkbox">
                                        <input asp-for="Input!.TermsAccepted" class="form-check-input" type="checkbox">
                                        <label class="form-check-label small" asp-for="Input!.TermsAccepted">
                                            I agree to the <a href="@privacyPolicyUrl" class="login-link fw-bold">terms & conditions</a>
                                        </label>
                                    </div>
                                    <span asp-validation-for="Input!.TermsAccepted" class="text-danger small"></span>
                                </div>

                                <button class="btn btn-primary d-block btn-user w-100 shadow-sm" type="submit">
                                    Register Account
                                </button>
                            </form>
                            @if (!string.IsNullOrEmpty(Configuration["Authentication:Microsoft:ClientId"]) ||
                                                        !string.IsNullOrEmpty(Configuration["Authentication:Google:ClientId"]))
                            {
                                <div class="social-login-section">
                                    @* Microsoft Login *@
                                    @if (!string.IsNullOrEmpty(Configuration["Authentication:Microsoft:ClientId"]))
                                    {
                                        <form id="microsoft-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                                            <input type="hidden" name="provider" value="Microsoft">
                                            <button type="submit" class="btn btn-outline-primary d-block btn-user w-100 mb-2" alt="Sign in using Microsoft">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 23 23" width="20" height="20" class="me-2">
                                                    <rect x="1" y="1" width="10" height="10" fill="#f25022" />
                                                    <rect x="12" y="1" width="10" height="10" fill="#7fba00" />
                                                    <rect x="1" y="12" width="10" height="10" fill="#00a4ef" />
                                                    <rect x="12" y="12" width="10" height="10" fill="#ffb900" />
                                                </svg>
                                                Sign in with Microsoft
                                            </button>
                                        </form>
                                    }

                                    @* Google Login *@
                                    @if (!string.IsNullOrEmpty(Configuration["Authentication:Google:ClientId"]))
                                    {
                                        <form id="google-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                                            <input type="hidden" name="provider" value="Google">
                                            <button type="submit" class="btn btn-outline-danger d-block btn-user w-100" alt="Sign in using Google">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20" height="20" class="me-2">
                                                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                                                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                                                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                                                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                                                    <path fill="none" d="M0 0h48v48H0z" />
                                                </svg>
                                                Sign in with Google
                                            </button>
                                        </form>
                                    }
                                </div>
                            }
                            <hr class="my-4">
                            <div class="text-center">
                                @if (string.Equals(Configuration["Authentication:EmailLoginEnabled"], "true", StringComparison.OrdinalIgnoreCase))
                                {
                                    <a class="small login-link d-block mb-1" asp-page="./ForgotPassword">Forgot Password?</a>
                                }
                                <a class="small login-link d-block fw-bold" href="./Login">Already have an account? Login!</a>
                            </div>
                        </div>


                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}