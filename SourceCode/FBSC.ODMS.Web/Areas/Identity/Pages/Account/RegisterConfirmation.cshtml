@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Register confirmation";
    Layout = "_Layout";
}

<div class="auth-page-wrapper">
    <div class="container d-flex justify-content-center align-items-center auth-vh-80">
        <div class="card shadow-lg o-hidden border-0 my-5 overflow-hidden auth-card-sm auth-card-rounded">
            <div class="card-body p-0">
                <div class="p-5 text-center">
                    @if (Model.DisplayConfirmAccountLink)
                    {
                        <div class="icon-circle mb-4 shadow-sm mx-auto auth-status-icon auth-icon-warning">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>

                        <h3 class="fw-bold text-dark mb-2">Development Mode</h3>
                        <p class="text-muted mb-4 small">
                            This app does not currently have a real email sender registered.
                            Normally this link would be sent via email.
                        </p>

                        <div class="alert alert-warning border-0 small mb-4">
                            <i class="fas fa-link me-2"></i>
                            <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="fw-bold text-decoration-none text-dark">
                                Click here to confirm your account
                            </a>
                        </div>

                        <p class="small text-muted mb-0">
                            See <a href="https://aka.ms/aspaccountconf" target="_blank" class="login-link">docs</a> for real email configuration.
                        </p>
                    }
                    else
                    {
                        <div class="icon-circle mb-4 shadow-sm mx-auto auth-status-icon auth-icon-primary">
                            <i class="fas fa-envelope-open-text"></i>
                        </div>

                        <h3 class="fw-bold text-dark mb-2">Almost There!</h3>
                        <p class="text-muted mb-4 small">
                            Please check your email to confirm your account. We've sent a verification link to your inbox.
                        </p>

                        <hr class="my-4">

                        <div class="d-grid">
                            <a href="./Login" class="btn btn-primary btn-user shadow-sm py-2">
                                <i class="fas fa-sign-in-alt me-2"></i> Go to Login
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>