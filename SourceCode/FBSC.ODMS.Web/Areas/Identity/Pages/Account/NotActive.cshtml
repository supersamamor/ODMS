@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Account Not Active";
    Layout = "_Layout";
}

<div class="auth-page-wrapper">
    <div class="container d-flex justify-content-center align-items-center auth-vh-80">
        <div class="card shadow-lg o-hidden border-0 my-5 overflow-hidden auth-card-sm auth-card-rounded">
            <div class="card-body p-0">
                <div class="p-5 text-center">
                    <div class="icon-circle mb-4 shadow-sm mx-auto auth-status-icon auth-icon-warning">
                        <i class="fas fa-user-clock"></i>
                    </div>

                    <h3 class="fw-bold text-dark mb-2">Account Pending</h3>
                    <p class="text-muted mb-4 small">
                        Your account is currently <strong>inactive</strong>. To gain access to the system, please reach out to your System Administrator for activation.
                    </p>

                    <div class="alert alert-light border small text-start mb-4 auth-small-alert">
                        <i class="fas fa-info-circle text-primary me-2"></i>
                        Once an administrator approves your request, you will be able to log in with your credentials.
                    </div>

                    <hr class="my-4">

                    <div class="d-grid">
                        @* btn-user handles the 10rem rounding from site.css *@
                        <a href="./Login" class="btn btn-primary btn-user shadow-sm py-2">
                            <i class="fas fa-arrow-left me-2"></i> Return to Login
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-light py-3 text-center border-0">
                <a href="mailto:@(Configuration.GetValue<string>("CustomerSupportEmail"))" class="small login-link fw-bold">
                    <i class="fas fa-envelope me-1"></i> Contact Support
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}