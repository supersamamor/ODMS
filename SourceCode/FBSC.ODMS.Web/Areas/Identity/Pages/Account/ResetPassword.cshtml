@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
    Layout = "_Layout";
}

<div class="auth-page-wrapper">
    <div class="container d-flex justify-content-center align-items-center auth-vh-90">
        <div class="card shadow-lg o-hidden border-0 my-5 overflow-hidden auth-card-1000 auth-card-rounded">
            <div class="card-body p-0">
                <div class="row g-0">
                    <div class="col-lg-5 d-none d-lg-flex">
                        <div class="flex-grow-1 bg-login-image auth-img-min-500"></div>
                    </div>

                    <div class="col-lg-7">
                        <div class="p-5">
                            <div class="text-center mb-4">
                                <h4 class="text-dark fw-bold mb-1">Reset Password</h4>
                                <p class="text-muted small">You are only one step away from your new password.</p>
                            </div>

                            <form method="post" class="user">
                                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                                <input asp-for="Input!.Code" type="hidden" />

                                <div class="mb-3">
                                    <label asp-for="Input!.Email" class="form-label ms-1">Email Address</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="fas fa-envelope text-primary small"></i>
                                        </span>
                                        <input asp-for="Input!.Email" class="form-control border-start-0 bg-light" placeholder="Email" readonly>
                                    </div>
                                    <span asp-validation-for="Input!.Email" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Input!.Password" class="form-label ms-1">New Password</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="fas fa-lock text-primary small"></i>
                                        </span>
                                        <input asp-for="Input!.Password" class="form-control border-start-0" placeholder="New Password">
                                    </div>
                                    <span asp-validation-for="Input!.Password" class="text-danger small"></span>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="Input!.ConfirmPassword" class="form-label ms-1">Confirm New Password</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="fas fa-shield-alt text-primary small"></i>
                                        </span>
                                        <input asp-for="Input!.ConfirmPassword" class="form-control border-start-0" placeholder="Confirm Password">
                                    </div>
                                    <span asp-validation-for="Input!.ConfirmPassword" class="text-danger small"></span>
                                </div>

                                <button type="submit" class="btn btn-primary btn-user w-100 shadow-sm py-2">
                                    Change Password
                                </button>
                            </form>

                            <hr class="my-4">

                            <div class="text-center">
                                <a href="./Login" class="small login-link fw-bold">
                                    <i class="fas fa-arrow-left me-1"></i> Return to login page
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}