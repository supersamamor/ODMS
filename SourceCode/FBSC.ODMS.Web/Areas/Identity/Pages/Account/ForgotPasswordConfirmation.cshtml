@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Email Sent";
    Layout = "_Layout";
}

<div class="auth-page-wrapper">
    <div class="container d-flex justify-content-center align-items-center auth-vh-80">
        <div class="card shadow-lg o-hidden border-0 my-5 overflow-hidden auth-card-sm auth-card-rounded">
            <div class="card-body p-0">
                <div class="p-5 text-center">
                    <div class="icon-circle icon-success mb-4 shadow-sm mx-auto auth-status-icon">
                        <i class="fas fa-paper-plane"></i>
                    </div>

                    <h3 class="fw-bold text-dark mb-2">Check Your Email</h3>
                    <p class="text-muted mb-4 small">
                        We've sent a password reset link to your email address. Please check your inbox (and spam folder) to proceed.
                    </p>

                    <hr class="my-4">

                    <div class="d-grid">
                        @* btn-user handles the 10rem rounding and font from site.css *@
                        <a href="./Login" class="btn btn-primary btn-user shadow-sm py-2">
                            <i class="fas fa-arrow-left me-2"></i> Return to Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>