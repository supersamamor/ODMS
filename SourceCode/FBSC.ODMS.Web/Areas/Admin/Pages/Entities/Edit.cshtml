@page
@model EditModel
@{
    ViewData["Title"] = Localizer["Edit Entity"];
    ViewData["ActiveMainPage"] = "Entities";
    ViewData["Level1"] = "Admin";
    var breadcrumbs = new[] {
        new { Title = "Entities List", Url = "/Admin/Entities/Index", IsActive = false },
        new { Title = "Edit Entity", Url = "", IsActive = true },
    };
}
<partial name="_BreadcrumbPartial" model=@(breadcrumbs) />
<form id="entity-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="card">
        <h5 class="card-header"><span class="card-header-custom">@Localizer["Entity Info"]</span><br></h5>
        <div class="card-body">
            <partial name="_EditEntityDetails" model="Model.Entity" />
        </div>
    </div>
    <div id="toolbar-container" class="btn-group" role="group">
        <a asp-page="Index" id="btnCancelConfirmationModal" class="btn btnFills btn-outline-secondary btnBackIcon" aria-label="@Localizer["Back"]" title="@Localizer["Back"]"></a>
        <button type="button" id="btnConfirmationModal" class="btn btnFills btn-outline-success btnSaveIcon" aria-label="@Localizer["Save changes"]" title="@Localizer["Save changes"]"></button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script asp-add-nonce>
        $(document).ready(function () {
            $.bindSaveConfirmationModal('Save', '#btnConfirmationModal', '#entity-form');
            $.bindCancelConfirmationModal('Cancel', '#btnCancelConfirmationModal', '#entity-form', 'Do you want to cancel the changes?');           
        });
    </script>
}