@page
@model IndexModel
@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["ActiveMainPage"] = "Applications";
    ViewData["Title"] = Localizer["Applications List"];
    ViewData["Level1"] = "Admin";
    IEnumerable<dynamic> breadCrumbs = [new { Title = "Applications List", Url = "", IsActive = true }];
}
<partial name="_BreadcrumbPartial" model=@(breadCrumbs) />
<div class="card">
    <div class="card-body">
        <table id="applications" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%">
            <thead>
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.Application.DisplayName)
                    </th>
                    <th>
                        @Localizer["Actions"]
                    </th>
                </tr>
            </thead>
        </table>
    </div>
</div>

@section Scripts {
    <partial name="_DataTableScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var table = $('#applications').DataTable({
                select: false,
                serverSide: true,
                order: [[0, 'asc']],
                dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                ajax:
                {
                    url: '@Url.Page("/Applications/Index", new { area = "Admin", handler = "ListAll" })',
                    type: "POST",
                    headers: {
                        RequestVerificationToken:
                            $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                },
                columns: [
                    { data: "displayName", name: "DisplayName", responsivePriority: 1 },
                    {
                        data: null,
                        searchable: false,
                        orderable: false,
                        responsivePriority: 2,
                        width: "10%",
                        className: "text-center",
                        render: function (data, type, row, meta) {
                            var url = '@Url.Page("/Applications/View", new { area = "Admin" })' + '?id=' + row.clientId;
                            var button = '<a href="' + url + '" class="btn btnFills btn-outline-success btnInfoIcon" aria-label="@Localizer["View"]" title="@Localizer["View"]"></a>';
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Applications.Edit)).Succeeded)
        {
            <text>
                                    url = '@Url.Page("/Applications/Edit", new { area = "Admin" })' + '?id=' + row.clientId;
                                button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnEditIcon" aria-label="@Localizer["Edit"]" title="@Localizer["Edit"]"></a>';
            </text>
        }
                            return button;
                        },
                    },
                    { data: "clientId", name: "ClientId", visible: false },
                ],
                buttons: [
        @* Add Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Applications.Create)).Succeeded)
        {
            <text>
                            {
                                text: '<i class="fas fa-plus"></i>',
                                className: 'btn btn-success btnAddApplications text-light',
                                titleAttr: '@Localizer["Add"]',
                                action: function (e, dt, node, config) {
                                    window.location.href = '@Url.Page("/Applications/Add", new { area = "Admin" })';
                                }
                            },
            </text>
        }
        @* Page Length Button *@
            {
                extend: 'pageLength',
                className: 'btn btn-primary',
                titleAttr: '@Localizer["Rows per page"]'
            }
                ],
            });
            var debounce = new $.fn.dataTable.Debounce(table); // Add delay to search
            $.InitializeSearchKeyCookies(table);
        });
    </script>
}