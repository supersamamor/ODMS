@using Models
@model ApplicationViewModel

<div class="row g-3">
    <div class="col-12 col-md-6">
        <label asp-for="@Model.ClientId" class="form-label"><strong>Client Id :</strong></label>
        <input asp-for="@Model.ClientId" class="form-control" readonly />
    </div>
    <div class="col-12 col-md-6">
        <label asp-for="@Model.DisplayName" class="form-label fieldrequired"><strong>Name :</strong></label>
        <input asp-for="@Model.DisplayName" class="form-control" readonly />
    </div>
    <div class="col">
        <div class="mb-3">
            <label asp-for="@Model.RedirectUri" class="form-label fieldrequired"><strong>Redirect URI :</strong></label>
            <input asp-for="@Model.RedirectUri" class="form-control" readonly />
        </div>
    </div>
    <div class="col-12">
        <label asp-for="@Model.PostLogoutRedirectUris" class="form-label fieldrequired"><strong>Logout URI :</strong></label>
        <input asp-for="@Model.PostLogoutRedirectUris" class="form-control" readonly />
    </div>
    <div class="col-12">
        <label asp-for="@Model.Scopes" class="form-label fieldrequired"><strong>Scopes :</strong></label>
        <input asp-for="@Model.Scopes" class="form-control" readonly />
    </div>
    <div class="col-12">
        <label asp-for="@Model.Entity" class="form-label fieldrequired"><strong>Entity :</strong></label>
        <input asp-for="@Model.Entity" class="form-control" readonly />
    </div>
    <div class="col-12">
        <label asp-for="@Model.WebhookHmacSecret" class="form-label fieldrequired"><strong>Webhook HMAC Secret :</strong></label>
        <input asp-for="WebhookHmacSecret"
               type="password"
               value="@Model.WebhookHmacSecret"
               class="form-control"
               readonly />
    </div>
    <div class="col-12">
        <label asp-for="@Model.CompleteScopes" class="form-label fieldrequired"><strong>Complete Scopes :</strong></label>
        <textarea asp-for="@Model.CompleteScopes" class="form-control" rows="6" readonly></textarea>
    </div>
</div>

