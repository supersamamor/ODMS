@using Models
@model ApplicationViewModel

<div class="row g-3">
    @if (!string.IsNullOrWhiteSpace(Model.DisplayName))
    {
        <div class="col-12 col-md-6">
            <label asp-for="ClientId" class="form-label"><strong>@Localizer["Client Id"]</strong></label>
            <input asp-for="ClientId" class="form-control bg-light" readonly />
        </div>
    }

    <div class="col-12 col-md-6">
        <label asp-for="DisplayName" class="form-label fieldrequired"><strong>@Localizer["Name"]</strong></label>
        <input asp-for="DisplayName" class="form-control" maxlength="255" />
        <span asp-validation-for="DisplayName" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label asp-for="RedirectUri" class="form-label fieldrequired"><strong>@Localizer["Redirect URI"]</strong></label>
        <input asp-for="RedirectUri" class="form-control" maxlength="255" />
        <span asp-validation-for="RedirectUri" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label asp-for="PostLogoutRedirectUris" class="form-label fieldrequired"><strong>@Localizer["Logout URI"]</strong></label>
        <input asp-for="PostLogoutRedirectUris" class="form-control" maxlength="255" />
        <span asp-validation-for="PostLogoutRedirectUris" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label asp-for="Scopes" class="form-label fieldrequired"><strong>@Localizer["Scopes"]</strong></label>
        <input asp-for="Scopes" class="form-control" maxlength="255" />
        <span asp-validation-for="Scopes" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label asp-for="Entity" class="form-label fieldrequired"><strong>@Localizer["Entity"]</strong></label>
        <select id="entity-select" asp-for="Entity" class="select2 form-control" asp-items="@Model.Entities">
            <option></option>
        </select>
        <span asp-validation-for="Entity" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label asp-for="WebhookHmacSecret" class="form-label"><strong>@Localizer["Webhook HMAC Secret"]</strong></label>
        <div class="input-group">
            <input asp-for="WebhookHmacSecret"
                   type="password"
                   value="@Model.WebhookHmacSecret"
                   class="form-control"
                   id="hmacSecretInput"
                   maxlength="128" />
            <button class="btn btn-outline-secondary" type="button" onclick="generateRandomSecret()" title="Generate Random Secret">
                <i class="fas fa-magic"></i>
            </button>
            <button class="btn btn-outline-secondary" type="button" onclick="toggleSecretVisibility()">
                <i class="fas fa-eye"></i>
            </button>
        </div>
        <small class="text-muted">@Localizer["Click the magic wand to generate a new secure secret."]</small>
        <span asp-validation-for="WebhookHmacSecret" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label asp-for="CompleteScopes" class="form-label"><strong>@Localizer["Complete Scopes"]</strong></label>
        <textarea asp-for="CompleteScopes" class="form-control bg-light" rows="4" readonly></textarea>
    </div>
</div>