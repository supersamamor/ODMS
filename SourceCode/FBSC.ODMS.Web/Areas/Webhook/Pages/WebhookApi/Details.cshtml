@page
@model DetailsModel
@{
    ViewData["Title"] = Localizer["View Webhook / Api"];
    ViewData["ActiveMainPage"] = "WebhookApi";
    ViewData["Level1"] = "SystemSetup";
    var breadcrumbs = new[] {
        new { Title = "Webhook / Api List", Url = "/Webhook/WebhookApi/Index", IsActive = false },
        new { Title = "View Webhook / Api", Url = "", IsActive = true },
    };
}
<partial name="_BreadcrumbPartial" model=@(breadcrumbs) />
<partial name="_CodeMirrorStyles" />
<div class="container-fluid" id="webhookApi-container">
    <input type="hidden" asp-for="@Model.RemoveSubDetailId" />
    <input type="hidden" asp-for="@Model.AsyncAction" />
    <div id="PartialLoaderContainer">
        <partial name="_InputFieldsPartial" model="Model.WebhookApi" />
    </div>
</div>
<div id="toolbar-container" class="btn-group" role="group">
    <a asp-page="Index" class="btn btnFills btn-outline-secondary btnBackIcon" aria-label="@Localizer["Back"]" title="@Localizer["Back"]"></a>
    @if ((await AuthorizationService.AuthorizeAsync(User, FBSC.ApiHub.WebhookPermission.WebhookApi.Create)).Succeeded)
    {
        <a asp-page="Add" id="btnAddRecord" class="btn btnFills btn-outline-success btnAddIcon" aria-label="@Localizer["Add"]" title="@Localizer["Add"]"></a>
    }
    @if ((await AuthorizationService.AuthorizeAsync(User, FBSC.ApiHub.WebhookPermission.WebhookApi.Edit)).Succeeded)
    {
        <a asp-page="Edit" asp-route-id="@Model.WebhookApi.Id" class="btn btnFills btn-outline-primary btnEditIcon" aria-label="@Localizer["Edit"]" title="@Localizer["Edit"]"></a>
    }
    @if ((await AuthorizationService.AuthorizeAsync(User, FBSC.ApiHub.WebhookPermission.WebhookApi.History)).Succeeded)
    {
        <a asp-page="History" asp-route-id="@Model.WebhookApi.Id" class="btn btnFills btn-outline-primary btnHistoryIcon" aria-label="@Localizer["History"]" title="@Localizer["History"]"></a>
    }
</div>
@section Scripts {
    <partial name="_CodeMirrorScripts" />
    <partial name="_DisableFieldsPartial" model="@("webhookApi-container")" />
    <script asp-add-nonce>
        $(document).ready(function () {
            const textAreaAiConfigJson = document.getElementById('AdditionalConfigurationJson');
            if (textAreaAiConfigJson) {
                var editor = CodeMirror.fromTextArea(textAreaAiConfigJson, {
                    mode: "application/json",
                    theme: "3024-night",
                    lineNumbers: true,
                    autoCloseBrackets: true,
                    autoCloseTags: true
                });

                function beautifyJson() {
                    var content = editor.getValue();

                    // 1. Check if null, undefined, or just whitespace
                    if (!content || content.trim() === "") {
                        return; // Exit silently
                    }

                    try {
                        var obj = JSON.parse(content);
                        var pretty = JSON.stringify(obj, null, 4);

                        // Only update if the content actually changed to avoid cursor jumps
                        if (content !== pretty) {
                            editor.setValue(pretty);
                        }
                    } catch (e) {                    
                    }
                }

                editor.setOption("extraKeys", {
                    "Ctrl-B": beautifyJson
                });

                editor.setSize(null, "250px");

                // Initial call - will now be silent if the textarea is empty
                beautifyJson();
            }
        });
    </script>
}