@page
@model AddModel
@{
    ViewData["Title"] = Localizer["Add Webhook / Api"];
    ViewData["ActiveMainPage"] = "WebhookApi";
    ViewData["Level1"] = "Admin";
    var breadcrumbs = new[] {
        new { Title = "Webhook / Api List", Url = "/Webhook/WebhookApi/Index", IsActive = false },
        new { Title = "Add Webhook / Api", Url = "", IsActive = true },
    };
}
<partial name="_BreadcrumbPartial" model=@(breadcrumbs) />
<partial name="_CodeMirrorStyles" />
<form id="webhookApi-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="@Model.RemoveSubDetailId" />
    <input type="hidden" asp-for="@Model.AsyncAction" />
    <div id="PartialLoaderContainer">
        <partial name="_InputFieldsPartial" model="Model.WebhookApi" />
    </div>
    <div id="toolbar-container" class="btn-group" role="group">
        <a asp-page="Index" id="btnCancelConfirmationModal" class="btn btnFills btn-outline-secondary btnBackIcon" aria-label="@Localizer["Back"]" title="@Localizer["Back"]"></a>
        <button type="button" id="btnConfirmationModal" class="btn btnFills btn-outline-success btnSaveIcon" aria-label="@Localizer["Save changes"]" title="@Localizer["Save changes"]"></button>
    </div>
</form>
@section Scripts {
    <partial name="_CodeMirrorScripts" />
    <partial name="_ValidationScriptsPartial" />
    <partial name="_WebhookEventAssignmentListValidationPartial" model="@Model.WebhookApi" />

    <script asp-add-nonce>
        $(document).ready(function () {
            $.bindSaveConfirmationModal('Save', '#btnConfirmationModal', '#webhookApi-form');
            $.bindCancelConfirmationModal('Cancel', '#btnCancelConfirmationModal', '#webhookApi-form', 'Do you want to cancel the changes?');
            function InitializeForm() {

                $('.DisableSelectDropdown').on('mousedown', function (e) {
                    e.preventDefault();
                    this.blur();
                    window.focus();
                });

                $.InitializeWebhookEventAssignmentFieldValidations($('#WebhookEventAssignmentCount').val());
                $('.RemoveWebhookEventAssignmentButton ').on('click', function () {
                    $('#RemoveSubDetailId').val($(this).attr('removeid'));
                    $('#AsyncAction').val('RemoveWebhookEventAssignment');
                    $.triggerPageForm('ChangeFormValue', '#PartialLoaderContainer', '#webhookApi-form', InitializeForm, true);
                });

                $('#btnAddWebhookEventAssignment').on('click', function () {
                    $('#AsyncAction').val('AddWebhookEventAssignment');
                    $.triggerPageForm('ChangeFormValue', '#PartialLoaderContainer', '#webhookApi-form', InitializeForm, true);
                });
                $('#GrantType').on('change', function () {
                    $.triggerPageForm('ChangeFormValue', '#PartialLoaderContainer', '#webhookApi-form', InitializeForm);
                });
                const textAreaAiConfigJson = document.getElementById('AdditionalConfigurationJson');
                if (textAreaAiConfigJson) {
                    var editor = CodeMirror.fromTextArea(textAreaAiConfigJson, {
                        mode: "application/json",
                        theme: "3024-night",
                        lineNumbers: true,
                        autoCloseBrackets: true,
                        autoCloseTags: true
                    });

                    function beautifyJson() {
                        var content = editor.getValue();

                        // 1. Check if null, undefined, or just whitespace
                        if (!content || content.trim() === "") {
                            return; // Exit silently
                        }

                        try {
                            var obj = JSON.parse(content);
                            var pretty = JSON.stringify(obj, null, 4);

                            // Only update if the content actually changed to avoid cursor jumps
                            if (content !== pretty) {
                                editor.setValue(pretty);
                            }
                        } catch (e) {                        
                        }
                    }

                    editor.setOption("extraKeys", {
                        "Ctrl-B": beautifyJson
                    });

                    editor.setSize(null, "250px");

                    // Initial call - will now be silent if the textarea is empty
                    beautifyJson();
                }
            }
            InitializeForm();
        });
    </script>
}