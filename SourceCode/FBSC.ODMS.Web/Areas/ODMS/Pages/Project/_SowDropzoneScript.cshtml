@* Statement-of-Work dropzone behavior, shared by Project Add + Edit.
   Defines a global initSowDropzone() that (re)binds after each partial reload.
   Native HTML5 drag-and-drop: preventDefault on dragover so the drop is
   allowed, then bind DataTransfer.files onto the file input so they post with
   the form. "No SOW yet" disables the zone (server enforces the same rule). *@
<script asp-add-nonce>
    window.initSowDropzone = function () {
        var zone = document.getElementById('sowDropzone');
        var input = document.getElementById('SOWForms');
        if (!zone || !input) { return; }

        var $form = $(input).closest('form');

        // Client-side SOW requirement, mirroring the server rule in
        // ProjectFormPageModel.ValidateSOW: a file is required unless "No SOW yet"
        // is checked or the project already has attachments. Registered as a
        // jquery-validate rule so the shared save flow ($(form).valid()) blocks
        // submission and the message lands in the asp-validation-for span.
        function wireSowValidation() {
            if (!window.jQuery || !$.validator) { return; }
            if (!$.validator.methods.sowrequired) {
                $.validator.addMethod('sowrequired', function (value, element) {
                    var hasNew = element.files && element.files.length > 0;
                    var noSowEl = document.getElementById('NoSOW');
                    var noSowChecked = noSowEl && noSowEl.checked;
                    var hasExisting = document.querySelectorAll('#sowAttachmentList .sow-attachment-row').length > 0;
                    return hasNew || noSowChecked || hasExisting;
                });
            }
            if ($form.length && $form.data('validator')) {
                $(input).rules('add', {
                    sowrequired: true,
                    messages: { sowrequired: "At least one Statement of Work file is required unless 'No SOW yet' is checked." }
                });
            }
        }
        function revalidateSow() {
            if ($form.length && $form.data('validator')) { $(input).valid(); }
        }

        function showSelectedFile() {
            var names = [];
            if (input.files && input.files.length) {
                for (var i = 0; i < input.files.length; i++) { names.push(input.files[i].name); }
            }
            document.getElementById('sowSelectedFile').textContent = names.join(', ');
        }

        input.addEventListener('change', function () { showSelectedFile(); revalidateSow(); });
        wireSowValidation();

        ['dragenter', 'dragover'].forEach(function (evt) {
            zone.addEventListener(evt, function (e) {
                e.preventDefault();
                e.stopPropagation();
                zone.classList.add('dragover');
            });
        });
        ['dragleave', 'dragend'].forEach(function (evt) {
            zone.addEventListener(evt, function (e) {
                e.preventDefault();
                e.stopPropagation();
                zone.classList.remove('dragover');
            });
        });
        zone.addEventListener('drop', function (e) {
            e.preventDefault();
            e.stopPropagation();
            zone.classList.remove('dragover');
            var dt = e.dataTransfer;
            if (dt && dt.files && dt.files.length) {
                // Bind the dropped files onto the input so they submit with the form.
                input.files = dt.files;
                showSelectedFile();
                revalidateSow();
            }
        });

        var noSow = document.getElementById('NoSOW');
        function toggleZone() {
            zone.classList.toggle('sow-disabled', noSow.checked);
        }
        noSow.addEventListener('change', function () { toggleZone(); revalidateSow(); });
        toggleZone();
    };
</script>
