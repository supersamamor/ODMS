@using Models
@model ProjectViewModel
<script asp-add-nonce>
    $(document).ready(function () { 
		$.InitializeTeamMembersFieldValidations = function(count)
        {
			let reqs = [];
			for (let idx = 0; idx < count; idx++) {
				// EmployeeId is optional: the "(Unknown)" default maps to a null value.
				reqs.push({name: "TeamMembersList[" + idx + "].EmployeeId", el: "Select", minlength:0, maxlength:0, isrequired: false, description: "Name"});
				reqs.push({name: "TeamMembersList[" + idx + "].Role", el: "Input", minlength:0, maxlength:100, isrequired: true, description: "Role"});

			}
			let validator = $("#project-form").validate();
			for (let j in reqs)
			{
				let e = reqs[j];
				let el = $(`*[name="${e.name}"]`);
				el.rules("add", {
					required: {                
						depends: function(element) {
							return e.isrequired;
						}
					},
					messages: {
						required: (e.description === '') ? 'this field is required' : `'${e.description}' is required`,
					},
				});
				if(e.isrequired == true)
				{
					let labelElement = $(`label[name="Label.${e.name}"]`);
					$(labelElement).addClass("fieldrequired");
					el.attr('data-val-required', (e.description === '') ? 'this field is required' : `'${e.description}' is required`);
					el.attr('data-val', true);
				}
				if(e.maxlength > 0) {el.attr('maxlength', e.maxlength);}
				if(e.minlength > 0) {el.attr('minlength', e.minlength);}   
			} 
		}       
    });
</script>