@page
@model HistoryModel
@{
    ViewData["Title"] = Localizer["Audit Trail - Project"];
    ViewData["ActiveMainPage"] = "Projects";
    ViewData["Level1"] = "Projects";
}
@* Read-only page: back link navigates directly; toolbar actions moved up. *@
<div class="page-header-bar">
    <nav class="page-header-backnav" aria-label="@Localizer["Back navigation"]">
        <a asp-page="Index" class="page-header-back">
            <i class="fas fa-chevron-left" aria-hidden="true"></i>
            @Localizer["Project Register"]
        </a>
        <span class="page-header-crumb-sep" aria-hidden="true">/</span>
        <span class="page-header-crumb-current">@Localizer["Audit Trail"]</span>
    </nav>
    <div class="page-header-form-actions">
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Project.Create)).Succeeded)
        {
            <a asp-page="Add" id="btnAddRecord" class="btn-header-cancel">@Localizer["New"]</a>
        }
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Project.Edit)).Succeeded)
        {
            <a asp-page="Edit" asp-route-id="@Model.Project.Id" class="page-header-action-btn">@Localizer["Edit"]</a>
        }
    </div>
</div>
<link rel="stylesheet" href="~/css/timeline.css" asp-append-version="true" />
<div id="project-container">
    <div class="card">
        <h5 class="card-header"><span class="card-header-custom">Change History - (Record Id : @Model.Project.Id)</span><br></h5>
        <div class="card-body">
            <ul class="timeline">
                @{
                    string invertedClass = "";
                    var userHelper = new FBSC.ODMS.Web.Helper.UserHelper(Mediator);
                }
                @foreach (var item in Model.AuditLogList)
                {
                    <li class="@invertedClass">
                        @Html.Raw(item.TypeFormatted)
                        <div class="timeline-panel">
                            <div class="timeline-heading">
                                <h6 class="timeline-title"><button class="timeline-link btnShowAuditTrailModal" data-auditlogsid="@item.Id"><i class="fas fa-calendar-alt"></i>@item.DateTimeFormatted</button></h6>
                                <p class="timeline-history"><small class="text-muted"><i class="fas fa-history"></i>@(string.IsNullOrEmpty(item.DateTimeDuration) ? "Just now" : item.DateTimeDuration + " ago") by @Html.Raw(await userHelper.GetUserName(item.UserId!))</small></p>
                            </div>
                        </div>
                    </li>
                    if (invertedClass == "")
                    {
                        invertedClass = "timeline-inverted";
                    }
                    else
                    {
                        invertedClass = "";
                    }
                }
            </ul>
        </div>
    </div>
</div>
@{
    var historyModalId = "changes-history-modal";
}
<partial name="_ModalPartial" model="@historyModalId" />
@section Scripts {
    <script asp-add-nonce>
        $(document).ready(function () {
            function InitializeForm() {
                //Pop-up Audit Trail
                function auditTrailModalPopup(reff) {
                    var auditlogsid = $(reff)[0].dataset.auditlogsid;
                    var url = '@Url.Page("/AuditTrail/Index", new { area = "ODMS" })' + '?handler=ChangesHistory&auditlogsid=' + auditlogsid + '&moduleName=' + '@nameof(Model.Project)';
                    var title = "Change History";
                    openModal("@historyModalId", url, title, null);
                }
                $(".btnShowAuditTrailModal").on('click', function (e) {
                    auditTrailModalPopup(this);
                });
            }
            InitializeForm();
        });
    </script>
}

