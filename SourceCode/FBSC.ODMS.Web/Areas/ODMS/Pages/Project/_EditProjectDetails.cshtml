@using Models
@model ProjectViewModel

<div class="form-section">
    <h6 class="form-section-title">@Localizer["Project Information"]</h6>
    <div class="row g-3">
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.DeliveryTower" class="form-label fieldrequired"><strong>@Localizer["Delivery Tower"] :</strong></label>
                <select asp-for="@Model.DeliveryTower" class="form-control" asp-items="@(dropdownService.DeliveryTowerList())">
                    <option value="">@Localizer["Select tower"]</option>
                </select>
                <span asp-validation-for="@Model.DeliveryTower" class="text-danger d-block mt-1"></span>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.DemandType" class="form-label fieldrequired"><strong>@Localizer["Demand Type"] :</strong></label>
                <select asp-for="@Model.DemandType" class="form-control" asp-items="@(dropdownService.DemandTypeList())">
                    <option value="">@Localizer["Select demand type"]</option>
                </select>
                <span asp-validation-for="@Model.DemandType" class="text-danger d-block mt-1"></span>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="mb-3">
                @* Auto-generated from the BU code + a 7-digit sequence; read-only. *@
                <label asp-for="@Model.ProjectCode" class="form-label"><strong>@Localizer["Project ID"] :</strong></label>
                <input asp-for="@Model.ProjectCode" class="form-control" readonly placeholder="@Localizer["Auto-generated on save"]" />
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.ProjectName" class="form-label fieldrequired"><strong>@Localizer["Project Name"] :</strong></label>
                <input asp-for="@Model.ProjectName" class="form-control" maxlength="255" placeholder="@Localizer["e.g. Digital Payments Integration"]" />
                <span asp-validation-for="@Model.ProjectName" class="text-danger d-block mt-1"></span>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.BusinessUnitId" class="form-label fieldrequired"><strong>@Localizer["Business Unit"] :</strong></label>
                <select asp-for="@Model.BusinessUnitId" class="form-control" asp-items="@(dropdownService.GetBusinessUnitList(Model.BusinessUnitId))"><option value="">@Localizer["Select BU"]</option></select>
                <span asp-validation-for="@Model.BusinessUnitId" class="text-danger d-block mt-1"></span>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.TechnologyBusinessPartnerId" class="form-label"><strong>@Localizer["Technology Business Partner"] :</strong></label>
                <select asp-for="@Model.TechnologyBusinessPartnerId" class="form-control" asp-items="@(dropdownService.GetEmployeeList(Model.TechnologyBusinessPartnerId))"><option value="">@Localizer["Select TBP"]</option></select>
                <span asp-validation-for="@Model.TechnologyBusinessPartnerId" class="text-danger d-block mt-1"></span>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.Priority" class="form-label fieldrequired"><strong>@Localizer["Priority"] :</strong></label>
                <select asp-for="@Model.Priority" class="form-control" asp-items="@(dropdownService.ProjectPriorityList())">
                    <option value="">@Localizer["Select priority"]</option>
                </select>
                <span asp-validation-for="@Model.Priority" class="text-danger d-block mt-1"></span>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.ApprovedBudget" class="form-label"><strong>@Localizer["Approved Budget"] :</strong></label>
                <input asp-for="@Model.ApprovedBudget" class="form-control" placeholder="@Localizer["e.g. ₱4,200,000"]" />
                <span asp-validation-for="@Model.ApprovedBudget" class="text-danger d-block mt-1"></span>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.BaselineStartDate" class="form-label fieldrequired"><strong>@Localizer["Start Date"] :</strong></label>
                <input type="date" asp-for="@Model.BaselineStartDate" class="form-control" />
                <span asp-validation-for="@Model.BaselineStartDate" class="text-danger d-block mt-1"></span>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.BaselineEndDate" class="form-label fieldrequired"><strong>@Localizer["Target End Date"] :</strong></label>
                <input type="date" asp-for="@Model.BaselineEndDate" class="form-control" />
                <span asp-validation-for="@Model.BaselineEndDate" class="text-danger d-block mt-1"></span>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.ActiveStatus" class="form-label"><strong>@Localizer["Status"] :</strong></label>
                <select asp-for="@Model.ActiveStatus" class="form-control" asp-items="@(dropdownService.ProjectActiveStatusList())">
                    <option value="">@Localizer["Select status"]</option>
                </select>
                <span asp-validation-for="@Model.ActiveStatus" class="text-danger d-block mt-1"></span>
            </div>
        </div>
        <div class="col-12">
            <div class="mb-3">
                <label asp-for="@Model.ProjectDescription" class="form-label"><strong>@Localizer["Project Description"] :</strong></label>
                <textarea asp-for="@Model.ProjectDescription" class="form-control" rows="3" maxlength="1000" placeholder="@Localizer["Brief description of the project scope and goals..."]"></textarea>
                <span asp-validation-for="@Model.ProjectDescription" class="text-danger d-block mt-1"></span>
            </div>
        </div>
    </div>
</div>
