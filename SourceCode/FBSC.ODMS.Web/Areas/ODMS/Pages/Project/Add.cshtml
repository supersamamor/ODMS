@page
@model AddModel
@{
    ViewData["Title"] = Localizer["Add Project"];
	ViewData["ActiveMainPage"] = "Projects";
	ViewData["Level1"] = "Projects";
}
@* Form-page header: back navigation on the left, Cancel/Create on the right.
   The two action elements keep the ids the confirmation-modal bindings in
   the Scripts section target (#btnCancelConfirmationModal /
   #btnConfirmationModal), so the save/cancel flow is unchanged - the
   buttons just live up here instead of a bottom toolbar. *@
<div class="page-header-bar">
    <nav class="page-header-backnav" aria-label="@Localizer["Back navigation"]">
        <a href="#" id="btnBackNav" class="page-header-back">
            <i class="fas fa-chevron-left" aria-hidden="true"></i>
            @Localizer["Project Register"]
        </a>
        <span class="page-header-crumb-sep" aria-hidden="true">/</span>
        <span class="page-header-crumb-current">@Localizer["New Project"]</span>
    </nav>
    <div class="page-header-form-actions">
        <a asp-page="Index" id="btnCancelConfirmationModal" class="btn-header-cancel">@Localizer["Cancel"]</a>
        <button type="button" id="btnConfirmationModal" class="page-header-action-btn">@Localizer["Create Project"]</button>
    </div>
</div>
<form id="project-form" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
	<input type="hidden" asp-for="@Model.RemoveSubDetailId" />
    <input type="hidden" asp-for="@Model.AsyncAction" />
	<div id="PartialLoaderContainer">
        <partial name="_InputFieldsPartial" model="Model.Project" />
    </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<partial name="_TeamMembersListValidationPartial" model="@Model.Project" />
<partial name="_SowDropzoneScript" />

<script asp-add-nonce>
    $(document).ready(function () {
		$.bindSaveConfirmationModal('Save', '#btnConfirmationModal','#project-form');
		$.bindCancelConfirmationModal('Cancel', '#btnCancelConfirmationModal','#project-form', 'Do you want to cancel the changes?');
		// Back-nav routes through the same cancel confirmation, so unsaved
		// changes are never silently discarded.
		$('#btnBackNav').on('click', function (e) {
			e.preventDefault();
			$('#btnCancelConfirmationModal').trigger('click');
		});
		function InitializeForm()
		{			

			$('.DisableSelectDropdown').on('mousedown', function(e) {
				e.preventDefault();
				this.blur();
				window.focus();
			});
			
			$.InitializeTeamMembersFieldValidations($('#TeamMembersCount').val());
			$('.RemoveTeamMembersButton ').on( 'click', function () {
				$('#RemoveSubDetailId').val($(this).attr('removeid'));
				$('#AsyncAction').val('RemoveTeamMembers');
				$.triggerPageForm('ChangeFormValue','#PartialLoaderContainer', '#project-form', InitializeForm, true);
			});

			$('#btnAddTeamMembers').on( 'click', function () {
				$('#AsyncAction').val('AddTeamMembers');
				$.triggerPageForm('ChangeFormValue','#PartialLoaderContainer', '#project-form', InitializeForm, true);
			});

			$.fn.employeeSelect = function() {
				this.filter("select").each(function() {
					$(this).ajaxSelect({
						ajax: {
							url: '@Url.Page("/Dropdown/Index", new { area = "ODMS", handler = "Select2EmployeeData" })',
						}
					});
				});
				return this;
			};
			$("#ProjectManagerId").employeeSelect();
			$("#DeputyProjectManagerId").employeeSelect();
			$("#TechnologyBusinessPartnerId").employeeSelect();
			$(".TeamMemberEmployeeSelect").employeeSelect();

			$.fn.businessunitSelect = function() {
				this.filter("select").each(function() {
					$(this).ajaxSelect({
						ajax: {
							url: '@Url.Page("/Dropdown/Index", new { area = "ODMS", handler = "Select2BusinessUnitData" })',
						}
					});
				});
				return this;
			};
			$("#BusinessUnitId").businessunitSelect();

			initSowDropzone();

		}
		InitializeForm();
    });
</script>
}