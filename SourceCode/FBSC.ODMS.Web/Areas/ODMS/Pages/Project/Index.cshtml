@page
@model IndexModel

@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["Title"] = Localizer["Project Register"];
    ViewData["PageSubtitle"] = Localizer["All projects across the portfolio"];
    ViewData["ActiveMainPage"] = "Projects";
    ViewData["Level1"] = "Projects";
}
@if ((await AuthorizationService.AuthorizeAsync(User, Permission.Project.Create)).Succeeded)
{
    // Renders as the "+ New Project" button in the page header; the
    // btnAddProject class keeps the existing click-loader binding.
    ViewData["PageHeaderAddUrl"] = Url.Page("/Project/Add", new { area = "ODMS" });
    ViewData["PageHeaderAddLabel"] = Localizer["New Project"];
    ViewData["PageHeaderAddClass"] = "btnAddProject";
}
<partial name="_PageHeaderPartial"  />
@* Delivery Tower/Category pill filter (design parity): All + one pill per
   category, with the filtered project count on the right. *@
<div class="dt-pill-filter-bar">
    <span class="dt-pill-filter-label">@Localizer["Delivery Tower"]</span>
    <button type="button" class="dt-pill active" data-value="">@Localizer["All"]</button>
    @foreach (var category in FBSC.ODMS.Core.Constants.DeliveryCategories.List)
    {
        <button type="button" class="dt-pill" data-value="@category">@Localizer[category]</button>
    }
    <span class="dt-pill-filter-count" id="projectCountLabel"></span>
</div>
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <table id="project" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%">
                    <thead>
                        <tr>
                            <th>
                                @Localizer["ID"]
                            </th>
                            <th>
								@Localizer["Project"]
							</th>
                            <th>
                                @Localizer["Delivery Category"]
                            </th>
							<th>
								@Localizer["BU"]
							</th>
                            <th>
                                @Localizer["Project Manager"]
                            </th>
							<th>
								@Localizer["Priority"]
							</th>
                            <th>
                                @Localizer["Status"]
                            </th>
							<th>
								@Localizer["Start Date"]
							</th>
							<th>
								@Localizer["End Date"]
							</th>
							<th>
								@Localizer["Budget"]
							</th>
                            <th>
                                @Localizer["Actions"]
                            </th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>


<div id="BatchUploadPartialContainer">
    <partial name="_BatchUpload" model="Model.BatchUpload" />
</div>
@section Scripts {
    <partial name="_DataTableScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var deliveryCategoryFilter = '';
            var table = $('#project').DataTable({
                select: false,
                serverSide: true,
                responsive: true,
                @* LastModifiedDate's column index (13-column table, 0-12). *@
                order: [[11, 'desc']],
                dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                ajax:
                {
                    url: '@Url.Page("/Project/Index", new { area = "ODMS", handler = "ListAll" })',
                    type: "POST",
                    headers: {
                        RequestVerificationToken:
                            $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                    @* Send the active Delivery Tower pill with every draw. *@
                    data: function (d) {
                        d.deliveryCategory = deliveryCategoryFilter;
                    },
                },
                drawCallback: function (settings) {
                    var count = settings.json ? settings.json.recordsFiltered : new $.fn.dataTable.Api(settings).page.info().recordsDisplay;
                    $('#projectCountLabel').text(count + ' ' + (count === 1 ? '@Localizer["project"]' : '@Localizer["projects"]'));
                },
                initComplete: function (settings, json) {
                    BindTableRowCollapseEvent();
                },
                columns: [
                    { data: "projectCode", name: "ProjectCode", responsivePriority: 1, title: '@Localizer["ID"]', searchable: true, className: "text-start" },
                    { data: "projectName", name: "ProjectName", responsivePriority: 1, title: '@Localizer["Project"]', searchable: true, className: "text-start" },
                    { data: "deliveryCategory", name: "DeliveryCategory", responsivePriority: 2, title: '@Localizer["Delivery Category"]', searchable: true, className: "text-start" },
				{ data: "businessUnitId", name: "BusinessUnitId", responsivePriority: 1, title: '@Localizer["BU"]', searchable: false, className: "text-start" },
                    { data: "projectManagerId", name: "ProjectManagerId", responsivePriority: 2, title: '@Localizer["Project Manager"]', searchable: false, className: "text-start" },
                { data: "priority", name: "Priority", responsivePriority: 1, title: '@Localizer["Priority"]', searchable: true, className: "text-start" },
                    { data: "activeStatus", name: "ActiveStatus", responsivePriority: 2, title: '@Localizer["Status"]', searchable: false, className: "text-start" },
                { data: "baselineStartDateFormatted", name: "BaselineStartDate", responsivePriority: 2, title: '@Localizer["Start Date"]', searchable: false, className: "fills-text-center" },
				{ data: "baselineEndDateFormatted", name: "BaselineEndDate", responsivePriority: 2, title: '@Localizer["End Date"]', searchable: false, className: "fills-text-center" },
				{ data: "approvedBudgetFormatted", name: "ApprovedBudget", responsivePriority: 2, title: '@Localizer["Budget"]', searchable: false, className: "fills-text-end" },

                    {
                        data: null,
                        searchable: false,
                        orderable: false,
                        responsivePriority: 1,
                        width: "10%",
                        className: "fills-text-center",
                        render: function (data, type, row, meta) {
                            var url = '@Url.Page("/Project/Details", new { area = "ODMS" })' + '?id=' + row.id;
							var button = '<a href="' + url + '" class="btn btnFills btn-outline-success btnInfoIcon btnViewProject" aria-label="@Localizer["View"]" title="@Localizer["View"]"></a>';
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.Project.Edit)).Succeeded)
						{
							<text>
											url = '@Url.Page("/Project/Edit", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnEditIcon btnEditProject" aria-label="@Localizer["Edit"]" title="@Localizer["Edit"]"></a>';
							</text>
						}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.Project.Delete)).Succeeded)
						{
							<text>
											url = '@Url.Page("/Project/Delete", new { area = "ODMS" })' + '?id=' + row.id;
												button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-danger btnDeleteIcon btnDeleteProject" aria-label="@Localizer["Delete"]" title="@Localizer["Delete"]"></a>';
							</text>
						}
						
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.Project.History)).Succeeded)
						{
							<text>
											url = '@Url.Page("/Project/History", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnHistoryIcon" aria-label="@Localizer["History"]" title="@Localizer["History"]"></a>';
							</text>
						}
							return button;
                        },
                    },
                    { data: "lastModifiedDate", name: "LastModifiedDate", title: '@Localizer["Last Modified Date"]', visible: false, searchable: false },
                    { data: "id", name: "Id", visible: false },
                ],
                buttons: [
        @* Add button intentionally omitted here - it lives in the page header
           (see the PageHeaderAddUrl block at the top of this page). *@

        @* Download Template Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Project.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-download"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Download Template"]',
                        action: function (e, dt, node, config) {
                            $('#download-template-form').submit();
                        }
                    },
            </text>
        }

        @* Upload Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Project.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-upload"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Upload"]',
                        action: function (e, dt, node, config) {
                            $('#btnBatchUpload').click();
                        }
                    },
            </text>
        }

        @* Page Length Button *@
            {
                extend: 'pageLength',
                className: 'btn btn-primary',
                titleAttr: '@Localizer["Rows per page"]'
            }
        ],
            });
            var debounce = new $.fn.dataTable.Debounce(table); // Add delay to search

            $('.btn-table_filter').on('click', function (e) {
                table.ajax.reload(null, false);
            });
            $('.dt-pill').on('click', function () {
                $('.dt-pill').removeClass('active');
                $(this).addClass('active');
                deliveryCategoryFilter = $(this).data('value') || '';
                table.ajax.reload();
            });
            function BindTableRowCollapseEvent() {
                $('#project tbody').on('click', 'td.dtr-control', function () {
                    $.showAjaxLoaderOnClick([".btnAddProject", ".btnEditProject", ".btnViewProject", ".btnDeleteProject"]);
                });
            }
            $.showAjaxLoaderOnClick([".btnAddProject", ".btnEditProject", ".btnViewProject", ".btnDeleteProject"]);
            $.InitializeSearchKeyCookies(table);
            $('#btnBatchUpload').on('change', function (e) {
                $('#batch-upload-form').submit();
            });           
        @if (!string.IsNullOrEmpty(Model.BatchUpload.BatchUploadFileName))
        {
            <text>
                    $('#btnDownloadBatchUploadTemplateLink')[0].click();
            </text>
        }
        });
    </script>
}