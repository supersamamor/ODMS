@using Models
@model BusinessUnitViewModel
@{
    // Code is immutable after creation: rendered read-only on Edit. The value
    // still posts (read-only inputs submit); the Edit command re-preserves the
    // stored code server-side as defense-in-depth against tampering.
    var isEdit = ViewData["IsEdit"] as bool? ?? false;
}
<div class="row g-3">
    <div class="col-12 col-md-4">
        <div class="mb-3">
            <label asp-for="@Model.Code" class="form-label fieldrequired"><strong>@Localizer["Code"] :</strong></label>
            <input asp-for="@Model.Code" class="form-control" maxlength="20" placeholder="@Localizer["e.g. FLI"]" readonly="@isEdit" />
            <span asp-validation-for="@Model.Code" class="text-danger d-block mt-1"></span>
        </div>
    </div>
    <div class="col-12 col-md-8">
        <div class="mb-3">
            <label asp-for="@Model.Name" class="form-label fieldrequired"><strong>@Localizer["Name"] :</strong></label>
            <input asp-for="@Model.Name" class="form-control" maxlength="150" />
            <span asp-validation-for="@Model.Name" class="text-danger d-block mt-1"></span>
        </div>
    </div>
</div>
