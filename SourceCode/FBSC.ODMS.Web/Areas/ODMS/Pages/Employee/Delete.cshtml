@page
@model DeleteModel
@{
    ViewData["Title"] = Localizer["Delete Employee"];
    ViewData["ActiveMainPage"] = "Employee";
    ViewData["Level1"] = "Admin";
	var breadcrumbs = new[] {
		new { Title = "Employee List", Url = "/ODMS/Employee/Index", IsActive = false },
		new { Title = "Delete Employee", Url = "", IsActive = true },
	};
}
<partial name="_BreadcrumbPartial" model=@(breadcrumbs) />
<form id="employee-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="@Model.RemoveSubDetailId" />
    <input type="hidden" asp-for="@Model.AsyncAction" />
    <div id="PartialLoaderContainer">
        <partial name="_InputFieldsPartial" model="Model.Employee" />
    </div>
    <div id="toolbar-container" class="btn-group" role="group">
        <a asp-page="Index" class="btn btnFills btn-outline-secondary btnCancelIcon" aria-label="@Localizer["Cancel"]" title="@Localizer["Cancel"]"></a>
        <button type="button" id="btnDelete" class="btn btnFills btn-outline-danger btnDeleteIcon" aria-label="@Localizer["Delete"]" title="@Localizer["Delete"]"></button>
    </div>
</form>

@section Scripts {
    <partial name="_DisableFieldsPartial" model="@("PartialLoaderContainer")" />
    <partial name="_ValidationScriptsPartial" />
    <script asp-add-nonce>
        $(document).ready(function () {
            $.bindSaveConfirmationModal('Save', '#btnDelete', '#employee-form', 'Are you sure you want to delete this employee?');
        });
    </script>
}