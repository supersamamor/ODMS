@using Models
@model ApproverSetupViewModel

<div class="form-section">
    <h6 class="form-section-title">@Localizer["Approval Rule"]</h6>
    <div class="row g-3">
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.TableName" class="form-label fieldrequired"><strong>@Localizer["Table Name"] :</strong></label>
                <select asp-for="@Model.TableName" class="form-control" asp-items="@FBSC.ODMS.Core.ODMS.ApprovalModule.ApprovalTableList.Select(l => new SelectListItem { Value = l, Text = l })">
                    <option value="">- Select Table Name -</option>
                </select>
                <span asp-validation-for="@Model.TableName" class="text-danger"></span>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.ApprovalType" class="form-label fieldrequired"><strong>@Localizer["Approval Type"] :</strong></label>
                <select asp-for="@Model.ApprovalType" class="form-control" asp-items="@FBSC.ODMS.Core.ODMS.ApprovalTypes.ApprovalTypeList.Select(l => new SelectListItem { Value = l, Text = l })">
                    <option value="">- Select Approval Type -</option>
                </select>
                <span asp-validation-for="@Model.ApprovalType" class="text-danger"></span>
            </div>
        </div>
        @* Delivery Tower routing applies to the Project module only. Leave blank
           to make this setup the fallback for all towers. *@
        <div class="col-12 col-md-6">
            <div class="mb-3">
                <label asp-for="@Model.DeliveryTower" class="form-label"><strong>@Localizer["Delivery Tower"] :</strong></label>
                <select asp-for="@Model.DeliveryTower" class="form-control" asp-items="@(dropdownService.DeliveryTowerList())">
                    <option value="">@Localizer["All Delivery Towers"]</option>
                </select>
                <span asp-validation-for="@Model.DeliveryTower" class="text-danger"></span>
            </div>
        </div>
    </div>
</div>

<div class="form-section">
    <h6 class="form-section-title">@Localizer["Notification"]</h6>
    <div class="row g-3">
        <div class="col-12">
            <div class="mb-3">
                <label asp-for="@Model.EmailSubject" class="form-label fieldrequired"><strong>@Localizer["Email Subject"] :</strong></label>
                <input asp-for="@Model.EmailSubject" class="form-control" maxlength="255" />
                <span asp-validation-for="@Model.EmailSubject" class="text-danger"></span>
            </div>
        </div>
        <div class="col-12">
            <div class="mb-3">
                <label asp-for="@Model.EmailBody" class="form-label fieldrequired"><strong>@Localizer["Email Body"] :</strong></label>
                <textarea asp-for="@Model.EmailBody" class="form-control" rows=8></textarea>
                <span asp-validation-for="@Model.EmailBody" class="text-danger"></span>
            </div>
        </div>
    </div>
</div>
