@page
@model IndexModel

@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["Title"] = Localizer["Approval Setup List"];
    ViewData["ActiveMainPage"] = "Approval";
    ViewData["Level1"] = "Admin";
    IEnumerable<dynamic> breadCrumbs = [new { Title = "Approval Setup List", Url = "", IsActive = true }];
}
<partial name="_BreadcrumbPartial" model=@(breadCrumbs) />
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <table id="approverSetup" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%">
                    <thead>
                        <tr>
                            <th>
                                @Localizer["Table"]
                            </th>
                            <th>
                                @Localizer["Approval Type"]
                            </th>
                            <th>
                                @Localizer["Entity"]
                            </th>
                            <th>
                                @Localizer["Actions"]
                            </th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_DataTableScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var table = $('#approverSetup').DataTable({
                select: false,
                serverSide: true,
                order: [[2, 'desc']],
                dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                ajax:
                {
                    url: '@Url.Page("/ApproverSetup/Index", new { area = "ODMS", handler = "ListAll" })',
                    type: "POST",
                    headers: {
                        RequestVerificationToken:
                            $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                },
                initComplete: function (settings, json) {
                    BindTableRowCollapseEvent();
                },
                columns: [
                    { data: "tableName", name: "TableName", responsivePriority: 1, title: '@Localizer["Table"]', searchable: true },
                    { data: "approvalType", name: "ApprovalType", responsivePriority: 1, title: '@Localizer["Approval Type"]', searchable: false },
                    { data: "entity", name: "Entity", responsivePriority: 1, title: '@Localizer["Entity"]', searchable: false },
                    {
                        data: null,
                        searchable: false,
                        orderable: false,
                        responsivePriority: 2,
                        width: "10%",
                        className: "text-center",
                        render: function (data, type, row, meta) {
                            var url = '@Url.Page("/ApproverSetup/Details", new { area = "ODMS" })' + '?id=' + row.id;
                            var button = '<a href="' + url + '" class="btn btnFills btn-outline-success btnInfoIcon btnViewApproverSetup" aria-label="@Localizer["View"]" title="@Localizer["View"]"></i></a>';
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.ApproverSetup.Edit)).Succeeded)
        {
            <text>
                                    url = '@Url.Page("/ApproverSetup/Edit", new { area = "ODMS" })' + '?id=' + row.id;
                                button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnEditIcon btnEditApproverSetup" aria-label="@Localizer["Edit"]" title="@Localizer["Edit"]"></a>';
            </text>
        }
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.PendingApprovals.View)).Succeeded)
        {
            <text>
                                    url = '@Url.Page("/ApproverSetup/PendingApprovals", new { area = "ODMS" })' + '?tableName=' + row.tableName;
                                    button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnApprovalListIcon btnPendingApprovals" aria-label="@Localizer["Pending Approvals"]" title="@Localizer["Pending Approvals"]"></a>';
            </text>
        }
                            return button;
                        },
                    },
                    { data: "lastModifiedDate", name: "LastModifiedDate", title: '@Localizer["Last Modified Date"]', visible: false, searchable: false },
                    { data: "id", name: "Id", visible: false },
                ],
                buttons: [ 
                    @* Add Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.ApproverSetup.Create)).Succeeded)
        {
            <text>
                                            {
                                                text: '<i class="fas fa-plus"></i>',
                                                className: 'btn btn-success btnAddApproverSetup text-light',
                                                titleAttr: '@Localizer["Add"]',
                                                action: function (e, dt, node, config) {
                                                    window.location.href = '@Url.Page("/ApproverSetup/Add", new { area = "ODMS" })';
                                                }
                                            },
            </text>
        }
        @* Page Length Button *@
            {
                extend: 'pageLength',
                className: 'btn btn-primary',
                titleAttr: '@Localizer["Rows per page"]'
            }],
            });
            var debounce = new $.fn.dataTable.Debounce(table); // Add delay to search
            function BindTableRowCollapseEvent() {
                $('#approverSetup tbody').on('click', 'td.dtr-control', function () {
                    $.showAjaxLoaderOnClick([".btnAddApproverSetup", ".btnEditApproverSetup", ".btnViewApproverSetup", ".btnDeleteApproverSetup"]);
                });
            }
            $.showAjaxLoaderOnClick([".btnAddApproverSetup", ".btnEditApproverSetup", ".btnViewApproverSetup", ".btnDeleteApproverSetup", ".btnPendingApprovals"]);
        });
    </script>
}