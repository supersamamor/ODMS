@page
@model IndexModel

@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["Title"] = Localizer["Data Source List"];
    ViewData["ActiveMainPage"] = "DataSource";
    ViewData["Level1"] = "ODMS";
	IEnumerable<dynamic> breadCrumbs = [new { Title = "Data Source List", Url = "", IsActive = true }];
}
<partial name="_BreadcrumbPartial" model=@(breadCrumbs) />
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <table id="dataSource" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%">
                    <thead>
                        <tr>
                            <th>
								@Localizer["Connection Name"]
							</th>
							<th>
								@Localizer["MS SQL Server Host Or Instance"]
							</th>
							<th>
								@Localizer["Target Database Name"]
							</th>
							<th>
								@Localizer["SQL, WindowsIntegrated, or AzureAD"]
							</th>
							<th>
								@Localizer["Connection Username"]
							</th>
							<th>
								@Localizer["Description"]
							</th>
							<th>
								@Localizer["Is Active"]
							</th>
							  
							<th>
								@Localizer["Status"]
							</th> 
                            <th>
                                @Localizer["Actions"]
                            </th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>


<div id="BatchUploadPartialContainer">
    <partial name="_BatchUpload" model="Model.BatchUpload" />
</div>
@section Scripts {
    <partial name="_DataTableScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var table = $('#dataSource').DataTable({
                select: false,
                serverSide: true,
                responsive: true,
                order: [[9, 'desc']],
                dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                ajax:
                {
                    url: '@Url.Page("/DataSource/Index", new { area = "ODMS", handler = "ListAll" })',
                    type: "POST",
                    headers: {
                        RequestVerificationToken:
                            $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                },
                initComplete: function (settings, json) {
                    BindTableRowCollapseEvent();
                },
                columns: [
                    { data: "name", name: "Name", responsivePriority: 1, title: '@Localizer["Connection Name"]', searchable: true, className: "text-start" },
				{ data: "serverAddress", name: "ServerAddress", responsivePriority: 1, title: '@Localizer["MS SQL Server Host Or Instance"]', searchable: false, className: "text-start" },
				{ data: "databaseName", name: "DatabaseName", responsivePriority: 1, title: '@Localizer["Target Database Name"]', searchable: false, className: "text-start" },
				{ data: "authenticationType", name: "AuthenticationType", responsivePriority: 2, title: '@Localizer["SQL, WindowsIntegrated, or AzureAD"]', searchable: false, className: "text-start" },
				{ data: "username", name: "Username", responsivePriority: 2, title: '@Localizer["Connection Username"]', searchable: false, className: "text-start" },
				{ data: "description", name: "Description", responsivePriority: 2, title: '@Localizer["Description"]', searchable: false, className: "text-start" },
				{ data: "isActiveFormatted", name: "IsActive", responsivePriority: 2, title: '@Localizer["Is Active"]', searchable: false, className: "fills-text-center" },
				   
					{ data: "statusBadge", name: "StatusBadge", responsivePriority: 1, title: '@Localizer["Approval Status"]', searchable: false, orderable: false, className: "fills-text-center" },
                    {
                        data: null,
                        searchable: false,
                        orderable: false,
                        responsivePriority: 1,
                        width: "10%",
                        className: "fills-text-center",
                        render: function (data, type, row, meta) {
                            var url = '@Url.Page("/DataSource/Details", new { area = "ODMS" })' + '?id=' + row.id;
							var button = '<a href="' + url + '" class="btn btnFills btn-outline-success btnInfoIcon btnViewDataSource" aria-label="@Localizer["View"]" title="@Localizer["View"]"></a>';
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSource.Edit)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DataSource/Edit", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnEditIcon btnEditDataSource" aria-label="@Localizer["Edit"]" title="@Localizer["Edit"]"></a>';
							</text>
						}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSource.Delete)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DataSource/Delete", new { area = "ODMS" })' + '?id=' + row.id;
												button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-danger btnDeleteIcon btnDeleteDataSource" aria-label="@Localizer["Delete"]" title="@Localizer["Delete"]"></a>';
							</text>
						}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSource.Approve)).Succeeded)
				{
					<text>
						url = '@Url.Page("/DataSource/Approve", new { area = "ODMS" })' + '?id=' + row.id;
						button =  button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-success btnApproveIcon" title="@Localizer["Approve"]"></a>';
					</text>
				}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSource.History)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DataSource/History", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnHistoryIcon" aria-label="@Localizer["History"]" title="@Localizer["History"]"></a>';
							</text>
						}
							return button;
                        },
                    },
                    { data: "lastModifiedDate", name: "LastModifiedDate", title: '@Localizer["Last Modified Date"]', visible: false, searchable: false },
                    { data: "id", name: "Id", visible: false },
                ],
                buttons: [
        @* Add Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSource.Create)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-plus"></i>',
                        className: 'btn btn-success btnAddDataSource text-light',
                        titleAttr: '@Localizer["Add"]',
                        action: function (e, dt, node, config) {
                            window.location.href = '@Url.Page("/DataSource/Add", new { area = "ODMS" })';
                        }
                    },
            </text>
        }

        @* Download Template Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSource.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-download"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Download Template"]',
                        action: function (e, dt, node, config) {
                            $('#download-template-form').submit();
                        }
                    },
            </text>
        }

        @* Upload Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSource.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-upload"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Upload"]',
                        action: function (e, dt, node, config) {
                            $('#btnBatchUpload').click();
                        }
                    },
            </text>
        }

        @* Page Length Button *@
            {
                extend: 'pageLength',
                className: 'btn btn-primary',
                titleAttr: '@Localizer["Rows per page"]'
            }
        ],
            });
            var debounce = new $.fn.dataTable.Debounce(table); // Add delay to search

            $('.btn-table_filter').on('click', function (e) {
                table.ajax.reload(null, false);
            });
            function BindTableRowCollapseEvent() {
                $('#dataSource tbody').on('click', 'td.dtr-control', function () {
                    $.showAjaxLoaderOnClick([".btnAddDataSource", ".btnEditDataSource", ".btnViewDataSource", ".btnDeleteDataSource"]);
                });
            }
            $.showAjaxLoaderOnClick([".btnAddDataSource", ".btnEditDataSource", ".btnViewDataSource", ".btnDeleteDataSource"]);
            $.InitializeSearchKeyCookies(table);
            $('#btnBatchUpload').on('change', function (e) {
                $('#batch-upload-form').submit();
            });           
        @if (!string.IsNullOrEmpty(Model.BatchUpload.BatchUploadFileName))
        {
            <text>
                    $('#btnDownloadBatchUploadTemplateLink')[0].click();
            </text>
        }
        });
    </script>
}