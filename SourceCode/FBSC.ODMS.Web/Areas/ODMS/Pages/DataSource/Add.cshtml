@page
@model AddModel
@{
    ViewData["Title"] = Localizer["Add Data Source"];
    ViewData["ActiveMainPage"] = "DataSource";
    ViewData["Level1"] = "ODMS";
	var breadcrumbs = new[] {
		new { Title = "Data Source List", Url = "/ODMS/DataSource/Index", IsActive = false },
		new { Title = "Add Data Source", Url = "", IsActive = true },
	};
}
<partial name="_BreadcrumbPartial" model=@(breadcrumbs) />
<form enctype="multipart/form-data" id="dataSource-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
	<input type="hidden" asp-for="@Model.RemoveSubDetailId" />
    <input type="hidden" asp-for="@Model.AsyncAction" />
	<div id="PartialLoaderContainer">
        <partial name="_InputFieldsPartial" model="Model.DataSource" />
    </div> 	
	<div id="toolbar-container" class="btn-group" role="group">     
		<a asp-page="Index" id="btnCancelConfirmationModal" class="btn btnFills btn-outline-secondary btnBackIcon" aria-label="@Localizer["Back"]" title="@Localizer["Back"]"></a>
		<button type="button" id="btnConfirmationModal" class="btn btnFills btn-outline-success btnSaveIcon" aria-label="@Localizer["Save changes"]" title="@Localizer["Save changes"]"></button>
	</div>   	
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial" />

<script asp-add-nonce>
    $(document).ready(function () {
		$.bindSaveConfirmationModal('Save', '#btnConfirmationModal','#dataSource-form');
		$.bindCancelConfirmationModal('Cancel', '#btnCancelConfirmationModal','#dataSource-form', 'Do you want to cancel the changes?');
		function InitializeForm()
		{			

			$('.DisableSelectDropdown').on('mousedown', function(e) {
				e.preventDefault();
				this.blur();
				window.focus();
			});
			$('#DataSourceType').on('change', function () {
				$.triggerPageForm('ChangeFormValue', '#PartialLoaderContainer', '#dataSource-form', InitializeForm);
			});
		}
		InitializeForm();
    });
</script>
}