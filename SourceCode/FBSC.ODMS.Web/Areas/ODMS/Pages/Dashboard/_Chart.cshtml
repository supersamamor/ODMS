@using Models
@model IList<ReportResultViewModel>

@{
    // The dashboard's global header bar owns these filter parameters; they are
    // appended to every report's filter list server-side, so they must not
    // render again as per-widget inputs. Widget-specific filters still do.
    var globalFieldNames = new[]
    {
        FBSC.ODMS.Core.Constants.GlobalReportFilterFields.Project,
        FBSC.ODMS.Core.Constants.GlobalReportFilterFields.WeekNumber,
        FBSC.ODMS.Core.Constants.GlobalReportFilterFields.WeekStartDate,
        FBSC.ODMS.Core.Constants.GlobalReportFilterFields.WeekEndDate,
        FBSC.ODMS.Core.Constants.GlobalReportFilterFields.BusinessUnit,
    };
}

<input type="hidden" id="ReportListCount" value="@Model.Count" />

@if (Model?.Count > 0)
{
    int sequence = 1;

    <div class="row dashboard-widget-row">
        @foreach (var item in Model)
        {
            string columnWidthClass = item.SpanWidth switch
            {
                25 => "col-12 col-md-6 col-lg-3",
                50 => "col-12 col-md-6 col-lg-6",
                100 => "col-12",
                _ => "col-12 col-md-6 col-lg-6" // Defaults to 50%
            };
            string typeIconClass = item.ReportOrChartType switch
            {
                FBSC.ODMS.Core.Constants.ReportChartType.Table => "fas fa-table",
                FBSC.ODMS.Core.Constants.ReportChartType.Pie => "fas fa-chart-pie",
                FBSC.ODMS.Core.Constants.ReportChartType.Doughnut => "fas fa-circle-notch",
                FBSC.ODMS.Core.Constants.ReportChartType.PDF => "fas fa-file-pdf",
                FBSC.ODMS.Core.Constants.ReportChartType.HorizontalBar => "fas fa-chart-bar",
                FBSC.ODMS.Core.Constants.ReportChartType.StackedHorizontalBar => "fas fa-chart-bar",
                FBSC.ODMS.Core.Constants.ReportChartType.Bar => "fas fa-chart-bar",
                FBSC.ODMS.Core.Constants.ReportChartType.PolarArea => "fas fa-compass",
                FBSC.ODMS.Core.Constants.ReportChartType.CustomHtml => "fas fa-file-code",
                _ => "fas fa-chart-line"
            };
            var widgetFilters = (item.Filters ?? [])
                .Where(f => !globalFieldNames.Contains(f.FieldName, StringComparer.OrdinalIgnoreCase))
                .OrderBy(f => f.Sequence)
                .ToList();
            <div class="@columnWidthClass margin-bottom-20">
                <div class="card custom-card-container dashboard-widget-card dashboard-widget-animate">
                    <h5 class="card-header dashboard-widget-header d-flex justify-content-between align-items-center">
                        <span class="card-header-custom dashboard-widget-title">
                            <span class="dashboard-widget-type-icon" aria-hidden="true"><i class="@typeIconClass"></i></span>
                            <span class="dashboard-widget-title-text" title="@item.ReportName">@item.ReportName</span>
                        </span>
                        <div class="dashboard-widget-actions">
                            @if (widgetFilters.Count > 0)
                            {
                                <button type="button" class="btn btn-sm widget-icon-btn" data-bs-toggle="collapse" data-bs-target="#collapse_@item.DomId" aria-expanded="false" aria-controls="collapse_@item.DomId" title="@Localizer["Filters"]">
                                    <i class="fas fa-filter"></i>
                                </button>
                            }
                            @if (Configuration.GetValue<bool>("EnableGenerativeAIIntegration") && (await AuthorizationService.AuthorizeAsync(User, Permission.AIDrivenDataAnalysisAndInsights.View)).Succeeded)
                            {
                                <button type="button" data-reportid="@item.ReportId" class="btn btn-sm widget-icon-btn btnDataAnalyzeData" title="@Localizer["Data Analysis"]">
                                    <i class="fas fa-robot"></i>
                                </button>
                            }
                        </div>
                    </h5>

                    @if (widgetFilters.Count > 0)
                    {
                        <!-- Per-widget (report-specific) filters. Global filters are
                             excluded above - the dashboard header bar owns those. -->
                        <div class="collapse dashboard-widget-filters border-bottom" id="collapse_@item.DomId">
                            <div class="card-body dashboard-widget-filters-body">
                                <span class="dashboard-widget-filters-eyebrow"><i class="fas fa-sliders-h"></i>@Localizer["Filters"]</span>
                                <form id="form_@item.DomId" method="post" class="dashboard-filter-form" data-domid="@item.DomId" data-reportid="@item.ReportId">
                                    <div class="row row-cols-1 row-cols-sm-1 row-cols-md-2">
                                        @{
                                            int filterSequence = 1;
                                        }
                                        @foreach (var filter in widgetFilters)
                                        {
                                            <!-- Hidden inputs to construct the request model -->
                                            <input type="hidden" name="Filters[@(filterSequence - 1)].FieldName" value="@filter.FieldName" />
                                            <input type="hidden" name="Filters[@(filterSequence - 1)].DataType" value="@filter.DataType" />

                                            <div class="col">
                                                <div class="mb-3">
                                                    <div class="input-group">
                                                        <div class="input-group-prepend">
                                                            <span class="input-group-text"> @filter.FieldDescription </span>
                                                        </div>
                                                        @switch (filter.DataType)
                                                        {
                                                            case FBSC.ODMS.Core.Constants.DataTypes.CustomDropdown:
                                                                <select class="form-control" name="Filters[@(filterSequence - 1)].FieldValue" asp-items="@(dropdownService.GetDropdownFromCsv(filter.CustomDropdownValues!))">
                                                                    <option value="">- Select @filter.FieldDescription -</option>
                                                                </select>
                                                                break;
                                                            case FBSC.ODMS.Core.Constants.DataTypes.DropdownFromTable:
                                                                <select class="form-control" name="Filters[@(filterSequence - 1)].FieldValue" asp-items="@(await dropdownService.GetDropdownFromTableKeyValue(filter.DropdownTableKeyAndValue!, filter.DropdownFilter))">
                                                                    <option value="">- Select @filter.FieldDescription -</option>
                                                                </select>
                                                                break;
                                                            case FBSC.ODMS.Core.Constants.DataTypes.Years:
                                                                <select class="form-control" name="Filters[@(filterSequence - 1)].FieldValue" asp-items="@(dropdownService.GetYearsList(10, 0))">
                                                                    <option value="">- Select Year -</option>
                                                                </select>
                                                                break;
                                                            case FBSC.ODMS.Core.Constants.DataTypes.Months:
                                                                <select class="form-control" name="Filters[@(filterSequence - 1)].FieldValue" asp-items="@(dropdownService.GetMonthsList())">
                                                                    <option value="">- Select Month -</option>
                                                                </select>
                                                                break;
                                                            case FBSC.ODMS.Core.Constants.DataTypes.Date:
                                                                <input class="form-control" type="date" name="Filters[@(filterSequence - 1)].FieldValue" />
                                                                break;
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                            filterSequence++;
                                        }
                                        <div class="col">
                                            <div class="col">
                                                <button type="button" class="btn btn-violet text-light btn-sm btn-apply-filter" title="@Localizer["Apply Filters"]">
                                                    <i class="fas fa-file-import"></i> Apply
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }

                    <div class="card-body custom-graph-body dashboard-widget-body">
                        @if (item.ReportOrChartType == FBSC.ODMS.Core.Constants.ReportChartType.Table)
                        {
                            <table id="@item.DomId" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%"></table>
                        }
                        else if (item.ReportOrChartType == FBSC.ODMS.Core.Constants.ReportChartType.PDF)
                        {
                            <iframe id="PdfFrame_@item.DomId" src="@Url.Page("/ViewAttachment/Index", new { area = "ODMS", handler = "Preview", completeFilePath = item.PdfCompleteFilePath, timestamp = DateTime.Now.Ticks })" class="pdf-frame"></iframe>
                        }
                        else if (item.ReportOrChartType == FBSC.ODMS.Core.Constants.ReportChartType.CustomHtml)
                        {
                            <div id="CustomHtmlFrame_@item.DomId" class="dashboard-widget-custom-html">
                                @Html.Raw(item.CustomHtmlContent)
                            </div>
                        }
                        else
                        {
                            string canvasClass = item.ReportOrChartType switch
                            {
                                FBSC.ODMS.Core.Constants.ReportChartType.Pie => "pie-graph-canvas",
                                FBSC.ODMS.Core.Constants.ReportChartType.Doughnut => "pie-graph-canvas",
                                FBSC.ODMS.Core.Constants.ReportChartType.PolarArea => "pie-graph-canvas",
                                _ => "default-graph-canvas" // Bar, Horizontal Bar, Line, Radar
                            };
                            <canvas id="@item.DomId" class="@canvasClass"></canvas>
                        }
                    </div>
                </div>
            </div>

            <input type="hidden" id="ReportList_@(sequence - 1)_DomId" value="@item.DomId" />
            <input type="hidden" id="ReportList_@(sequence - 1)_ReportId" value="@item.ReportId" />
            <input type="hidden" id="ReportList_@(sequence - 1)_DrillDownReportId" value="@item.DrillDownReportId" />
            <input type="hidden" id="ReportList_@(sequence - 1)_ReportName" value="@item.ReportName" />
            <input type="hidden" id="ReportList_@(sequence - 1)_ReportOrChartType" value="@item.ReportOrChartType" />
            <input type="hidden" id="ReportList_@(sequence - 1)_ColumnHeaders" value="@item.ColumnHeaders" />
            <input type="hidden" id="ReportList_@(sequence - 1)_Results" value="@item.Results" />
            <input type="hidden" id="ReportList_@(sequence - 1)_DisplayLegend" value="@Html.Raw(item.DisplayLegend.ToString().ToLower())" />
            <input type="hidden" id="ReportList_@(sequence - 1)_IsPercentage" value="@Html.Raw(item.IsPercentage.ToString().ToLower())" />

            sequence++;
        }
    </div>
}
else
{
    <div class="dashboard-empty-state">
        <div class="dashboard-empty-state-icon" aria-hidden="true"><i class="fas fa-chart-line"></i></div>
        <div class="dashboard-empty-state-title">@Localizer["No widgets to show yet"]</div>
        <div class="dashboard-empty-state-subtitle">@Localizer["Reports added to this dashboard will appear here as charts, tables, and documents."]</div>
    </div>
}