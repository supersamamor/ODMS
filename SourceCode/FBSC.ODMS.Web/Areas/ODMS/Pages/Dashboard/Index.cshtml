@page
@model FBSC.ODMS.Web.Areas.ODMS.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveMainPage"] = "Dashboard";
    ViewData["Level1"] = "Dashboard";
}
@section Styles {
    <partial name="_DataTableStyles" />
}

@* Global header/filter bar (replaces the redundant "Dashboard" breadcrumb).
   Controls broadcast into each widget's existing filter form and trigger its
   Apply, so they only affect widgets whose report defines a matching filter. *@
<div class="dashboard-header-bar">
    <div class="dashboard-header-title">
        <h1>@Localizer["Executive Dashboard"]</h1>
        <p>@Localizer["Real-time view of all project portfolio"]</p>
    </div>
    <div class="dashboard-header-controls">
        <label class="dashboard-header-chip" title="@Localizer["Filter widgets by date"]">
            <i class="far fa-calendar-alt" aria-hidden="true"></i>
            <input type="date" id="globalFilterDate" aria-label="@Localizer["Filter widgets by date"]" />
        </label>
        <label class="dashboard-header-chip dashboard-header-search" title="@Localizer["Search widgets"]">
            <i class="fas fa-search" aria-hidden="true"></i>
            <input type="search" id="globalWidgetSearch" placeholder="@Localizer["Search widgets..."]" aria-label="@Localizer["Search widgets"]" />
        </label>
        <label class="dashboard-header-chip" title="@Localizer["Filter widgets by business unit"]">
            <i class="fas fa-filter" aria-hidden="true"></i>
            <select id="globalFilterBU" aria-label="@Localizer["Filter widgets by business unit"]" asp-items="@(dropdownService.GetBusinessUnitList(""))">
                <option value="">@Localizer["BU"]</option>
            </select>
        </label>
        <button type="button" id="btnDashboardExport" class="dashboard-header-chip dashboard-header-export" title="@Localizer["Export dashboard"]">
            <i class="fas fa-download" aria-hidden="true"></i>&nbsp;@Localizer["Export"]
        </button>
    </div>
</div>

<!-- Keep chart-form separate so it doesn't wrap the partial -->
<form id="chart-form" method="post">
    <input type="hidden" asp-for="@Model.SelectedReportId" />
</form>

<div id="PartialLoaderContainer">
    <partial name="_Chart" model="@Model.ReportList" />
</div>

@{
    var dataAnalyticsModalId = "data-analytics-modal";
}
<partial name="_ModalPartial" model="@dataAnalyticsModalId" />
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_ChartBuilderScripts" />
    <script asp-add-nonce>
        $(document).ready(function() {
            function RefreshChart() {
                var reportCount = $('#ReportListCount').val();
                for (let idx = 0; idx < reportCount; idx++) {
                    var domId = $('#ReportList_' + idx + '_DomId').val();
                    var reportId = $('#ReportList_' + idx + '_ReportId').val();
                    var drillDownReportId = $('#ReportList_' + idx + '_DrillDownReportId').val();
                    var reportName = $('#ReportList_' + idx + '_ReportName').val();
                    var reportOrChartType = $('#ReportList_' + idx + '_ReportOrChartType').val();
                    var columnHeaders = $('#ReportList_' + idx + '_ColumnHeaders').val();
                    var results = $('#ReportList_' + idx + '_Results').val();
                    var displayLegend = $('#ReportList_' + idx + '_DisplayLegend').val();
                    var isPercentage = $('#ReportList_' + idx + '_IsPercentage').val();

                    // SAFE PARSING: Fallback to null if the string is empty (e.g., for PDF widgets)
                    var parsedHeaders = columnHeaders ? JSON.parse(columnHeaders) : null;
                    var parsedResults = results ? JSON.parse(results) : null;

                    $.BuildChart(domId, reportName, reportOrChartType, parsedHeaders, parsedResults, displayLegend, isPercentage, reportId, drillDownReportId);
                }
            }

            RefreshChart();

            // ---- Global header/filter bar ----

            // Live widget search: hides widget cards whose title doesn't match.
            $('#globalWidgetSearch').on('input', function () {
                var term = $(this).val().toLowerCase();
                $('.dashboard-widget-card').each(function () {
                    var title = $(this).find('.dashboard-widget-title-text').text().toLowerCase();
                    $(this).closest('[class*="col-"]').toggle(title.indexOf(term) > -1);
                });
            });

            // Pushes a value into every widget filter the matcher accepts,
            // then reuses that widget's own Apply (ajax refresh + spinner).
            function broadcastGlobalFilter(matcher, value) {
                $('.dashboard-filter-form').each(function () {
                    var form = $(this);
                    var touched = false;
                    form.find('input[type="hidden"][name$=".FieldName"]').each(function () {
                        var idxMatch = $(this).attr('name').match(/Filters\[(\d+)\]/);
                        if (!idxMatch) { return; }
                        var valueEl = form.find('[name="Filters[' + idxMatch[1] + '].FieldValue"]');
                        if (matcher($(this).val() || '', valueEl)) {
                            valueEl.val(value);
                            touched = true;
                        }
                    });
                    if (touched) {
                        form.find('.btn-apply-filter').trigger('click');
                    }
                });
            }

            // BU: targets widget filters whose field name mentions BusinessUnit.
            $('#globalFilterBU').on('change', function () {
                var value = $(this).val();
                broadcastGlobalFilter(function (fieldName) {
                    return fieldName.toLowerCase().indexOf('businessunit') > -1;
                }, value);
            });

            // Date: targets every Date-type widget filter.
            $('#globalFilterDate').on('change', function () {
                var value = $(this).val();
                broadcastGlobalFilter(function (fieldName, valueEl) {
                    return valueEl.attr('type') === 'date';
                }, value);
            });

            $('#btnDashboardExport').on('click', function () {
                window.print();
            });

            $('.dashboard-filter-form .btn-apply-filter').on('click', function(e) {            
                e.preventDefault(); // Prevents any default button behavior

                var submitBtn = $(this);
                var form = submitBtn.closest('form'); // Dynamically find the parent form

                var reportId = form.data('reportid');
                var domId = form.data('domid');
                var originalBtnHtml = submitBtn.html();

                // Extract the anti-forgery token from this specific form
                var token = form.find('input[name="__RequestVerificationToken"]').val();

                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Loading...');

                $.ajax({
                    url: '?handler=RefreshDashboardWidget&reportId=' + encodeURIComponent(reportId),
                    type: 'POST',
                    data: form.serialize(),
                    headers: {
                        "RequestVerificationToken": token
                    },
                    success: function(response) {
                        if (response.success) {

                            // Handle PDF rendering by updating the iframe source directly
                            if (response.reportOrChartType === 'PDF') {
                                $('#PdfFrame_' + domId).attr('src', response.pdfUrl);
                            }
                            else if (response.reportOrChartType === 'Custom Html') {
                                $('#CustomHtmlFrame_' + domId).html(response.customHtmlContent);
                            }
                            // Handle standard charts and tables
                            else {
                                var reportCount = $('#ReportListCount').val();
                                var reportName = "";
                                var isPercentage = "false";
                                var drillDownReportId = "";

                                for (let idx = 0; idx < reportCount; idx++) {
                                    if ($('#ReportList_' + idx + '_DomId').val() === domId) {
                                        reportName = $('#ReportList_' + idx + '_ReportName').val();
                                        isPercentage = $('#ReportList_' + idx + '_IsPercentage').val();
                                        drillDownReportId = $('#ReportList_' + idx + '_DrillDownReportId').val();
                                        break;
                                    }
                                }

                                var parsedHeaders = response.columnHeaders ? JSON.parse(response.columnHeaders) : null;
                                var parsedResults = response.results ? JSON.parse(response.results) : null;

                                $.BuildChart(
                                    domId,
                                    reportName,
                                    response.reportOrChartType,
                                    parsedHeaders,
                                    parsedResults,
                                    response.displayLegend,
                                    isPercentage === "true",
                                    reportId,
                                    drillDownReportId
                                );
                            }
                        } else {
                            alert("Error refreshing data.");
                        }
                    },
                    error: function(xhr) {
                        console.error(xhr.responseText);
                        alert("A critical error occurred while fetching data. Check console for details.");
                    },
                    complete: function() {
                        submitBtn.prop('disabled', false).html(originalBtnHtml);
                    }
                });
            });
            function analyzeDataModalPopup(reff) {
                var reportId = $(reff)[0].dataset.reportid;
                $('#SelectedReportId').val(reportId);
                openDataAnalyticsModal('@dataAnalyticsModalId');
            }
            $(".btnDataAnalyzeData").on('click', function(e) {
                analyzeDataModalPopup(this);
            });
            function openDataAnalyticsModal(modalId) {
                $('body').removeClass('loaded');
                var url = '?handler=DataAnalytics';

                $.post(url, $('#chart-form').serialize(), function(response) {
                    var placeholderElement = $('#' + modalId);
                    placeholderElement.find('.modal-body').html(response);
                    placeholderElement.find('.modal-title').html("");
                    placeholderElement.find('.modal').modal('show');

                    // Event handler for the close button
                    placeholderElement.find('.modal-footer .btnClose').click(function() {
                        placeholderElement.find('.modal').modal('hide');
                    });

                    // Event handler for the 'x' button
                    placeholderElement.find('.modal-header .close').click(function() {
                        placeholderElement.find('.modal').modal('hide');
                    });

                    $('body').addClass('loaded');
                }).fail(function() { });
            }
        });
    </script>
}