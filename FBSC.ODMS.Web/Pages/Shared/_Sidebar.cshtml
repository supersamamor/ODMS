                    {
                        <li class="nav-item">
                            <a href="/ODMS/ReportSetup" class="nav-link @ManageNavPages.PageNavClass(ViewContext, "ReportSetup")">
                                <span>
                                    @Localizer["Report Setup"]
                                </span>
                            </a>
                        </li>
                    }
					@if ((await AuthorizationService.AuthorizeAsync(User, FBSC.HTMLTemplate.HTMLTemplatePermission.HTMLTemplate.View)).Succeeded)
					{
						<li class="nav-item">
							<a href="/HTMLTemplate/Setup" class="nav-link @ManageNavPages.PageNavClass(ViewContext, "HTMLTemplate")">
								<span>
									@Localizer["HTML Template"]
