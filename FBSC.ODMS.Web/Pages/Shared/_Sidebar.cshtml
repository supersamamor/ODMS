								<a href = "/ODMS/DashboardTheme" class="nav-link @ManageNavPages.PageNavClass(ViewContext, "DashboardTheme")">
									<span>
										@Localizer["Dashboard Theme"]
									</span>
								</a>
							</li>
						}
						@if((await AuthorizationService.AuthorizeAsync(User, Permission.Dashboard.View)).Succeeded)
						{
							<li class="nav-item">
								<a href = "/ODMS/Dashboard" class="nav-link @ManageNavPages.PageNavClass(ViewContext, "Dashboard")">
									<span>
										@Localizer["Dashboard"]
									</span>
								</a>
							</li>
						}
						@if((await AuthorizationService.AuthorizeAsync(User, Permission.AiSqlGenerationRequest.View)).Succeeded)
						{
							<li class="nav-item">
								<a href = "/ODMS/AiSqlGenerationRequest" class="nav-link @ManageNavPages.PageNavClass(ViewContext, "AiSqlGenerationRequest")">
