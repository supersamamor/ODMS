@page
@model EditModel
@section Styles {
<partial name="_DataTableStyles" />
}
@{
    ViewData["Title"] = Localizer["Edit Application"];
    ViewData["ActiveMainPage"] = "Applications";
    ViewData["Level1"] = "Admin";
    var breadcrumbs = new[] {
        new { Title = "Application List", Url = "/Admin/Applications/Index", IsActive = false },
        new { Title = "Edit Application", Url = "", IsActive = true },
    };
}
<partial name="_BreadcrumbPartial" model=@(breadcrumbs) />
<form id="application-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="card">
        <h5 class="card-header"><span class="card-header-custom">@Localizer["Application Info"]</span><br></h5>
        <div class="card-body">
            <partial name="_EditApplicationDetails" model="Model.Application" />
        </div>
    </div>
    <br />
    <div class="card">
        <h5 class="card-header"><span class="card-header-custom">@Localizer["Permissions"]</span><br></h5>
        <div class="card-body overflow-x-scroll">
            <partial name="_EditPermissions" model="Model.ApplicationPermissions" />
        </div>
    </div>
    <div id="toolbar-container" class="btn-group" role="group">
        <a asp-page="Index" id="btnCancelConfirmationModal" class="btn btnFills btn-outline-secondary btnBackIcon" title="@Localizer["Back"]"></a>
		<button asp-page-handler="Generate" type="submit" class="btn btn-primary" title="@Localizer["Save changes"]"><i class="fas fa-key"></i></button>
        <button type="button" id="btnConfirmationModal" class="btn btnFills btn-outline-success btnSaveIcon" title="@Localizer["Save changes"]"></button>
    </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<partial name="_DataTableScripts" />
<script asp-add-nonce>
    $(document).ready(function () {
		$.bindSaveConfirmationModal('Save', '#btnConfirmationModal', '#application-form');
		$.bindCancelConfirmationModal('Cancel', '#btnCancelConfirmationModal', '#application-form', 'Do you want to cancel the changes?');
        var permissions = $("#permissions").DataTable({
            select: false,
            searching: true,
            paging: true,
			dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
            info: true,
            buttons: [],
            columnDefs: [
                {
                    targets: [1],
                    orderDataType: 'dom-checkbox',
                }
            ]
        });
        $('#application-form').onSubmitIncludeAllFieldsFromTable(permissions);
    });
	function generateRandomSecret() {
		// Generate 32 bytes of random data and convert to Base64
		const array = new Uint8Array(32);
		window.crypto.getRandomValues(array);

		// Convert to Base64 string
		const secret = btoa(String.fromCharCode.apply(null, array));

		const input = document.getElementById("hmacSecretInput");
		input.value = secret;
		input.type = "text"; // Show the user what was generated
	}

	function toggleSecretVisibility() {
		const input = document.getElementById("hmacSecretInput");
		input.type = input.type === "password" ? "text" : "password";
	}
</script>
}