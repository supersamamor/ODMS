@page
@model IndexModel
@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["ActiveMainPage"] = "Entities";
    ViewData["Title"] = Localizer["Entities List"];
    ViewData["Level1"] = "Admin";
    IEnumerable<dynamic> breadCrumbs = [new { Title = "Entities List", Url = "", IsActive = true }];
}
<partial name="_BreadcrumbPartial" model=@(breadCrumbs) />
<div class="card">
    <div class="card-body">
        <table id="entities" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%">
            <thead>
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.Entity.Name)
                    </th>
                    <th>
                        @Localizer["Actions"]
                    </th>
                </tr>
            </thead>
        </table>
    </div>
</div>

@section Scripts {
    <partial name="_DataTableScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var table = $('#entities').DataTable({
                select: false,
                serverSide: true,
                order: [[0, 'asc']],
                dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                ajax:
                {
                    url: '@Url.Page("/Entities/Index", new { area = "Admin", handler = "ListAll" })',
                    type: "POST",
                    headers: {
                        RequestVerificationToken:
                            $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                },
                columns: [
                    { data: "name", name: "Name", responsivePriority: 1 },
                    {
                        data: null,
                        searchable: false,
                        orderable: false,
                        responsivePriority: 2,
                        width: "10%",
                        className: "text-center",
                        render: function (data, type, row, meta) {
                            var url = '@Url.Page("/Entities/View", new { area = "Admin" })' + '?id=' + row.id;
                            var button = '<a href="' + url + '" class="btn btnFills btn-outline-success btnInfoIcon" title="@Localizer["View"]"></a>';
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Entities.Edit)).Succeeded)
        {
            <text>
                                    url = '@Url.Page("/Entities/Edit", new { area = "Admin" })' + '?id=' + row.id;
                                button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnEditIcon" title="@Localizer["Edit"]"></a>';
            </text>
        }
                            return button;
                        },
                    },
                    { data: "id", name: "Id", visible: false },
                ],
                buttons: [
        @* Add Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Entities.Create)).Succeeded)
        {
            <text>
                                {
                                    text: '<i class="fas fa-plus"></i>',
                                    className: 'btn btn-success btnAddEntities text-light',
                                    titleAttr: '@Localizer["Add"]',
                                    action: function (e, dt, node, config) {
                                        window.location.href = '@Url.Page("/Entities/Add", new { area = "Admin" })';
                                    }
                                },
            </text>
        }
        @* Page Length Button *@
            {
                extend: 'pageLength',
                className: 'btn btn-primary',
                titleAttr: '@Localizer["Rows per page"]'
            }
                ],
            });
            var debounce = new $.fn.dataTable.Debounce(table); // Add delay to search
            $.InitializeSearchKeyCookies(table);
        });
    </script>
}