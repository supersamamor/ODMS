@using Models
@model IList<UserRoleViewModel>
<table id="roles" class="table table-hover table-bordered table-striped fills-table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.First().Name)
            </th>
            <th class="text-center">
                @Html.DisplayNameFor(model => model.First().Selected)
            </th>
        </tr>
    </thead>
    <tbody>
        @for (int i = 0; i < Model.Count(); i++)
        {
            <tr>
                <td>
                    @Model[i].Name
                </td>
                <td class="text-center">
                    @if (Model[i].Selected)
                    {
                        <input type="checkbox" name="Roles[@(i)].Selected" class="form-check-input" value=true checked />
                    }
                    else
                    {
                        <input type="checkbox" name="Roles[@(i)].Selected" class="form-check-input" value=true />
                    }
                    <input type="hidden" asp-for="@Model[i].Name" name="Roles[@(i)].Name" />
                </td>
            </tr>
        }
    </tbody>
</table>