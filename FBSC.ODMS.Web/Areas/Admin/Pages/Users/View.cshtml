@page
@model ViewModel
@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["Title"] = Localizer["View User"];
    ViewData["ActiveMainPage"] = "Users";
    ViewData["Level1"] = "Admin";
    var breadcrumbs = new[] {
        new { Title = "Users List", Url = "/Admin/Users/Index", IsActive = false },
        new { Title = "View User", Url = "", IsActive = true },
    };
}
<partial name="_BreadcrumbPartial" model=@(breadcrumbs) />
<div class="container-fluid" id="user-container">
    <input type="hidden" asp-for="@Model.UserModel!.Id" name="Id" />
    <div id="PartialLoaderContainer">
        <partial name="_InputFieldsPartial" model="Model.UserModel" />
    </div>
</div>

<div id="toolbar-container" class="btn-group" role="group">
    <a asp-page="Index" class="btn btnFills btn-outline-secondary btnBackIcon" title="@Localizer["Back"]"></a>
    @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Users.Create)).Succeeded)
    {
        <a asp-page="Add" id="btnAddRecord" class="btn btnFills btn-outline-success btnAddIcon" title="@Localizer["Add"]"></a>
    }
    @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Users.Edit)).Succeeded)
    {
        <a asp-page="Edit" asp-route-id="@Model.UserModel.Id" class="btn btnFills btn-outline-primary btnEditLightIcon" title="@Localizer["Edit"]"></a>
    }
</div>

@section Scripts {
    <partial name="_DataTableScripts" />
    <partial name="_DisableFieldsPartial" model="@("user-container")" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var roles = $("#roles").DataTable({
                select: false,
                searching: true,
                paging: true,
				dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                info: true,
                buttons: [],
                columnDefs: [
                    {
                        targets: [1],
                        orderDataType: 'dom-checkbox',
                    }
                ]
            });
        });
    </script>
}