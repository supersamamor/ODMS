@page
@model AddModel
@{
    ViewData["Title"] = Localizer["Add API"];
    ViewData["ActiveMainPage"] = "APIs";
    ViewData["Level1"] = "Admin";
    var breadcrumbs = new[] {
        new { Title = "APIs List", Url = "/Admin/Apis/Index", IsActive = false },
        new { Title = "Add API", Url = "", IsActive = true },
    };
}
<partial name="_BreadcrumbPartial" model=@(breadcrumbs) />
<form id="api-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="card">
        <h5 class="card-header"><span class="card-header-custom">@Localizer["API Info"]</span><br></h5>
        <div class="card-body">
            <partial name="_EditApiDetails" model="Model.Scope" />
        </div>
    </div>
    <div id="toolbar-container" class="btn-group" role="group">
        <a asp-page="Index" id="btnCancelConfirmationModal" class="btn btnFills btn-outline-secondary btnBackIcon" title="@Localizer["Back"]"></a>
        <button type="button" id="btnConfirmationModal" class="btn btnFills btn-outline-success btnSaveIcon" title="@Localizer["Save changes"]"></button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script asp-add-nonce>
        $(document).ready(function () {
            $.bindSaveConfirmationModal('Save', '#btnConfirmationModal', '#api-form');
            $.bindCancelConfirmationModal('Cancel', '#btnCancelConfirmationModal', '#api-form', 'Do you want to cancel the changes?');           
        });
    </script>
}