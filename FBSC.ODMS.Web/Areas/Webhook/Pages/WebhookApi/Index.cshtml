@page
@model IndexModel

@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["Title"] = Localizer["Webhook / Api List"];
    ViewData["ActiveMainPage"] = "WebhookApi";
    ViewData["Level1"] = "Admin";
	IEnumerable<dynamic> breadCrumbs = [new { Title = "Webhook / Api List", Url = "", IsActive = true }];
}
<partial name="_BreadcrumbPartial" model=@(breadCrumbs) />
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <table id="webhookApi" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%">
                    <thead>
                        <tr>
                            <th>
                                @Localizer["Name"]
                            </th>
                            <th>
                                @Localizer["Grant Type"]
                            </th>
                            <th>
                                @Localizer["Within Private Network"]
                            </th>
                            <th>
                                @Localizer["Base Url"]
                            </th>
                            <th>
                                @Localizer["Actions"]
                            </th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>
<div id="BatchUploadPartialContainer">
    <partial name="_BatchUpload" model="Model.BatchUpload" />
</div>
@section Scripts {
    <partial name="_DataTableScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var table = $('#webhookApi').DataTable({
                select: false,
                serverSide: true,
                responsive: true,
                order: [[5, 'desc']],
                dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                ajax:
                {
                    url: '@Url.Page("/WebhookApi/Index", new { area = "Webhook", handler = "ListAll" })',
                    type: "POST",
                    headers: {
                        RequestVerificationToken:
                            $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                },
                initComplete: function (settings, json) {
                    BindTableRowCollapseEvent();
                },
                columns: [
                    { data: "name", name: "Name", responsivePriority: 1, title: '@Localizer["Name"]', searchable: true, className: "text-start" },
                    { data: "grantType", name: "GrantType", responsivePriority: 1, title: '@Localizer["Grant Type"]', searchable: false, className: "text-start" },
                    { data: "withinPrivateNetworkFormatted", name: "WithinPrivateNetwork", responsivePriority: 1, title: '@Localizer["Within Private Network"]', searchable: false, className: "text-center" },
                    { data: "baseUrl", name: "BaseUrl", responsivePriority: 2, title: '@Localizer["Base Url"]', searchable: false, className: "text-start" },
                    {
                        data: null,
                        searchable: false,
                        orderable: false,
                        responsivePriority: 1,
                        width: "10%",
                        className: "text-center",
                        render: function (data, type, row, meta) {
                            var url = '@Url.Page("/WebhookApi/Details", new { area = "Webhook" })' + '?id=' + row.id;
                            var button = '<a href="' + url + '" class="btn btnFills btn-outline-success btnInfoIcon btnViewWebhookApi" title="@Localizer["View"]"></a>';
        @if ((await AuthorizationService.AuthorizeAsync(User,  FBSC.ApiHub.WebhookPermission.WebhookApi.Edit)).Succeeded)
        {
            <text>
                                    url = '@Url.Page("/WebhookApi/Edit", new { area = "Webhook" })' + '?id=' + row.id;
                                    button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnEditIcon btnEditWebhookApi" title="@Localizer["Edit"]"></a>';
            </text>
        }
        @if ((await AuthorizationService.AuthorizeAsync(User,  FBSC.ApiHub.WebhookPermission.WebhookApi.History)).Succeeded)
        {
            <text>
                                    url = '@Url.Page("/WebhookApi/History", new { area = "Webhook" })' + '?id=' + row.id;
                                    button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btn btnFills btnHistoryIcon" title="@Localizer["History"]"></a>';
            </text>
        }
        @if ((await AuthorizationService.AuthorizeAsync(User,  FBSC.ApiHub.WebhookPermission.WebhookApi.Logs)).Succeeded)
        {
            <text>
                                    url = '@Url.Page("/WebhookApi/Logs", new { area = "Webhook" })' + '?webhookApiId=' + row.id;
                                    button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-success btnApprovalList btnLogsWebhookApi" title="@Localizer["Logs"]"></a>';
            </text>
        }
                return button;
                        },
                    },
                    { data: "lastModifiedDate", name: "LastModifiedDate", title: '@Localizer["Last Modified Date"]', visible: false, searchable: false },
                    { data: "id", name: "Id", visible: false },
                ],
                buttons: [
            @* Add Button *@
            @if ((await AuthorizationService.AuthorizeAsync(User, FBSC.ApiHub.WebhookPermission.WebhookApi.Create)).Succeeded)
            {
                <text>
                        {
                            text: '<i class="fas fa-plus"></i>',
                            className: 'btn btn-success btnAddWebhookApi text-light',
                            titleAttr: '@Localizer["Add"]',
                            action: function (e, dt, node, config) {
                                window.location.href = '@Url.Page("/WebhookApi/Add", new { area = "Webhook" })';
                            }
                        },
                </text>
            }
            @* Page Length Button *@
            {
                extend: 'pageLength',
                className: 'btn btn-primary',
                titleAttr: '@Localizer["Rows per page"]'
            }
                ],
            });
            var debounce = new $.fn.dataTable.Debounce(table); // Add delay to search

            $('.btn-table_filter').on('click', function (e) {
                table.ajax.reload(null, false);
            });
            function BindTableRowCollapseEvent() {
                $('#webhookApi tbody').on('click', 'td.dtr-control', function () {
                    $.showAjaxLoaderOnClick([".btnAddWebhookApi", ".btnEditWebhookApi", ".btnViewWebhookApi", ".btnDeleteWebhookApi", ".btnLogsWebhookApi"]);
                });
            }
            $.showAjaxLoaderOnClick([".btnAddWebhookApi", ".btnEditWebhookApi", ".btnViewWebhookApi", ".btnDeleteWebhookApi"]);
            $.InitializeSearchKeyCookies(table);
            $('#btnBatchUpload').on('change', function (e) {
                $('#batch-upload-form').submit();
            });
          
        @if (!string.IsNullOrEmpty(Model.BatchUpload.BatchUploadFileName))
        {
            <text>
                    $('#btnDownloadBatchUploadTemplateLink')[0].click();
            </text>
        }
                                        });
    </script>
}