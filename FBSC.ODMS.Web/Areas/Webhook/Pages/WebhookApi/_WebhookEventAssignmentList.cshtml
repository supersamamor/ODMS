@model FBSC.ApiHub.ViewModels.WebhookApiViewModel

<input type="hidden" id="WebhookEventAssignmentCount" value="@Model?.WebhookEventAssignmentList?.Count" />

<div class="card">
    <h5 class="card-header d-flex justify-content-between align-items-center">
        <span class="card-header-custom">@Localizer["Webhook Event Assignment"]</span>
        <div>
            <a id="btnAddWebhookEventAssignment" class="btn btnMaterial btn-flat primary semicircle cancel btnAddRemoveSubDetailList text-light" title="@Localizer["Add"]"><i class="fas fa-plus"></i></a>
            <button class="cancel d-none" type="button" id="btnRemoveWebhookEventAssignment" value="RemoveWebhookEventAssignment"></button>
        </div>
    </h5>
    <div class="card-body overflow-auto">
        <table id="subDetailList" class="table table-hover table-bordered table-striped responsive nowrap fills-table align-middle" width="100%">
            <thead>
                <tr>
                    <th class="d-none"></th>
                    <th>@Localizer["Event Name"]</th>
                    <th>@Localizer["Method"]</th>
                    <th>@Localizer["Route"]</th>
                    <th class="text-center">@Localizer["Active"]</th>
                    <th class="text-center">@Localizer["Action"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.WebhookEventAssignmentList != null)
                {
                    int counter = 0;
                    foreach (var item in Model.WebhookEventAssignmentList)
                    {
                        <tr>
                            <td class="d-none">
                                <input type="hidden" name="WebhookEventAssignmentList[@counter].Id" value="@item.Id" />
                                <input type="hidden" name="WebhookEventAssignmentList[@counter].WebhookApiId" value="@item.WebhookApiId" />
                                <input asp-for="@item.NewRecord" type="hidden" name="WebhookEventAssignmentList[@counter].NewRecord" />
                            </td>
                            <td>
                                <select asp-for="@item.EventName" name="WebhookEventAssignmentList[@counter].EventName" class="form-select" asp-items="@(dropdownService.WebhookEventList())">
                                    <option value="">- Select Event -</option>
                                </select>
                                <span data-valmsg-for="WebhookEventAssignmentList[@counter].EventName" asp-validation-for="@item.EventName" class="text-danger"></span>
                            </td>
                            <td>
                                <select asp-for="@item.Method" name="WebhookEventAssignmentList[@counter].Method" class="form-select" asp-items="@(FBSC.ApiHub.Services.DropdownServices.HttpMethodList())">
                                    <option value="">- Select Http Method -</option>
                                </select>
                                <span data-valmsg-for="WebhookEventAssignmentList[@counter].Method" asp-validation-for="@item.Method" class="text-danger"></span>
                            </td>
                            <td>
                                <input asp-for="@item.Route" name="WebhookEventAssignmentList[@counter].Route" class="form-control" />
                                <span data-valmsg-for="WebhookEventAssignmentList[@counter].Route" asp-validation-for="@item.Route" class="text-danger"></span>
                            </td>
                            <td class="text-center">
                                <input asp-for="@item.Active" name="WebhookEventAssignmentList[@counter].Active" class="custom-checkbox-label" />
                            </td>
                            <td class="text-center">
                                <a class="btn btnMaterial btn-flat accent semicircle cancel RemoveWebhookEventAssignmentButton btnAddRemoveSubDetailList" title="@Localizer["Remove WebhookEventAssignment"]" removeId="@(item.Id)"><i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                        counter++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>