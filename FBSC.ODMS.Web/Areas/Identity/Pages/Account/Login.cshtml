@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
    Layout = "_Layout";
    var appName = Configuration.GetValue<string>("Application");
    var userIcon = "/img/Login_Icons/Userx16.png";
    var passwordIcon = "/img/Login_Icons/Passwordx16.png";
    // Check if there's a validation error and get the error message
    var errorMessage = "";
    if (ViewData.ModelState[""]?.Errors?.Count > 0)
    {
        var error = ViewData.ModelState[""]?.Errors.FirstOrDefault()?.ErrorMessage;
        if (error == "Invalid login attempt.")
        {
            errorMessage = "Your credentials did not match our records. Check your credentials and try again.";
        }
        else
        {
            errorMessage = error;
        }
    }
}
<div class="insightforge-auth-scope">
    <div class="auth-split">
        <div class="col-lg-6 d-none d-lg-flex auth-banner-pane">
            <div>
                <!-- Schema-agnostic dashboards over any connected data source: several
                     source icons (HRIS/accounting/inventory/custom) flowing into one
                     dashboard panel with mixed chart types. object-fit: contain via CSS so
                     the whole illustration always stays visible, never cropped. -->
                <svg class="auth-banner-illustration" viewBox="0 0 480 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="authBannerTitle">
                    <title id="authBannerTitle">Illustration of several external data sources feeding into one dashboard</title>
                    <g fill="none" stroke="currentColor" stroke-width="2.5" opacity="0.9">
                        <rect x="16" y="28" width="72" height="52" rx="8" />
                        <path d="M28 48h48M28 58h32" stroke-width="2" />
                        <rect x="16" y="134" width="72" height="52" rx="8" />
                        <circle cx="52" cy="152" r="10" />
                        <path d="M40 176c2-8 8-12 12-12s10 4 12 12" stroke-width="2" />
                        <rect x="16" y="240" width="72" height="52" rx="8" />
                        <path d="M28 266l10-10 8 6 14-16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </g>
                    <g stroke="currentColor" stroke-width="2" opacity="0.55" fill="none" stroke-dasharray="4 5">
                        <path d="M88 54C150 54 150 130 210 130" />
                        <path d="M88 160C150 160 150 160 210 160" />
                        <path d="M88 266C150 266 150 190 210 190" />
                    </g>
                    <g>
                        <rect x="214" y="60" width="250" height="200" rx="14" fill="currentColor" opacity="0.12" />
                        <rect x="214" y="60" width="250" height="200" rx="14" fill="none" stroke="currentColor" stroke-width="2.5" />
                        <rect x="238" y="176" width="22" height="60" rx="3" fill="currentColor" opacity="0.85" />
                        <rect x="270" y="152" width="22" height="84" rx="3" fill="currentColor" opacity="0.85" />
                        <rect x="302" y="128" width="22" height="108" rx="3" fill="currentColor" opacity="0.85" />
                        <rect x="334" y="164" width="22" height="72" rx="3" fill="currentColor" opacity="0.85" />
                        <path d="M238 108c0-16 13-29 29-29s29 13 29 29-13 29-29 29" fill="none" stroke="currentColor" stroke-width="2.5" />
                        <path d="M267 79v29l22 15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                        <path d="M366 90h74M366 100h58M366 110h66" stroke="currentColor" stroke-width="2" opacity="0.7" />
                    </g>
                </svg>
                <div class="auth-banner-copy">
                    <h2>One dashboard, every data source</h2>
                    <p>Connect any MS SQL database - HRIS, accounting, inventory, or custom - and turn it into live charts, tables, and KPIs without redesigning a thing.</p>
                </div>
            </div>
        </div>
        <div class="col-lg-6 auth-form-pane">
            <div class="auth-form-card">
                <div class="brand-lockup">
                    <svg class="brand-mark" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true">
                        <rect x="2" y="6" width="26" height="26" rx="6" fill="none" stroke="currentColor" stroke-width="2.5" />
                        <rect x="8" y="20" width="4" height="7" rx="1" fill="currentColor" />
                        <rect x="14" y="15" width="4" height="12" rx="1" fill="currentColor" />
                        <rect x="20" y="11" width="4" height="16" rx="1" fill="currentColor" />
                        <circle cx="33" cy="9" r="4" fill="none" stroke="currentColor" stroke-width="2" />
                        <circle cx="35" cy="23" r="3" fill="none" stroke="currentColor" stroke-width="2" />
                        <path d="M29 11 L26 15 M31 21 L27 23" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none" />
                    </svg>
                    <span class="brand-wordmark">InsightForge</span>
                </div>
                @if (string.Compare(Configuration["Authentication:EmailLoginEnabled"], "true", true) == 0)
                {
                    <!-- Modal -->
                    <div class="modal fade" id="errorModal" tabindex="-1" aria-labelledby="errorModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered col-md-3">
                            <div class="modal-content">
                                <div class="modal-header justify-content-center">
                                    <span class="icon-circle bg-danger"><i class="fas fa-times"></i></span>
                                </div>
                                <div class="modal-body mt-0 pt-0">
                                    <h5 class="text-danger">Login Failed!</h5>
                                    <p class="p-0 m-0">Your credentials did not match our records.<br>Check your credentials and try again.</p>
                                </div>
                                <div class="modal-footer justify-content-center border-top-0 pt-0 mt-0">
                                    <button type="button" class="btn btn-lg radius-100  btn-primary col" data-bs-dismiss="modal">Try again</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <form id="account" method="post" class="user">
                        <div class="mb-3 input-container">
                            <label for="Email" class="form-label custom-label">Email Address</label>
                            <div class="input-wrapper">
                                <img src="@userIcon" alt="" class="icon">
                                <input type="email" id="Email" name="Input.Email" class="form-control" placeholder="Enter email address">
                            </div>
                            <small><span asp-validation-for="Input!.Email" class="text-danger"></span></small>
                        </div>
                        <div class="mb-3">
                            <label for="Password" class="form-label custom-label">Password</label>
                            <div class="input-wrapper">
                                <img src="@passwordIcon" alt="" class="icon"> <!-- Add lock icon -->
                                <input type="password" id="Password" name="Input.Password" class="form-control" placeholder="Enter Password">
                                <span class="toggle-password"><i class="fas fa-eye-slash"></i></span>
                            </div>
                            <small><span asp-validation-for="Input!.Password" class="text-danger"></span></small>
                        </div>
                        @if (string.Compare(Configuration["Authentication:EmailLoginEnabled"], "true", true) == 0)
                        {
                            <div class="mb-3 login-link-container">
                                <div class="text-center custom-label">
                                    <a class="login-link" asp-page="./ForgotPassword">Forgot Password?</a>
                                </div>
                            </div>
                            <div class="mb-3 login-link-container">
                                <div class="text-center custom-label">
                                    <a class="login-link" asp-page="./Register">Create an Account!</a>
                                </div>
                            </div>
                        }

                        <button type="submit" class="btnSubmit btn btn-primary d-block btn-user w-100">Login</button>
                    </form>
                }
                @if (!string.IsNullOrEmpty(Configuration["Authentication:Microsoft:ClientId"]) ||
                                    !string.IsNullOrEmpty(Configuration["Authentication:Google:ClientId"]))
                {
                    <div class="social-login-section">
                        @* Microsoft Login *@
                        @if (!string.IsNullOrEmpty(Configuration["Authentication:Microsoft:ClientId"]))
                        {
                            <form id="microsoft-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                                <input type="hidden" name="provider" value="Microsoft">
                                <button type="submit" class="btn btn-outline-primary d-block btn-user w-100 mb-2" alt="Sign in using Microsoft">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 23 23" width="20" height="20" class="me-2">
                                        <rect x="1" y="1" width="10" height="10" fill="#f25022" />
                                        <rect x="12" y="1" width="10" height="10" fill="#7fba00" />
                                        <rect x="1" y="12" width="10" height="10" fill="#00a4ef" />
                                        <rect x="12" y="12" width="10" height="10" fill="#ffb900" />
                                    </svg>
                                    Sign in with Microsoft
                                </button>
                            </form>
                        }

                        @* Google Login *@
                        @if (!string.IsNullOrEmpty(Configuration["Authentication:Google:ClientId"]))
                        {
                            <form id="google-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                                <input type="hidden" name="provider" value="Google">
                                <button type="submit" class="btn btn-outline-danger d-block btn-user w-100" alt="Sign in using Google">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20" height="20" class="me-2">
                                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                                        <path fill="none" d="M0 0h48v48H0z" />
                                    </svg>
                                    Sign in with Google
                                </button>
                            </form>
                        }
                    </div>
                }
                <div class="text-center mt-4">
                    <img src="~/img/dpo_dps_logo.png" alt="" class="dps-footer-logo" />
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script asp-add-nonce>
            // Check if there's an error message to display
            var errorMessage = '@errorMessage';
            if (errorMessage !== '') {
                // Show the modal using jQuery
                var myModal = new bootstrap.Modal($('#errorModal'), {});
                myModal.show();
            }
            $(document).ready(function() {
            $('.toggle-password').on('click', function() {
                const passwordInput = $('#Password');
                const icon = $(this).find('i');

                if (passwordInput.attr('type') === 'password') {
                    passwordInput.attr('type', 'text');
                        icon.removeClass('fa-eye-slash').addClass('fa-eye'); // Change icon to eye-slash
                } else {
                    passwordInput.attr('type', 'password');
                        icon.removeClass('fa-eye').addClass('fa-eye-slash'); // Change icon to eye
                }
            });
        });
    </script>

}
