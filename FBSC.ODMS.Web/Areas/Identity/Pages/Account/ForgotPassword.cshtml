@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
    Layout = "_Layout";
}

<div class="auth-page-wrapper">
    <div class="container d-flex justify-content-center align-items-center auth-vh-85">
        <div class="card shadow-lg o-hidden border-0 my-5 overflow-hidden auth-card-900 auth-card-rounded">
            <div class="card-body p-0">
                <div class="row g-0">
                    <div class="col-lg-6 d-none d-lg-flex">
                        <div class="flex-grow-1 bg-login-image auth-img-min-400"></div>
                    </div>

                    <div class="col-lg-6">
                        <div class="p-5">
                            <div class="text-center">
                                <div class="icon-circle mb-3 shadow-sm mx-auto auth-icon-primary">
                                    <i class="fas fa-key"></i>
                                </div>
                                <h4 class="text-dark fw-bold mb-2">Forgot Your Password?</h4>
                                <p class="text-muted mb-4 small">
                                    We get it, stuff happens. Just enter your email address below and we'll send you a link to reset your password!
                                </p>
                            </div>

                            <form method="post" class="user mt-4">
                                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                                <div class="mb-3">
                                    <label asp-for="Input!.Email" class="form-label ms-2">Email Address</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="fas fa-envelope text-primary small"></i>
                                        </span>
                                        <input asp-for="Input!.Email" class="form-control border-start-0" placeholder="Enter Email Address...">
                                    </div>
                                    <span asp-validation-for="Input!.Email" class="text-danger field-validation-error"></span>
                                </div>

                                <div class="d-grid mt-4">
                                    @* Reusing .btn-user for the 10rem border-radius from site.css *@
                                    <button class="btn btn-primary btn-user shadow-sm py-2" type="submit">
                                        <i class="fas fa-paper-plane me-2"></i>Reset Password
                                    </button>
                                </div>
                            </form>

                            <hr class="my-4">

                            <div class="text-center">
                                <a class="login-link small d-block mb-2" asp-page="./Register">
                                    <i class="fas fa-user-plus me-1"></i>Create an Account!
                                </a>
                                <a class="login-link small d-block" href="./Login">
                                    <i class="fas fa-sign-in-alt me-1"></i>Already have an account? Login!
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}