@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
    Layout = "_Layout";
}

<div class="auth-page-wrapper">
    <div class="container d-flex justify-content-center align-items-center auth-vh-75">
        <div class="card shadow-lg o-hidden border-0 my-5 overflow-hidden auth-card-450 auth-card-rounded">
            <div class="card-body p-0">
                <div class="p-5 text-center">
                    <div class="icon-circle mb-4 shadow-sm mx-auto auth-icon-primary auth-icon-lg">
                        <i class="fas fa-sign-out-alt"></i>
                    </div>

                    <h3 class="fw-bold text-dark mb-2">Logged Out</h3>
                    <p class="text-muted mb-4 small">
                        You have successfully logged out of the application. Thank you for using our system.
                    </p>

                    <hr class="my-4">

                    <div class="d-grid">
                        @* btn-user handles the 10rem rounding from your site.css *@
                        <a href="./Login" class="btn btn-primary btn-user shadow-sm py-2">
                            <i class="fas fa-sign-in-alt me-2"></i> Return to Login
                        </a>
                    </div>

                    <div class="mt-4">
                        <p class="small text-muted mb-0">For security, please close your browser window.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>