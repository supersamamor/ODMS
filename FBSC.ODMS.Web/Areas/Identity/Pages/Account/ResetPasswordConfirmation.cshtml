@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Reset password confirmation";
    Layout = "_Layout";
}

<div class="auth-page-wrapper">
    <div class="container d-flex justify-content-center align-items-center auth-vh-80">
        <div class="card shadow-lg o-hidden border-0 my-5 overflow-hidden auth-card-sm auth-card-rounded">
            <div class="card-body p-0">
                <div class="p-5 text-center">
                    <div class="icon-circle mb-4 shadow-sm mx-auto auth-status-icon auth-icon-success">
                        <i class="fas fa-check"></i>
                    </div>

                    <h3 class="fw-bold text-dark mb-2">Password Changed!</h3>
                    <p class="text-muted mb-4 small">
                        Your password has been reset successfully. You can now use your new credentials to access your account.
                    </p>

                    <hr class="my-4">

                    <div class="d-grid">
                        @* Reusing btn-user for the 10rem border-radius from site.css *@
                        <a asp-page="./Login" class="btn btn-primary btn-user shadow-sm py-2">
                            <i class="fas fa-sign-in-alt me-2"></i> Log in Now
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>