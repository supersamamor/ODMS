@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<div class="error-page-wrapper">
    <div class="container d-flex justify-content-center align-items-center full-viewport-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 text-center access-denied-card">
                <div class="card-body p-5">
                    <div class="icon-circle icon-danger mb-4 shadow-sm mx-auto">
                        <i class="fas fa-shield-alt"></i>
                    </div>

                    <h2 class="fw-bold text-dark mb-3">Access Restricted</h2>

                    <p class="text-muted mb-4 small">
                        Apologies, but you do not have the necessary permissions to view this resource.
                        Please contact your system administrator if you believe this is an error.
                    </p>

                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-4">
                        <a href="/" class="btn btn-primary btn-user px-4 py-2">
                            <i class="fas fa-home me-2"></i>Return Dashboard
                        </a>
                        <button onclick="history.back()" class="btn btn-outline-secondary btn-user px-4 py-2">
                            <i class="fas fa-arrow-left me-2"></i>Go Back
                        </button>
                    </div>
                </div>
                <div class="card-footer bg-light text-muted py-3">
                    <small>Reference ID: @HttpContext.TraceIdentifier</small>
                </div>
            </div>
        </div>
    </div>
</div>