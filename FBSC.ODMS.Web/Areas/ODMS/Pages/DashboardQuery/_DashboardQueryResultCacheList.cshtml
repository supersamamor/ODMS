@using Models
@model DashboardQueryViewModel
<input type="hidden" id="DashboardQueryResultCacheCount" value="@Model?.DashboardQueryResultCacheList?.Count" />
<div class="card">
    <h5 class="card-header">
        <span  class="card-header-custom">@Localizer["Dashboard Query Result Cache"]</span>
        <a id="btnAddDashboardQueryResultCache" class="btn btnMaterial btn-flat primary semicircle cancel btnAddRemoveSubDetailList text-light" title="@Localizer["Add"]"><i class="fas fa-plus"></i></a>
        <button class="cancel d-none" type="button" id="btnRemoveDashboardQueryResultCache" value="RemoveDashboardQueryResultCache"></button>
    </h5>
    <div class="card-body overflow-auto">
        <table id="subDetailList" class="table table-hover table-striped responsive nowrap fills-table" width="100%">
            <thead>
                <tr>
                    <th class="d-none"></th>
                    <th class="text-center">
								@Localizer["Hash Of The Resolved Parameter Values For This Cache Entry"]
							</th>
							<th class="text-center">
								@Localizer["Rows Cached"]
							</th>
							<th class="text-center">
								@Localizer["Approximate Payload Size In Bytes"]
							</th>
							<th class="text-center">
								@Localizer["Cached At"]
							</th>
							<th class="text-center">
								@Localizer["Expires At"]
							</th>
							<th class="text-center">
								@Localizer["Flagged Stale By A Failed Or Overdue Refresh"]
							</th>
							
                    <th class="text-center">
                        @Localizer["Action"]
                    </th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.DashboardQueryResultCacheList != null)
                {
                    int counter = 0;
                    foreach (var item in Model.DashboardQueryResultCacheList)
                    {
                        <tr>
                            <td class="d-none">
                                <input type="hidden" name="DashboardQueryResultCacheList[@counter].Id" value="@item.Id" />
                                <input type="hidden" name="DashboardQueryResultCacheList[@counter].DashboardQueryId" value="@item.DashboardQueryId" />
                            </td>
                            <td>
										<input  asp-for="@item.ParameterSetHash" name="DashboardQueryResultCacheList[@counter].ParameterSetHash" class="form-control" maxlength="64" readonly/>
										<span data-valmsg-for="DashboardQueryResultCacheList[@counter].ParameterSetHash" asp-validation-for="@item.ParameterSetHash" class="text-danger"></span>
										<input type="hidden" asp-for="@item.ParameterSetHash"  name="DashboardQueryResultCacheList[@counter].ParameterSetHash"/>
									</td>
									<td>
										<input  asp-for="@item.RowCount" name="DashboardQueryResultCacheList[@counter].RowCount" class="form-control"  readonly/>
										<span data-valmsg-for="DashboardQueryResultCacheList[@counter].RowCount" asp-validation-for="@item.RowCount" class="text-danger"></span>
										<input type="hidden" asp-for="@item.RowCount"  name="DashboardQueryResultCacheList[@counter].RowCount"/>
									</td>
									<td>
										<input  asp-for="@item.CacheSizeBytes" name="DashboardQueryResultCacheList[@counter].CacheSizeBytes" class="form-control"  readonly/>
										<span data-valmsg-for="DashboardQueryResultCacheList[@counter].CacheSizeBytes" asp-validation-for="@item.CacheSizeBytes" class="text-danger"></span>
										<input type="hidden" asp-for="@item.CacheSizeBytes"  name="DashboardQueryResultCacheList[@counter].CacheSizeBytes"/>
									</td>
									<td>
										<input  asp-for="@item.CachedAt" name="DashboardQueryResultCacheList[@counter].CachedAt" class="form-control"  readonly/>
										<span data-valmsg-for="DashboardQueryResultCacheList[@counter].CachedAt" asp-validation-for="@item.CachedAt" class="text-danger"></span>
										<input type="hidden" asp-for="@item.CachedAt"  name="DashboardQueryResultCacheList[@counter].CachedAt"/>
									</td>
									<td>
										<input  asp-for="@item.ExpiresAt" name="DashboardQueryResultCacheList[@counter].ExpiresAt" class="form-control"  />
										<span data-valmsg-for="DashboardQueryResultCacheList[@counter].ExpiresAt" asp-validation-for="@item.ExpiresAt" class="text-danger"></span>
										
									</td>
									<td>
										<input asp-for="@item.IsStale" name="DashboardQueryResultCacheList[@counter].IsStale" class="custom-checkbox-label"  disabled/>
										<span data-valmsg-for="DashboardQueryResultCacheList[@counter].IsStale" asp-validation-for="@item.IsStale" class="text-danger"></span>
										<input type="hidden" asp-for="@item.IsStale"  name="DashboardQueryResultCacheList[@counter].IsStale"/>
									</td>
									
                            <td class="text-center">
                                <a class="btn btnFills btn-outline-danger btnDeleteIcon cancel RemoveDashboardQueryResultCacheButton btnAddRemoveSubDetailList" title="@Localizer["Remove DashboardQueryResultCache"]" removeId="@(item.Id)"></a>
                            </td>
                        </tr>
                        counter++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>
