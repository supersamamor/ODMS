@page
@model IndexModel

@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["Title"] = Localizer["Dashboard Query List"];
    ViewData["ActiveMainPage"] = "DashboardQuery";
    ViewData["Level1"] = "ODMS";
	IEnumerable<dynamic> breadCrumbs = [new { Title = "Dashboard Query List", Url = "", IsActive = true }];
}
<partial name="_BreadcrumbPartial" model=@(breadCrumbs) />
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <table id="dashboardQuery" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%">
                    <thead>
                        <tr>
                            <th>
								@Localizer["Data Source"]
							</th>
							<th>
								@Localizer["Name"]
							</th>
							<th>
								@Localizer["Description"]
							</th>
							<th>
								@Localizer["Has One Or More DashboardQueryParameter Rows"]
							</th>
							<th>
								@Localizer["Originated From An AiSqlGenerationRequest"]
							</th>
							<th>
								@Localizer["Valid, Invalid, Or NotYetValidated"]
							</th>
							<th>
								@Localizer["Last Validated At"]
							</th>
							<th>
								@Localizer["Last Execution Duration In Milliseconds"]
							</th>
							<th>
								@Localizer["Last Executed At"]
							</th>
							<th>
								@Localizer["Last Execution Error"]
							</th>
							<th>
								@Localizer["Is Active"]
							</th>
							  
							<th>
								@Localizer["Status"]
							</th> 
                            <th>
                                @Localizer["Actions"]
                            </th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>


<div id="BatchUploadPartialContainer">
    <partial name="_BatchUpload" model="Model.BatchUpload" />
</div>
@section Scripts {
    <partial name="_DataTableScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var table = $('#dashboardQuery').DataTable({
                select: false,
                serverSide: true,
                responsive: true,
                order: [[13, 'desc']],
                dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                ajax:
                {
                    url: '@Url.Page("/DashboardQuery/Index", new { area = "ODMS", handler = "ListAll" })',
                    type: "POST",
                    headers: {
                        RequestVerificationToken:
                            $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                },
                initComplete: function (settings, json) {
                    BindTableRowCollapseEvent();
                },
                columns: [
                    { data: "dataSourceId", name: "DataSourceId", responsivePriority: 1, title: '@Localizer["Data Source"]', searchable: false, className: "text-start" },
				{ data: "name", name: "Name", responsivePriority: 1, title: '@Localizer["Name"]', searchable: true, className: "text-start" },
				{ data: "description", name: "Description", responsivePriority: 1, title: '@Localizer["Description"]', searchable: false, className: "text-start" },
				{ data: "isParameterizedFormatted", name: "IsParameterized", responsivePriority: 2, title: '@Localizer["Has One Or More DashboardQueryParameter Rows"]', searchable: false, className: "fills-text-center" },
				{ data: "generatedByAIFormatted", name: "GeneratedByAI", responsivePriority: 2, title: '@Localizer["Originated From An AiSqlGenerationRequest"]', searchable: false, className: "fills-text-center" },
				{ data: "validationStatus", name: "ValidationStatus", responsivePriority: 2, title: '@Localizer["Valid, Invalid, Or NotYetValidated"]', searchable: false, className: "text-start" },
				{ data: "lastValidatedAtFormatted", name: "LastValidatedAt", responsivePriority: 2, title: '@Localizer["Last Validated At"]', searchable: false, className: "text-start" },
				{ data: "lastExecutionDurationMsFormatted", name: "LastExecutionDurationMs", responsivePriority: 2, title: '@Localizer["Last Execution Duration In Milliseconds"]', searchable: false, className: "fills-text-end" },
				{ data: "lastExecutedAtFormatted", name: "LastExecutedAt", responsivePriority: 2, title: '@Localizer["Last Executed At"]', searchable: false, className: "text-start" },
				{ data: "lastExecutionErrorRemarks", name: "LastExecutionErrorRemarks", responsivePriority: 2, title: '@Localizer["Last Execution Error"]', searchable: false, className: "text-start" },
				{ data: "isActiveFormatted", name: "IsActive", responsivePriority: 2, title: '@Localizer["Is Active"]', searchable: false, className: "fills-text-center" },
				   
					{ data: "statusBadge", name: "StatusBadge", responsivePriority: 1, title: '@Localizer["Approval Status"]', searchable: false, orderable: false, className: "fills-text-center" },
                    {
                        data: null,
                        searchable: false,
                        orderable: false,
                        responsivePriority: 1,
                        width: "10%",
                        className: "fills-text-center",
                        render: function (data, type, row, meta) {
                            var url = '@Url.Page("/DashboardQuery/Details", new { area = "ODMS" })' + '?id=' + row.id;
							var button = '<a href="' + url + '" class="btn btnFills btn-outline-success btnInfoIcon btnViewDashboardQuery" title="@Localizer["View"]"></a>';
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQuery.Edit)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DashboardQuery/Edit", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnEditIcon btnEditDashboardQuery" title="@Localizer["Edit"]"></a>';
							</text>
						}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQuery.Delete)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DashboardQuery/Delete", new { area = "ODMS" })' + '?id=' + row.id;
												button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-danger btnDeleteIcon btnDeleteDashboardQuery" title="@Localizer["Delete"]"></a>';
							</text>
						}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQuery.Approve)).Succeeded)
				{
					<text>
						url = '@Url.Page("/DashboardQuery/Approve", new { area = "ODMS" })' + '?id=' + row.id;
						button =  button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-success btnApproveIcon" title="@Localizer["Approve"]"></a>';
					</text>
				}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQuery.History)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DashboardQuery/History", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnHistoryIcon" title="@Localizer["History"]"></a>';
							</text>
						}
							return button;
                        },
                    },
                    { data: "lastModifiedDate", name: "LastModifiedDate", title: '@Localizer["Last Modified Date"]', visible: false, searchable: false },
                    { data: "id", name: "Id", visible: false },
                ],
                buttons: [
        @* Add Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQuery.Create)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-plus"></i>',
                        className: 'btn btn-success btnAddDashboardQuery text-light',
                        titleAttr: '@Localizer["Add"]',
                        action: function (e, dt, node, config) {
                            window.location.href = '@Url.Page("/DashboardQuery/Add", new { area = "ODMS" })';
                        }
                    },
            </text>
        }

        @* Download Template Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQuery.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-download"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Download Template"]',
                        action: function (e, dt, node, config) {
                            $('#download-template-form').submit();
                        }
                    },
            </text>
        }

        @* Upload Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQuery.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-upload"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Upload"]',
                        action: function (e, dt, node, config) {
                            $('#btnBatchUpload').click();
                        }
                    },
            </text>
        }

        @* Page Length Button *@
            {
                extend: 'pageLength',
                className: 'btn btn-primary',
                titleAttr: '@Localizer["Rows per page"]'
            }
        ],
            });
            var debounce = new $.fn.dataTable.Debounce(table); // Add delay to search

            $('.btn-table_filter').on('click', function (e) {
                table.ajax.reload(null, false);
            });
            function BindTableRowCollapseEvent() {
                $('#dashboardQuery tbody').on('click', 'td.dtr-control', function () {
                    $.showAjaxLoaderOnClick([".btnAddDashboardQuery", ".btnEditDashboardQuery", ".btnViewDashboardQuery", ".btnDeleteDashboardQuery"]);
                });
            }
            $.showAjaxLoaderOnClick([".btnAddDashboardQuery", ".btnEditDashboardQuery", ".btnViewDashboardQuery", ".btnDeleteDashboardQuery"]);
            $.InitializeSearchKeyCookies(table);
            $('#btnBatchUpload').on('change', function (e) {
                $('#batch-upload-form').submit();
            });           
        @if (!string.IsNullOrEmpty(Model.BatchUpload.BatchUploadFileName))
        {
            <text>
                    $('#btnDownloadBatchUploadTemplateLink')[0].click();
            </text>
        }
        });
    </script>
}