@using Models
@model DashboardQueryViewModel
<script asp-add-nonce>
    $(document).ready(function () { 
		$.InitializeDashboardQueryParameterFieldValidations = function(count)
        {
			let reqs = [];			
			for (let idx = 0; idx < count; idx++) {
				reqs.push({name: "DashboardQueryParameterList[" + idx + "].DashboardQueryId", el: "Input", minlength:0, maxlength:450, isrequired: true, description: "Dashboard Query"});
				reqs.push({name: "DashboardQueryParameterList[" + idx + "].ParameterName", el: "Input", minlength:0, maxlength:100, isrequired: true, description: "Sql Parameter Placeholder, E.g. @@DateFrom"});
				reqs.push({name: "DashboardQueryParameterList[" + idx + "].DataType", el: "Input", minlength:0, maxlength:50, isrequired: true, description: "Parameter Data Type"});
				reqs.push({name: "DashboardQueryParameterList[" + idx + "].ControlType", el: "Input", minlength:0, maxlength:50, isrequired: true, description: "Dropdown, DateRange, Text, Or MultiSelect"});
				reqs.push({name: "DashboardQueryParameterList[" + idx + "].DefaultValue", el: "Input", minlength:0, maxlength:450, isrequired: false, description: "Default Value"});
				reqs.push({name: "DashboardQueryParameterList[" + idx + "].IsRequired", el: "Input", minlength:0, maxlength:0, isrequired: false, description: "Is Required"});
				reqs.push({name: "DashboardQueryParameterList[" + idx + "].LookupSourceQuery", el: "Input", minlength:0, maxlength:0, isrequired: false, description: "Optional Sql That Populates This Parameter`s Dropdown Values"});
				reqs.push({name: "DashboardQueryParameterList[" + idx + "].Sequence", el: "Input", minlength:0, maxlength:0, isrequired: true, description: "Filter Bar Order"});
				
			}
			let validator = $("#dashboardQuery-form").validate();
			for (let j in reqs)
			{
				let e = reqs[j];
				let el = $(`*[name="${e.name}"]`);
				el.rules("add", {
					required: {                
						depends: function(element) {
							return e.isrequired;
						}
					},
					messages: {
						required: (e.description === '') ? 'this field is required' : `'${e.description}' is required`,
					},
				});
				if(e.isrequired == true)
				{
					let labelElement = $(`label[name="Label.${e.name}"]`);
					$(labelElement).addClass("fieldrequired");
					el.attr('data-val-required', (e.description === '') ? 'this field is required' : `'${e.description}' is required`);
					el.attr('data-val', true);
				}
				if(e.maxlength > 0) {el.attr('maxlength', e.maxlength);}
				if(e.minlength > 0) {el.attr('minlength', e.minlength);}   
			} 
		}       
    });
</script>