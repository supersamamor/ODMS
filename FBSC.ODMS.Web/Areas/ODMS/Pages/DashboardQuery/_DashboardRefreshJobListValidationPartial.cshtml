@using Models
@model DashboardQueryViewModel
<script asp-add-nonce>
    $(document).ready(function () { 
		$.InitializeDashboardRefreshJobFieldValidations = function(count)
        {
			let reqs = [];			
			for (let idx = 0; idx < count; idx++) {
				reqs.push({name: "DashboardRefreshJobList[" + idx + "].DashboardQueryId", el: "Input", minlength:0, maxlength:450, isrequired: true, description: "Dashboard Query"});
				reqs.push({name: "DashboardRefreshJobList[" + idx + "].TriggerType", el: "Input", minlength:0, maxlength:20, isrequired: true, description: "Manual Or Schedule"});
				reqs.push({name: "DashboardRefreshJobList[" + idx + "].Status", el: "Input", minlength:0, maxlength:50, isrequired: true, description: "Status"});
				reqs.push({name: "DashboardRefreshJobList[" + idx + "].QueuedAt", el: "Input", minlength:0, maxlength:0, isrequired: false, description: "Queued At"});
				reqs.push({name: "DashboardRefreshJobList[" + idx + "].StartedAt", el: "Input", minlength:0, maxlength:0, isrequired: false, description: "Started At"});
				reqs.push({name: "DashboardRefreshJobList[" + idx + "].CompletedAt", el: "Input", minlength:0, maxlength:0, isrequired: false, description: "Completed At"});
				reqs.push({name: "DashboardRefreshJobList[" + idx + "].DurationMs", el: "Input", minlength:0, maxlength:0, isrequired: false, description: "Duration In Milliseconds"});
				reqs.push({name: "DashboardRefreshJobList[" + idx + "].RowsCached", el: "Input", minlength:0, maxlength:0, isrequired: false, description: "Rows Written To Result Cache"});
				reqs.push({name: "DashboardRefreshJobList[" + idx + "].RetryCount", el: "Input", minlength:0, maxlength:0, isrequired: false, description: "Retry Count"});
				reqs.push({name: "DashboardRefreshJobList[" + idx + "].MaxRetries", el: "Input", minlength:0, maxlength:0, isrequired: false, description: "Max Retries"});
				reqs.push({name: "DashboardRefreshJobList[" + idx + "].ErrorRemarks", el: "Input", minlength:0, maxlength:450, isrequired: false, description: "Error Remarks"});
				
			}
			let validator = $("#dashboardQuery-form").validate();
			for (let j in reqs)
			{
				let e = reqs[j];
				let el = $(`*[name="${e.name}"]`);
				el.rules("add", {
					required: {                
						depends: function(element) {
							return e.isrequired;
						}
					},
					messages: {
						required: (e.description === '') ? 'this field is required' : `'${e.description}' is required`,
					},
				});
				if(e.isrequired == true)
				{
					let labelElement = $(`label[name="Label.${e.name}"]`);
					$(labelElement).addClass("fieldrequired");
					el.attr('data-val-required', (e.description === '') ? 'this field is required' : `'${e.description}' is required`);
					el.attr('data-val', true);
				}
				if(e.maxlength > 0) {el.attr('maxlength', e.maxlength);}
				if(e.minlength > 0) {el.attr('minlength', e.minlength);}   
			} 
		}       
    });
</script>