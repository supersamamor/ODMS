@page
@model IndexModel

@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["Title"] = Localizer["AI SQL Generation Request List"];
    ViewData["ActiveMainPage"] = "AiSqlGenerationRequest";
    ViewData["Level1"] = "ODMS";
	IEnumerable<dynamic> breadCrumbs = [new { Title = "AI SQL Generation Request List", Url = "", IsActive = true }];
}
<partial name="_BreadcrumbPartial" model=@(breadCrumbs) />
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <table id="aiSqlGenerationRequest" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%">
                    <thead>
                        <tr>
                            <th>
								@Localizer["Data Source"]
							</th>
							<th>
								@Localizer["User`s Plain-Language Question"]
							</th>
							<th>
								@Localizer["Dashboard Query Created On Acceptance"]
							</th>
							<th>
								@Localizer["Model Confidence 0-100"]
							</th>
							<th>
								@Localizer["Status"]
							</th>
							<th>
								@Localizer["Generation Or Validation Error"]
							</th>
							<th>
								@Localizer["Requested By"]
							</th>
							<th>
								@Localizer["Generated At"]
							</th>
							  
							
                            <th>
                                @Localizer["Actions"]
                            </th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>


<div id="BatchUploadPartialContainer">
    <partial name="_BatchUpload" model="Model.BatchUpload" />
</div>
@section Scripts {
    <partial name="_DataTableScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var table = $('#aiSqlGenerationRequest').DataTable({
                select: false,
                serverSide: true,
                responsive: true,
                order: [[8, 'desc']],
                dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                ajax:
                {
                    url: '@Url.Page("/AiSqlGenerationRequest/Index", new { area = "ODMS", handler = "ListAll" })',
                    type: "POST",
                    headers: {
                        RequestVerificationToken:
                            $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                },
                initComplete: function (settings, json) {
                    BindTableRowCollapseEvent();
                },
                columns: [
                    { data: "dataSourceId", name: "DataSourceId", responsivePriority: 1, title: '@Localizer["Data Source"]', searchable: false, className: "text-start" },
				{ data: "naturalLanguagePrompt", name: "NaturalLanguagePrompt", responsivePriority: 1, title: '@Localizer["User`s Plain-Language Question"]', searchable: false, className: "text-start" },
				{ data: "dashboardQueryId", name: "DashboardQueryId", responsivePriority: 2, title: '@Localizer["Dashboard Query Created On Acceptance"]', searchable: false, className: "text-start" },
				{ data: "confidenceScoreFormatted", name: "ConfidenceScore", responsivePriority: 2, title: '@Localizer["Model Confidence 0-100"]', searchable: false, className: "fills-text-end" },
				{ data: "validationStatus", name: "ValidationStatus", responsivePriority: 2, title: '@Localizer["Status"]', searchable: false, className: "text-start" },
				{ data: "errorRemarks", name: "ErrorRemarks", responsivePriority: 2, title: '@Localizer["Generation Or Validation Error"]', searchable: false, className: "text-start" },
				{ data: "requestedBy", name: "RequestedBy", responsivePriority: 2, title: '@Localizer["Requested By"]', searchable: true, className: "text-start" },
				{ data: "generatedAtFormatted", name: "GeneratedAt", responsivePriority: 2, title: '@Localizer["Generated At"]', searchable: false, className: "text-start" },
				   
					
                    {
                        data: null,
                        searchable: false,
                        orderable: false,
                        responsivePriority: 1,
                        width: "10%",
                        className: "fills-text-center",
                        render: function (data, type, row, meta) {
                            var url = '@Url.Page("/AiSqlGenerationRequest/Details", new { area = "ODMS" })' + '?id=' + row.id;
							var button = '<a href="' + url + '" class="btn btnFills btn-outline-success btnInfoIcon btnViewAiSqlGenerationRequest" title="@Localizer["View"]"></a>';
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.AiSqlGenerationRequest.Edit)).Succeeded)
						{
							<text>
											url = '@Url.Page("/AiSqlGenerationRequest/Edit", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnEditIcon btnEditAiSqlGenerationRequest" title="@Localizer["Edit"]"></a>';
							</text>
						}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.AiSqlGenerationRequest.Delete)).Succeeded)
						{
							<text>
											url = '@Url.Page("/AiSqlGenerationRequest/Delete", new { area = "ODMS" })' + '?id=' + row.id;
												button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-danger btnDeleteIcon btnDeleteAiSqlGenerationRequest" title="@Localizer["Delete"]"></a>';
							</text>
						}
						
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.AiSqlGenerationRequest.History)).Succeeded)
						{
							<text>
											url = '@Url.Page("/AiSqlGenerationRequest/History", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnHistoryIcon" title="@Localizer["History"]"></a>';
							</text>
						}
							return button;
                        },
                    },
                    { data: "lastModifiedDate", name: "LastModifiedDate", title: '@Localizer["Last Modified Date"]', visible: false, searchable: false },
                    { data: "id", name: "Id", visible: false },
                ],
                buttons: [
        @* Add Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.AiSqlGenerationRequest.Create)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-plus"></i>',
                        className: 'btn btn-success btnAddAiSqlGenerationRequest text-light',
                        titleAttr: '@Localizer["Add"]',
                        action: function (e, dt, node, config) {
                            window.location.href = '@Url.Page("/AiSqlGenerationRequest/Add", new { area = "ODMS" })';
                        }
                    },
            </text>
        }

        @* Download Template Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.AiSqlGenerationRequest.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-download"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Download Template"]',
                        action: function (e, dt, node, config) {
                            $('#download-template-form').submit();
                        }
                    },
            </text>
        }

        @* Upload Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.AiSqlGenerationRequest.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-upload"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Upload"]',
                        action: function (e, dt, node, config) {
                            $('#btnBatchUpload').click();
                        }
                    },
            </text>
        }

        @* Page Length Button *@
            {
                extend: 'pageLength',
                className: 'btn btn-primary',
                titleAttr: '@Localizer["Rows per page"]'
            }
        ],
            });
            var debounce = new $.fn.dataTable.Debounce(table); // Add delay to search

            $('.btn-table_filter').on('click', function (e) {
                table.ajax.reload(null, false);
            });
            function BindTableRowCollapseEvent() {
                $('#aiSqlGenerationRequest tbody').on('click', 'td.dtr-control', function () {
                    $.showAjaxLoaderOnClick([".btnAddAiSqlGenerationRequest", ".btnEditAiSqlGenerationRequest", ".btnViewAiSqlGenerationRequest", ".btnDeleteAiSqlGenerationRequest"]);
                });
            }
            $.showAjaxLoaderOnClick([".btnAddAiSqlGenerationRequest", ".btnEditAiSqlGenerationRequest", ".btnViewAiSqlGenerationRequest", ".btnDeleteAiSqlGenerationRequest"]);
            $.InitializeSearchKeyCookies(table);
            $('#btnBatchUpload').on('change', function (e) {
                $('#batch-upload-form').submit();
            });           
        @if (!string.IsNullOrEmpty(Model.BatchUpload.BatchUploadFileName))
        {
            <text>
                    $('#btnDownloadBatchUploadTemplateLink')[0].click();
            </text>
        }
        });
    </script>
}