@page
@model DetailsModel
@{
    ViewData["Title"] = Localizer["View AI SQL Generation Request"];
    ViewData["ActiveMainPage"] = "AiSqlGenerationRequest";
    ViewData["Level1"] = "ODMS";
	var breadcrumbs = new[] {
		new { Title = "AI SQL Generation Request List", Url = "/ODMS/AiSqlGenerationRequest/Index", IsActive = false },
		new { Title = "View AI SQL Generation Request", Url = "", IsActive = true },
	};
}
<partial name="_BreadcrumbPartial" model=@(breadcrumbs) />
<div id="aiSqlGenerationRequest-container">
    <input type="hidden" asp-for="@Model.RemoveSubDetailId" />
    <input type="hidden" asp-for="@Model.AsyncAction" />
    <div id="PartialLoaderContainer">
        <partial name="_InputFieldsPartial" model="Model.AiSqlGenerationRequest" />
    </div>
</div>
<div id="toolbar-container" class="btn-group" role="group">
    <a asp-page="Index" class="btn btnFills btn-outline-secondary btnBackIcon" title="@Localizer["Back"]"></a>
    @if ((await AuthorizationService.AuthorizeAsync(User, Permission.AiSqlGenerationRequest.Create)).Succeeded)
    {
        <a asp-page="Add" id="btnAddRecord" class="btn btnFills btn-outline-success btnAddIcon" title="@Localizer["Add"]"></a>
    }
    @if ((await AuthorizationService.AuthorizeAsync(User, Permission.AiSqlGenerationRequest.Edit)).Succeeded)
    {
        <a asp-page="Edit" asp-route-id="@Model.AiSqlGenerationRequest.Id" class="btn btnFills btn-outline-primary btnEditLightIcon" title="@Localizer["Edit"]"></a>
    }
    @if ((await AuthorizationService.AuthorizeAsync(User, Permission.AiSqlGenerationRequest.Delete)).Succeeded)
    {
        <a asp-page="Delete" asp-route-id="@Model.AiSqlGenerationRequest.Id" class="btn btnFills btn-outline-danger btnDeleteIcon" title="@Localizer["Delete"]"></a>
    }
	@if ((await AuthorizationService.AuthorizeAsync(User, Permission.AiSqlGenerationRequest.History)).Succeeded)
	{
        <a asp-page="History" asp-route-id="@Model.AiSqlGenerationRequest.Id" class="btn btnFills btn-outline-primary btnHistoryIcon" title="@Localizer["History"]"></a>
	}
	@if (string.IsNullOrEmpty(Model.AiSqlGenerationRequest.DashboardQueryId)
		&& !string.IsNullOrEmpty(Model.AiSqlGenerationRequest.GeneratedSqlQueryText)
		&& (await AuthorizationService.AuthorizeAsync(User, Permission.AiSqlGenerationRequest.Approve)).Succeeded)
	{
		<form method="post" asp-page-handler="CreateDashboardQuery" id="approveAiSqlForm" class="d-inline">
			<input type="hidden" name="id" value="@Model.AiSqlGenerationRequest.Id" />
			<button type="submit" class="btn btnFills btn-outline-success" title="@Localizer["Approve - create dashboard query from this SQL"]">
				<i class="fas fa-check-circle"></i> @Localizer["Approve"]
			</button>
		</form>
	}
</div>

@section Scripts {
<partial name="_DisableFieldsPartial" model="@("aiSqlGenerationRequest-container")" />
}