@using Models
@model DataUploadBatchViewModel
<script asp-add-nonce>
    $(document).ready(function () { 
		$.InitializeDataUploadColumnFieldValidations = function(count)
        {
			let reqs = [];			
			for (let idx = 0; idx < count; idx++) {
				reqs.push({name: "DataUploadColumnList[" + idx + "].DataUploadBatchId", el: "Input", minlength:0, maxlength:450, isrequired: true, description: "Data Upload Batch"});
				reqs.push({name: "DataUploadColumnList[" + idx + "].ColumnName", el: "Input", minlength:0, maxlength:150, isrequired: true, description: "Detected Column Name"});
				reqs.push({name: "DataUploadColumnList[" + idx + "].DetectedDataType", el: "Input", minlength:0, maxlength:50, isrequired: false, description: "Auto-Detected Data Type"});
				reqs.push({name: "DataUploadColumnList[" + idx + "].MappedSqlDataType", el: "Input", minlength:0, maxlength:50, isrequired: false, description: "Sql Data Type Used In Staging Table"});
				reqs.push({name: "DataUploadColumnList[" + idx + "].OrdinalPosition", el: "Input", minlength:0, maxlength:0, isrequired: false, description: "Column Order In File"});
				reqs.push({name: "DataUploadColumnList[" + idx + "].SampleValue", el: "Input", minlength:0, maxlength:450, isrequired: false, description: "First Non-Blank Sample Value"});
				
			}
			let validator = $("#dataUploadBatch-form").validate();
			for (let j in reqs)
			{
				let e = reqs[j];
				let el = $(`*[name="${e.name}"]`);
				el.rules("add", {
					required: {                
						depends: function(element) {
							return e.isrequired;
						}
					},
					messages: {
						required: (e.description === '') ? 'this field is required' : `'${e.description}' is required`,
					},
				});
				if(e.isrequired == true)
				{
					let labelElement = $(`label[name="Label.${e.name}"]`);
					$(labelElement).addClass("fieldrequired");
					el.attr('data-val-required', (e.description === '') ? 'this field is required' : `'${e.description}' is required`);
					el.attr('data-val', true);
				}
				if(e.maxlength > 0) {el.attr('maxlength', e.maxlength);}
				if(e.minlength > 0) {el.attr('minlength', e.minlength);}   
			} 
		}       
    });
</script>