@using Models
@model DashboardQueryResultCacheViewModel

<div class="row row-cols-1 row-cols-sm-1 row-cols-md-1 row-cols-lg-1 row-cols-xl-1 row-cols-xxl-1">
    <div class="col">
	<div class="mb-3">
		<label asp-for="@Model.DashboardQueryId" class="form-label"><strong>@Localizer["Dashboard Query"] :</strong></label>
			<select asp-for="@Model.DashboardQueryId" class="form-control" asp-items="@(dropdownService.GetDashboardQueryList(Model.DashboardQueryId))"><option value="">- Select Dashboard Query -</option></select>
			<span asp-validation-for="@Model.DashboardQueryId" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.ParameterSetHash" class="form-label"><strong>@Localizer["Hash Of The Resolved Parameter Values For This Cache Entry"] :</strong></label>
			<input asp-for="@Model.ParameterSetHash" class="form-control" maxlength="64"  readonly/>
			<span asp-validation-for="@Model.ParameterSetHash" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.RowCount" class="form-label"><strong>@Localizer["Rows Cached"] :</strong></label>
			<input asp-for="@Model.RowCount" class="form-control text-end"   readonly/>
			<span asp-validation-for="@Model.RowCount" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.CacheSizeBytes" class="form-label"><strong>@Localizer["Approximate Payload Size In Bytes"] :</strong></label>
			<input asp-for="@Model.CacheSizeBytes" class="form-control text-end"   readonly/>
			<span asp-validation-for="@Model.CacheSizeBytes" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.CachedAt" class="form-label"><strong>@Localizer["Cached At"] :</strong></label>
			<input asp-for="@Model.CachedAt" class="form-control"   readonly/>
			<span asp-validation-for="@Model.CachedAt" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.ExpiresAt" class="form-label"><strong>@Localizer["Expires At"] :</strong></label>
			<input asp-for="@Model.ExpiresAt" class="form-control"  />
			<span asp-validation-for="@Model.ExpiresAt" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.IsStale" class="form-label"><strong>@Localizer["Flagged Stale By A Failed Or Overdue Refresh"] :</strong></label>
			<input asp-for="@Model.IsStale" class="custom-checkbox-label" readonly/>
			<span asp-validation-for="@Model.IsStale" class="text-danger d-block mt-1"></span>
			
	</div>
</div>

</div>
