@page
@model DeleteModel
@{
    ViewData["Title"] = Localizer["Delete Dashboard Query Result Cache"];
    ViewData["ActiveMainPage"] = "DashboardQueryResultCache";
    ViewData["Level1"] = "ODMS";
	var breadcrumbs = new[] {
		new { Title = "Dashboard Query Result Cache List", Url = "/ODMS/DashboardQueryResultCache/Index", IsActive = false },
		new { Title = "Delete Dashboard Query Result Cache", Url = "", IsActive = true },
	};
}
<partial name="_BreadcrumbPartial" model=@(breadcrumbs) />
<form id="dashboardQueryResultCache-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="@Model.RemoveSubDetailId" />
    <input type="hidden" asp-for="@Model.AsyncAction" />
    <div id="PartialLoaderContainer">
        <partial name="_InputFieldsPartial" model="Model.DashboardQueryResultCache" />
    </div>
    <div id="toolbar-container" class="btn-group" role="group">
        <a asp-page="Index" class="btn btnFills btn-outline-secondary btnCancelIcon" title="@Localizer["Cancel"]"></a>
        <button type="button" id="btnDelete" class="btn btnFills btn-outline-danger btnDeleteIcon" title="@Localizer["Delete"]"></button>
    </div>
</form>

@section Scripts {
    <partial name="_DisableFieldsPartial" model="@("PartialLoaderContainer")" />
    <partial name="_ValidationScriptsPartial" />
    <script asp-add-nonce>
        $(document).ready(function () {
            $.bindSaveConfirmationModal('Save', '#btnDelete', '#dashboardQueryResultCache-form', 'Are you sure you want to delete this dashboardQueryResultCache?');
        });
    </script>
}