@page
@model IndexModel

@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["Title"] = Localizer["Data Source Schema Cache List"];
    ViewData["ActiveMainPage"] = "DataSourceSchemaCache";
    ViewData["Level1"] = "ODMS";
	IEnumerable<dynamic> breadCrumbs = [new { Title = "Data Source Schema Cache List", Url = "", IsActive = true }];
}
<partial name="_BreadcrumbPartial" model=@(breadCrumbs) />
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <table id="dataSourceSchemaCache" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%">
                    <thead>
                        <tr>
                            <th>
								@Localizer["Data Source"]
							</th>
							<th>
								@Localizer["Sql Schema Name"]
							</th>
							<th>
								@Localizer["Sql Table Name"]
							</th>
							<th>
								@Localizer["Sql Column Name"]
							</th>
							<th>
								@Localizer["Native Sql Data Type"]
							</th>
							<th>
								@Localizer["Column Order In Source Table"]
							</th>
							<th>
								@Localizer["Is Nullable"]
							</th>
							<th>
								@Localizer["Last Discovered At"]
							</th>
							  
							
                            <th>
                                @Localizer["Actions"]
                            </th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>


<div id="BatchUploadPartialContainer">
    <partial name="_BatchUpload" model="Model.BatchUpload" />
</div>
@section Scripts {
    <partial name="_DataTableScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var table = $('#dataSourceSchemaCache').DataTable({
                select: false,
                serverSide: true,
                responsive: true,
                order: [[8, 'desc']],
                dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                ajax:
                {
                    url: '@Url.Page("/DataSourceSchemaCache/Index", new { area = "ODMS", handler = "ListAll" })',
                    type: "POST",
                    headers: {
                        RequestVerificationToken:
                            $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                },
                initComplete: function (settings, json) {
                    BindTableRowCollapseEvent();
                },
                columns: [
                    { data: "dataSourceId", name: "DataSourceId", responsivePriority: 1, title: '@Localizer["Data Source"]', searchable: false, className: "text-start" },
				{ data: "schemaName", name: "SchemaName", responsivePriority: 1, title: '@Localizer["Sql Schema Name"]', searchable: true, className: "text-start" },
				{ data: "tableName", name: "TableName", responsivePriority: 1, title: '@Localizer["Sql Table Name"]', searchable: true, className: "text-start" },
				{ data: "columnName", name: "ColumnName", responsivePriority: 2, title: '@Localizer["Sql Column Name"]', searchable: true, className: "text-start" },
				{ data: "sqlDataType", name: "SqlDataType", responsivePriority: 2, title: '@Localizer["Native Sql Data Type"]', searchable: false, className: "text-start" },
				{ data: "ordinalPositionFormatted", name: "OrdinalPosition", responsivePriority: 2, title: '@Localizer["Column Order In Source Table"]', searchable: false, className: "fills-text-end" },
				{ data: "isNullableFormatted", name: "IsNullable", responsivePriority: 2, title: '@Localizer["Is Nullable"]', searchable: false, className: "fills-text-center" },
				{ data: "refreshedAtFormatted", name: "RefreshedAt", responsivePriority: 2, title: '@Localizer["Last Discovered At"]', searchable: false, className: "text-start" },
				   
					
                    {
                        data: null,
                        searchable: false,
                        orderable: false,
                        responsivePriority: 1,
                        width: "10%",
                        className: "fills-text-center",
                        render: function (data, type, row, meta) {
                            var url = '@Url.Page("/DataSourceSchemaCache/Details", new { area = "ODMS" })' + '?id=' + row.id;
							var button = '<a href="' + url + '" class="btn btnFills btn-outline-success btnInfoIcon btnViewDataSourceSchemaCache" title="@Localizer["View"]"></a>';
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSourceSchemaCache.Edit)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DataSourceSchemaCache/Edit", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnEditIcon btnEditDataSourceSchemaCache" title="@Localizer["Edit"]"></a>';
							</text>
						}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSourceSchemaCache.Delete)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DataSourceSchemaCache/Delete", new { area = "ODMS" })' + '?id=' + row.id;
												button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-danger btnDeleteIcon btnDeleteDataSourceSchemaCache" title="@Localizer["Delete"]"></a>';
							</text>
						}
						
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSourceSchemaCache.History)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DataSourceSchemaCache/History", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnHistoryIcon" title="@Localizer["History"]"></a>';
							</text>
						}
							return button;
                        },
                    },
                    { data: "lastModifiedDate", name: "LastModifiedDate", title: '@Localizer["Last Modified Date"]', visible: false, searchable: false },
                    { data: "id", name: "Id", visible: false },
                ],
                buttons: [
        @* Add Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSourceSchemaCache.Create)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-plus"></i>',
                        className: 'btn btn-success btnAddDataSourceSchemaCache text-light',
                        titleAttr: '@Localizer["Add"]',
                        action: function (e, dt, node, config) {
                            window.location.href = '@Url.Page("/DataSourceSchemaCache/Add", new { area = "ODMS" })';
                        }
                    },
            </text>
        }

        @* Download Template Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSourceSchemaCache.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-download"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Download Template"]',
                        action: function (e, dt, node, config) {
                            $('#download-template-form').submit();
                        }
                    },
            </text>
        }

        @* Upload Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSourceSchemaCache.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-upload"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Upload"]',
                        action: function (e, dt, node, config) {
                            $('#btnBatchUpload').click();
                        }
                    },
            </text>
        }

        @* Page Length Button *@
            {
                extend: 'pageLength',
                className: 'btn btn-primary',
                titleAttr: '@Localizer["Rows per page"]'
            }
        ],
            });
            var debounce = new $.fn.dataTable.Debounce(table); // Add delay to search

            $('.btn-table_filter').on('click', function (e) {
                table.ajax.reload(null, false);
            });
            function BindTableRowCollapseEvent() {
                $('#dataSourceSchemaCache tbody').on('click', 'td.dtr-control', function () {
                    $.showAjaxLoaderOnClick([".btnAddDataSourceSchemaCache", ".btnEditDataSourceSchemaCache", ".btnViewDataSourceSchemaCache", ".btnDeleteDataSourceSchemaCache"]);
                });
            }
            $.showAjaxLoaderOnClick([".btnAddDataSourceSchemaCache", ".btnEditDataSourceSchemaCache", ".btnViewDataSourceSchemaCache", ".btnDeleteDataSourceSchemaCache"]);
            $.InitializeSearchKeyCookies(table);
            $('#btnBatchUpload').on('change', function (e) {
                $('#batch-upload-form').submit();
            });           
        @if (!string.IsNullOrEmpty(Model.BatchUpload.BatchUploadFileName))
        {
            <text>
                    $('#btnDownloadBatchUploadTemplateLink')[0].click();
            </text>
        }
        });
    </script>
}