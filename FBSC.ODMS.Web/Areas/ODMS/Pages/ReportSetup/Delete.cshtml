@page
@model DeleteModel
@{
    ViewData["Title"] = Localizer["Delete Report Setup"];
    ViewData["ActiveMainPage"] = "ReportSetup";
    ViewData["Level1"] = "Admin";
    var breadcrumbs = new[] {
        new { Title = "Report Setup List", Url = "/ODMS/ReportSetup/Index", IsActive = false },
        new { Title = "Delete Report Setup", Url = "", IsActive = true },
    };
}
<partial name="_BreadcrumbPartial" model=@(breadcrumbs) />
<partial name="_CodeMirrorStyles" />
<partial name="_RichTextEditorStyles" />
<div class=row>
    <div class="col-12">
        <div class="alert alert-danger" role="alert">
            @Localizer["Are you sure you want to delete this report?"]
        </div>
    </div>
</div>
<form id="report-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="@Model.RemoveSubDetailId" />
    <input type="hidden" asp-for="@Model.AsyncAction" />
    <div id="PartialLoaderContainer">
        <partial name="_InputFieldsPartial" model="Model.Report" />
    </div>
    <div id="toolbar-container" class="btn-group" role="group">
        <a asp-page="Index" class="btn btnFills btn-outline-secondary btnBackIcon" title="@Localizer["Back"]"></a>
        <button type="button" id="btnDelete" class="btn btnFills btn-outline-danger btnDeleteIcon" title="@Localizer["Delete"]"></button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_DisableFieldsPartial" model="@("PartialLoaderContainer")" />
    <partial name="_CodeMirrorScripts" />
	<partial name="_RichTextEditorScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
			$.bindSaveConfirmationModal('Delete', '#btnDelete', '#report-form');
            function InitializeForm() {      
                const textAreaQueryString = document.getElementById('QueryString');
                if (textAreaQueryString) {
                    var editor = CodeMirror.fromTextArea(
                        textAreaQueryString, {
                        mode: 'sql',
                        theme: '3024-night',
                        lineNumbers: true,
                        autoCloseBrackets: true,
                        autoCloseTags: true
                    });
                }
                $('#HtmlTemplate').richText();
				$('#HtmlFooterTemplate').richText();
				
				// Make the contenteditable div readonly
				$('.richText-editor').attr('contenteditable', 'false');
				// Disable toolbar buttons
				$('.richText-toolbar').css('pointer-events', 'none').css('opacity', '0.5');
            }
            InitializeForm();
        });

    </script>
}