@page
@model DetailsModel
@{
    ViewData["Title"] = Localizer["View Data Source"];
    ViewData["ActiveMainPage"] = "DataSource";
    ViewData["Level1"] = "ODMS";
	var breadcrumbs = new[] {
		new { Title = "Data Source List", Url = "/ODMS/DataSource/Index", IsActive = false },
		new { Title = "View Data Source", Url = "", IsActive = true },
	};
}
<partial name="_BreadcrumbPartial" model=@(breadcrumbs) />
<div id="dataSource-container">
    <input type="hidden" asp-for="@Model.RemoveSubDetailId" />
    <input type="hidden" asp-for="@Model.AsyncAction" />
    <div id="PartialLoaderContainer">
        <partial name="_InputFieldsPartial" model="Model.DataSource" />
    </div>
</div>
<div id="toolbar-container" class="btn-group" role="group">
    <a asp-page="Index" class="btn btnFills btn-outline-secondary btnBackIcon" title="@Localizer["Back"]"></a>
    @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSource.Create)).Succeeded)
    {
        <a asp-page="Add" id="btnAddRecord" class="btn btnFills btn-outline-success btnAddIcon" title="@Localizer["Add"]"></a>
    }
    @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSource.Edit)).Succeeded)
    {
        <a asp-page="Edit" asp-route-id="@Model.DataSource.Id" class="btn btnFills btn-outline-primary btnEditLightIcon" title="@Localizer["Edit"]"></a>
    }
    @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSource.Delete)).Succeeded)
    {
        <a asp-page="Delete" asp-route-id="@Model.DataSource.Id" class="btn btnFills btn-outline-danger btnDeleteIcon" title="@Localizer["Delete"]"></a>
    }
	@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSource.History)).Succeeded)
	{
        <a asp-page="History" asp-route-id="@Model.DataSource.Id" class="btn btnFills btn-outline-primary btnHistoryIcon" title="@Localizer["History"]"></a>
	}
	@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DataSource.Approve)).Succeeded)
	{
		<form method="post" asp-page-handler="TestConnection" class="d-inline">
			<input type="hidden" name="id" value="@Model.DataSource.Id" />
			<button type="submit" class="btn btnFills btn-outline-info" title="@Localizer["Test Connection"]">
				<i class="fas fa-plug"></i> @Localizer["Test Connection"]
			</button>
		</form>
	}
</div>

@section Scripts {
<partial name="_DisableFieldsPartial" model="@("dataSource-container")" />
}