@using Models
@model DataSourceViewModel

<div class="row row-cols-1 row-cols-sm-1 row-cols-md-1 row-cols-lg-1 row-cols-xl-1 row-cols-xxl-1">
    <div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Name" class="form-label"><strong>@Localizer["Friendly Label For This Connection"] :</strong></label>
			<input asp-for="@Model.Name" class="form-control" maxlength="150" />
			<span asp-validation-for="@Model.Name" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.SystemType" class="form-label"><strong>@Localizer["HRIS, Accounting, CRM, or Custom — free-text category for grouping/filtering"] :</strong></label>
			<input asp-for="@Model.SystemType" class="form-control" maxlength="50" />
			<span asp-validation-for="@Model.SystemType" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.ConnectionKind" class="form-label"><strong>@Localizer["Connection Kind"] :</strong></label>
			<select asp-for="@Model.ConnectionKind" id="ConnectionKind" class="form-control">
				<option value="@FBSC.ODMS.Core.Constants.DataSourceConnectionKind.ExternalDatabase">@Localizer["External Database (live SQL Server connection)"]</option>
				<option value="@FBSC.ODMS.Core.Constants.DataSourceConnectionKind.UploadedFile">@Localizer["Uploaded File (CSV / XLSX)"]</option>
			</select>
			<span asp-validation-for="@Model.ConnectionKind" class="text-danger d-block mt-1"></span>
			<small class="form-text text-muted">@Localizer["Uploaded-file data sources have no server/credentials below - use the Upload File action from the Details page instead."]</small>
	</div>
</div>
<div id="externalDatabaseFields">
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.ConnectionMode" class="form-label"><strong>@Localizer["ConnectionString or ServerCredentials"] :</strong></label>
			<input asp-for="@Model.ConnectionMode" class="form-control" maxlength="30" />
			<span asp-validation-for="@Model.ConnectionMode" class="text-danger d-block mt-1"></span>

	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.ServerAddress" class="form-label"><strong>@Localizer["MS SQL Server Host Or Instance"] :</strong></label>
			<input asp-for="@Model.ServerAddress" class="form-control" maxlength="200" />
			<span asp-validation-for="@Model.ServerAddress" class="text-danger d-block mt-1"></span>

	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.DatabaseName" class="form-label"><strong>@Localizer["Target Database Name"] :</strong></label>
			<input asp-for="@Model.DatabaseName" class="form-control" maxlength="150" />
			<span asp-validation-for="@Model.DatabaseName" class="text-danger d-block mt-1"></span>

	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.AuthenticationType" class="form-label"><strong>@Localizer["SQL, WindowsIntegrated, or AzureAD"] :</strong></label>
			<input asp-for="@Model.AuthenticationType" class="form-control" maxlength="50" />
			<span asp-validation-for="@Model.AuthenticationType" class="text-danger d-block mt-1"></span>

	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Username" class="form-label"><strong>@Localizer["Connection Username"] :</strong></label>
			<input asp-for="@Model.Username" class="form-control" maxlength="100" />
			<span asp-validation-for="@Model.Username" class="text-danger d-block mt-1"></span>

	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.PasswordEncrypted" class="form-label"><strong>@Localizer["Connection Password (leave blank to keep the current value)"] :</strong></label>
			<input asp-for="@Model.PasswordEncrypted" type="password" autocomplete="new-password" class="form-control" maxlength="450" />
			<span asp-validation-for="@Model.PasswordEncrypted" class="text-danger d-block mt-1"></span>
			<small class="form-text text-muted">@Localizer["Stored encrypted at rest - never displayed once saved."]</small>
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.ConnectionStringEncrypted" class="form-label"><strong>@Localizer["Full Connection String (used instead of the fields above when Connection Mode is ConnectionString - leave blank to keep the current value)"] :</strong></label>
			<input asp-for="@Model.ConnectionStringEncrypted" type="password" autocomplete="new-password" class="form-control" maxlength="450" />
			<span asp-validation-for="@Model.ConnectionStringEncrypted" class="text-danger d-block mt-1"></span>
			<small class="form-text text-muted">@Localizer["Stored encrypted at rest - never displayed once saved."]</small>
	</div>
</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Description" class="form-label"><strong>@Localizer["Description"] :</strong></label>
			<input asp-for="@Model.Description" class="form-control" maxlength="450" />
			<span asp-validation-for="@Model.Description" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.IsActive" class="form-label"><strong>@Localizer["Is Active"] :</strong></label>
			<input asp-for="@Model.IsActive" class="custom-checkbox-label"/>
			<span asp-validation-for="@Model.IsActive" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.LastTestedAt" class="form-label"><strong>@Localizer["Last Connection Test At"] :</strong></label>
			<input asp-for="@Model.LastTestedAt" class="form-control"   readonly/>
			<span asp-validation-for="@Model.LastTestedAt" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.LastTestStatus" class="form-label"><strong>@Localizer["Last Connection Test Result"] :</strong></label>
			<input asp-for="@Model.LastTestStatus" class="form-control" maxlength="50"  readonly/>
			<span asp-validation-for="@Model.LastTestStatus" class="text-danger d-block mt-1"></span>

	</div>
</div>

</div>
<script asp-add-nonce>
	// Re-runs every time this partial is (re)inserted, including via the AJAX
	// ChangeFormValue swap used elsewhere on this form - so the toggle stays correct
	// across Add/Edit/Details and after adding/removing schema-cache rows.
	(function () {
		var $kind = $('#ConnectionKind');
		var $externalFields = $('#externalDatabaseFields');
		function toggleByConnectionKind() {
			var isUploadedFile = $kind.val() === '@FBSC.ODMS.Core.Constants.DataSourceConnectionKind.UploadedFile';
			$externalFields.toggleClass('d-none', isUploadedFile);
		}
		$kind.off('change.connectionKind').on('change.connectionKind', toggleByConnectionKind);
		toggleByConnectionKind();
	})();
</script>
