@using Models
@model DashboardViewModel

<div class="row row-cols-1 row-cols-sm-1 row-cols-md-1 row-cols-lg-1 row-cols-xl-1 row-cols-xxl-1">
    <div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Code" class="form-label"><strong>@Localizer["Code"] :</strong></label>
			<input asp-for="@Model.Code" class="form-control" maxlength="50" />
			<span asp-validation-for="@Model.Code" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Name" class="form-label"><strong>@Localizer["Name"] :</strong></label>
			<input asp-for="@Model.Name" class="form-control" maxlength="150" />
			<span asp-validation-for="@Model.Name" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Description" class="form-label"><strong>@Localizer["Description"] :</strong></label>
			<input asp-for="@Model.Description" class="form-control" maxlength="450" />
			<span asp-validation-for="@Model.Description" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Category" class="form-label"><strong>@Localizer["HRIS, Accounting, Sales, Or Custom Grouping"] :</strong></label>
			<input asp-for="@Model.Category" class="form-control" maxlength="100" />
			<span asp-validation-for="@Model.Category" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.DashboardThemeId" class="form-label"><strong>@Localizer["Dashboard Theme"] :</strong></label>
			<select asp-for="@Model.DashboardThemeId" class="form-control" asp-items="@(dropdownService.GetDashboardThemeList(Model.DashboardThemeId))"><option value="">- Select Dashboard Theme -</option></select>
			<span asp-validation-for="@Model.DashboardThemeId" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.OwnerUserId" class="form-label"><strong>@Localizer["Owner"] :</strong></label>
			<input asp-for="@Model.OwnerUserId" class="form-control" maxlength="100" />
			<span asp-validation-for="@Model.OwnerUserId" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.IsPublic" class="form-label"><strong>@Localizer["Is Public"] :</strong></label>
			<input asp-for="@Model.IsPublic" class="custom-checkbox-label"/>
			<span asp-validation-for="@Model.IsPublic" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.IsTemplate" class="form-label"><strong>@Localizer["Is Reusable Template"] :</strong></label>
			<input asp-for="@Model.IsTemplate" class="custom-checkbox-label"/>
			<span asp-validation-for="@Model.IsTemplate" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.RefreshIntervalSeconds" class="form-label"><strong>@Localizer["Default Widget Refresh Interval"] :</strong></label>
			<input asp-for="@Model.RefreshIntervalSeconds" class="form-control text-end"  />
			<span asp-validation-for="@Model.RefreshIntervalSeconds" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.LastPublishedAt" class="form-label"><strong>@Localizer["Last Published At"] :</strong></label>
			<input asp-for="@Model.LastPublishedAt" class="form-control"   readonly/>
			<span asp-validation-for="@Model.LastPublishedAt" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.IsActive" class="form-label"><strong>@Localizer["Is Active"] :</strong></label>
			<input asp-for="@Model.IsActive" class="custom-checkbox-label"/>
			<span asp-validation-for="@Model.IsActive" class="text-danger d-block mt-1"></span>
			
	</div>
</div>

</div>
