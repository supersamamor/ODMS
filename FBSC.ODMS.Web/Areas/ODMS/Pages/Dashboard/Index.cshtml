@page
@model IndexModel

@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["Title"] = Localizer["Dashboard List"];
    ViewData["ActiveMainPage"] = "Dashboard";
    ViewData["Level1"] = "ODMS";
	IEnumerable<dynamic> breadCrumbs = [new { Title = "Dashboard List", Url = "", IsActive = true }];
}
<partial name="_BreadcrumbPartial" model=@(breadCrumbs) />
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <table id="dashboard" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%">
                    <thead>
                        <tr>
                            <th>
								@Localizer["Code"]
							</th>
							<th>
								@Localizer["Name"]
							</th>
							<th>
								@Localizer["Description"]
							</th>
							<th>
								@Localizer["HRIS, Accounting, Sales, Or Custom Grouping"]
							</th>
							<th>
								@Localizer["Dashboard Theme"]
							</th>
							<th>
								@Localizer["Owner"]
							</th>
							<th>
								@Localizer["Is Public"]
							</th>
							<th>
								@Localizer["Is Reusable Template"]
							</th>
							<th>
								@Localizer["Default Widget Refresh Interval"]
							</th>
							<th>
								@Localizer["Last Published At"]
							</th>
							<th>
								@Localizer["Is Active"]
							</th>
							  
							<th>
								@Localizer["Status"]
							</th> 
                            <th>
                                @Localizer["Actions"]
                            </th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>


<div id="BatchUploadPartialContainer">
    <partial name="_BatchUpload" model="Model.BatchUpload" />
</div>
@section Scripts {
    <partial name="_DataTableScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var table = $('#dashboard').DataTable({
                select: false,
                serverSide: true,
                responsive: true,
                order: [[13, 'desc']],
                dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                ajax:
                {
                    url: '@Url.Page("/Dashboard/Index", new { area = "ODMS", handler = "ListAll" })',
                    type: "POST",
                    headers: {
                        RequestVerificationToken:
                            $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                },
                initComplete: function (settings, json) {
                    BindTableRowCollapseEvent();
                },
                columns: [
                    { data: "code", name: "Code", responsivePriority: 1, title: '@Localizer["Code"]', searchable: true, className: "text-start" },
				{ data: "name", name: "Name", responsivePriority: 1, title: '@Localizer["Name"]', searchable: true, className: "text-start" },
				{ data: "description", name: "Description", responsivePriority: 1, title: '@Localizer["Description"]', searchable: false, className: "text-start" },
				{ data: "category", name: "Category", responsivePriority: 2, title: '@Localizer["HRIS, Accounting, Sales, Or Custom Grouping"]', searchable: true, className: "text-start" },
				{ data: "dashboardThemeId", name: "DashboardThemeId", responsivePriority: 2, title: '@Localizer["Dashboard Theme"]', searchable: false, className: "text-start" },
				{ data: "ownerUserId", name: "OwnerUserId", responsivePriority: 2, title: '@Localizer["Owner"]', searchable: true, className: "text-start" },
				{ data: "isPublicFormatted", name: "IsPublic", responsivePriority: 2, title: '@Localizer["Is Public"]', searchable: false, className: "fills-text-center" },
				{ data: "isTemplateFormatted", name: "IsTemplate", responsivePriority: 2, title: '@Localizer["Is Reusable Template"]', searchable: false, className: "fills-text-center" },
				{ data: "refreshIntervalSecondsFormatted", name: "RefreshIntervalSeconds", responsivePriority: 2, title: '@Localizer["Default Widget Refresh Interval"]', searchable: false, className: "fills-text-end" },
				{ data: "lastPublishedAtFormatted", name: "LastPublishedAt", responsivePriority: 2, title: '@Localizer["Last Published At"]', searchable: false, className: "text-start" },
				{ data: "isActiveFormatted", name: "IsActive", responsivePriority: 2, title: '@Localizer["Is Active"]', searchable: false, className: "fills-text-center" },
				   
					{ data: "statusBadge", name: "StatusBadge", responsivePriority: 1, title: '@Localizer["Approval Status"]', searchable: false, orderable: false, className: "fills-text-center" },
                    {
                        data: null,
                        searchable: false,
                        orderable: false,
                        responsivePriority: 1,
                        width: "10%",
                        className: "fills-text-center",
                        render: function (data, type, row, meta) {
                            var url = '@Url.Page("/Dashboard/Details", new { area = "ODMS" })' + '?id=' + row.id;
							var button = '<a href="' + url + '" class="btn btnFills btn-outline-success btnInfoIcon btnViewDashboard" title="@Localizer["View"]"></a>';
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.Dashboard.Edit)).Succeeded)
						{
							<text>
											url = '@Url.Page("/Dashboard/Edit", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnEditIcon btnEditDashboard" title="@Localizer["Edit"]"></a>';
							</text>
						}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.Dashboard.Delete)).Succeeded)
						{
							<text>
											url = '@Url.Page("/Dashboard/Delete", new { area = "ODMS" })' + '?id=' + row.id;
												button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-danger btnDeleteIcon btnDeleteDashboard" title="@Localizer["Delete"]"></a>';
							</text>
						}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.Dashboard.Approve)).Succeeded)
				{
					<text>
						url = '@Url.Page("/Dashboard/Approve", new { area = "ODMS" })' + '?id=' + row.id;
						button =  button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-success btnApproveIcon" title="@Localizer["Approve"]"></a>';
					</text>
				}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.Dashboard.History)).Succeeded)
						{
							<text>
											url = '@Url.Page("/Dashboard/History", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnHistoryIcon" title="@Localizer["History"]"></a>';
							</text>
						}
							return button;
                        },
                    },
                    { data: "lastModifiedDate", name: "LastModifiedDate", title: '@Localizer["Last Modified Date"]', visible: false, searchable: false },
                    { data: "id", name: "Id", visible: false },
                ],
                buttons: [
        @* Add Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Dashboard.Create)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-plus"></i>',
                        className: 'btn btn-success btnAddDashboard text-light',
                        titleAttr: '@Localizer["Add"]',
                        action: function (e, dt, node, config) {
                            window.location.href = '@Url.Page("/Dashboard/Add", new { area = "ODMS" })';
                        }
                    },
            </text>
        }

        @* Download Template Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Dashboard.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-download"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Download Template"]',
                        action: function (e, dt, node, config) {
                            $('#download-template-form').submit();
                        }
                    },
            </text>
        }

        @* Upload Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.Dashboard.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-upload"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Upload"]',
                        action: function (e, dt, node, config) {
                            $('#btnBatchUpload').click();
                        }
                    },
            </text>
        }

        @* Page Length Button *@
            {
                extend: 'pageLength',
                className: 'btn btn-primary',
                titleAttr: '@Localizer["Rows per page"]'
            }
        ],
            });
            var debounce = new $.fn.dataTable.Debounce(table); // Add delay to search

            $('.btn-table_filter').on('click', function (e) {
                table.ajax.reload(null, false);
            });
            function BindTableRowCollapseEvent() {
                $('#dashboard tbody').on('click', 'td.dtr-control', function () {
                    $.showAjaxLoaderOnClick([".btnAddDashboard", ".btnEditDashboard", ".btnViewDashboard", ".btnDeleteDashboard"]);
                });
            }
            $.showAjaxLoaderOnClick([".btnAddDashboard", ".btnEditDashboard", ".btnViewDashboard", ".btnDeleteDashboard"]);
            $.InitializeSearchKeyCookies(table);
            $('#btnBatchUpload').on('change', function (e) {
                $('#batch-upload-form').submit();
            });           
        @if (!string.IsNullOrEmpty(Model.BatchUpload.BatchUploadFileName))
        {
            <text>
                    $('#btnDownloadBatchUploadTemplateLink')[0].click();
            </text>
        }
        });
    </script>
}