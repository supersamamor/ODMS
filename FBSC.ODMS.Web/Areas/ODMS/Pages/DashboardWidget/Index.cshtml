@page
@model IndexModel

@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["Title"] = Localizer["Dashboard Widget List"];
    ViewData["ActiveMainPage"] = "DashboardWidget";
    ViewData["Level1"] = "ODMS";
	IEnumerable<dynamic> breadCrumbs = [new { Title = "Dashboard Widget List", Url = "", IsActive = true }];
}
<partial name="_BreadcrumbPartial" model=@(breadCrumbs) />
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <table id="dashboardWidget" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%">
                    <thead>
                        <tr>
                            <th>
								@Localizer["Dashboard"]
							</th>
							<th>
								@Localizer["Dashboard Query"]
							</th>
							<th>
								@Localizer["Report Type"]
							</th>
							<th>
								@Localizer["Widget Title"]
							</th>
							<th>
								@Localizer["Maps To A DashboardQueryResultColumn.ColumnName"]
							</th>
							<th>
								@Localizer["Json Array Of Measure Column Names"]
							</th>
							<th>
								@Localizer["Optional Grouping/Series Column"]
							</th>
							<th>
								@Localizer["Overrides The Result Column`s Default Aggregation"]
							</th>
							<th>
								@Localizer["Optional Dashboard Opened On Widget Click"]
							</th>
							<th>
								@Localizer["Grid Column Position"]
							</th>
							<th>
								@Localizer["Grid Row Position"]
							</th>
							<th>
								@Localizer["Grid Width In Columns"]
							</th>
							<th>
								@Localizer["Grid Height In Rows"]
							</th>
							<th>
								@Localizer["Overrides Dashboard-Level Refresh Interval"]
							</th>
							<th>
								@Localizer["Tab/Load Order"]
							</th>
							  
							
                            <th>
                                @Localizer["Actions"]
                            </th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>


<div id="BatchUploadPartialContainer">
    <partial name="_BatchUpload" model="Model.BatchUpload" />
</div>
@section Scripts {
    <partial name="_DataTableScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var table = $('#dashboardWidget').DataTable({
                select: false,
                serverSide: true,
                responsive: true,
                order: [[15, 'desc']],
                dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                ajax:
                {
                    url: '@Url.Page("/DashboardWidget/Index", new { area = "ODMS", handler = "ListAll" })',
                    type: "POST",
                    headers: {
                        RequestVerificationToken:
                            $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                },
                initComplete: function (settings, json) {
                    BindTableRowCollapseEvent();
                },
                columns: [
                    { data: "dashboardId", name: "DashboardId", responsivePriority: 1, title: '@Localizer["Dashboard"]', searchable: false, className: "text-start" },
				{ data: "dashboardQueryId", name: "DashboardQueryId", responsivePriority: 1, title: '@Localizer["Dashboard Query"]', searchable: false, className: "text-start" },
				{ data: "reportTypeId", name: "ReportTypeId", responsivePriority: 1, title: '@Localizer["Report Type"]', searchable: false, className: "text-start" },
				{ data: "title", name: "Title", responsivePriority: 2, title: '@Localizer["Widget Title"]', searchable: true, className: "text-start" },
				{ data: "xAxisColumnName", name: "XAxisColumnName", responsivePriority: 2, title: '@Localizer["Maps To A DashboardQueryResultColumn.ColumnName"]', searchable: false, className: "text-start" },
				{ data: "yAxisColumnsJson", name: "YAxisColumnsJson", responsivePriority: 2, title: '@Localizer["Json Array Of Measure Column Names"]', searchable: false, className: "text-start" },
				{ data: "seriesColumnName", name: "SeriesColumnName", responsivePriority: 2, title: '@Localizer["Optional Grouping/Series Column"]', searchable: false, className: "text-start" },
				{ data: "aggregationOverride", name: "AggregationOverride", responsivePriority: 2, title: '@Localizer["Overrides The Result Column`s Default Aggregation"]', searchable: false, className: "text-start" },
				{ data: "drillDownDashboardId", name: "DrillDownDashboardId", responsivePriority: 2, title: '@Localizer["Optional Dashboard Opened On Widget Click"]', searchable: false, className: "text-start" },
				{ data: "gridPositionXFormatted", name: "GridPositionX", responsivePriority: 2, title: '@Localizer["Grid Column Position"]', searchable: false, className: "fills-text-end" },
				{ data: "gridPositionYFormatted", name: "GridPositionY", responsivePriority: 2, title: '@Localizer["Grid Row Position"]', searchable: false, className: "fills-text-end" },
				{ data: "gridWidthFormatted", name: "GridWidth", responsivePriority: 2, title: '@Localizer["Grid Width In Columns"]', searchable: false, className: "fills-text-end" },
				{ data: "gridHeightFormatted", name: "GridHeight", responsivePriority: 2, title: '@Localizer["Grid Height In Rows"]', searchable: false, className: "fills-text-end" },
				{ data: "refreshIntervalOverrideSecondsFormatted", name: "RefreshIntervalOverrideSeconds", responsivePriority: 2, title: '@Localizer["Overrides Dashboard-Level Refresh Interval"]', searchable: false, className: "fills-text-end" },
				{ data: "sequenceFormatted", name: "Sequence", responsivePriority: 2, title: '@Localizer["Tab/Load Order"]', searchable: false, className: "fills-text-end" },
				   
					
                    {
                        data: null,
                        searchable: false,
                        orderable: false,
                        responsivePriority: 1,
                        width: "10%",
                        className: "fills-text-center",
                        render: function (data, type, row, meta) {
                            var url = '@Url.Page("/DashboardWidget/Details", new { area = "ODMS" })' + '?id=' + row.id;
							var button = '<a href="' + url + '" class="btn btnFills btn-outline-success btnInfoIcon btnViewDashboardWidget" title="@Localizer["View"]"></a>';
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardWidget.Edit)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DashboardWidget/Edit", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnEditIcon btnEditDashboardWidget" title="@Localizer["Edit"]"></a>';
							</text>
						}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardWidget.Delete)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DashboardWidget/Delete", new { area = "ODMS" })' + '?id=' + row.id;
												button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-danger btnDeleteIcon btnDeleteDashboardWidget" title="@Localizer["Delete"]"></a>';
							</text>
						}
						
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardWidget.History)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DashboardWidget/History", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnHistoryIcon" title="@Localizer["History"]"></a>';
							</text>
						}
							return button;
                        },
                    },
                    { data: "lastModifiedDate", name: "LastModifiedDate", title: '@Localizer["Last Modified Date"]', visible: false, searchable: false },
                    { data: "id", name: "Id", visible: false },
                ],
                buttons: [
        @* Add Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardWidget.Create)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-plus"></i>',
                        className: 'btn btn-success btnAddDashboardWidget text-light',
                        titleAttr: '@Localizer["Add"]',
                        action: function (e, dt, node, config) {
                            window.location.href = '@Url.Page("/DashboardWidget/Add", new { area = "ODMS" })';
                        }
                    },
            </text>
        }

        @* Download Template Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardWidget.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-download"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Download Template"]',
                        action: function (e, dt, node, config) {
                            $('#download-template-form').submit();
                        }
                    },
            </text>
        }

        @* Upload Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardWidget.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-upload"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Upload"]',
                        action: function (e, dt, node, config) {
                            $('#btnBatchUpload').click();
                        }
                    },
            </text>
        }

        @* Page Length Button *@
            {
                extend: 'pageLength',
                className: 'btn btn-primary',
                titleAttr: '@Localizer["Rows per page"]'
            }
        ],
            });
            var debounce = new $.fn.dataTable.Debounce(table); // Add delay to search

            $('.btn-table_filter').on('click', function (e) {
                table.ajax.reload(null, false);
            });
            function BindTableRowCollapseEvent() {
                $('#dashboardWidget tbody').on('click', 'td.dtr-control', function () {
                    $.showAjaxLoaderOnClick([".btnAddDashboardWidget", ".btnEditDashboardWidget", ".btnViewDashboardWidget", ".btnDeleteDashboardWidget"]);
                });
            }
            $.showAjaxLoaderOnClick([".btnAddDashboardWidget", ".btnEditDashboardWidget", ".btnViewDashboardWidget", ".btnDeleteDashboardWidget"]);
            $.InitializeSearchKeyCookies(table);
            $('#btnBatchUpload').on('change', function (e) {
                $('#batch-upload-form').submit();
            });           
        @if (!string.IsNullOrEmpty(Model.BatchUpload.BatchUploadFileName))
        {
            <text>
                    $('#btnDownloadBatchUploadTemplateLink')[0].click();
            </text>
        }
        });
    </script>
}