@using Models
@model DashboardQueryResultColumnViewModel

<div class="row row-cols-1 row-cols-sm-1 row-cols-md-1 row-cols-lg-1 row-cols-xl-1 row-cols-xxl-1">
    <div class="col">
	<div class="mb-3">
		<label asp-for="@Model.DashboardQueryId" class="form-label"><strong>@Localizer["Dashboard Query"] :</strong></label>
			<select asp-for="@Model.DashboardQueryId" class="form-control" asp-items="@(dropdownService.GetDashboardQueryList(Model.DashboardQueryId))"><option value="">- Select Dashboard Query -</option></select>
			<span asp-validation-for="@Model.DashboardQueryId" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.ColumnName" class="form-label"><strong>@Localizer["Column Name As Returned By The Query"] :</strong></label>
			<input asp-for="@Model.ColumnName" class="form-control" maxlength="150"  readonly/>
			<span asp-validation-for="@Model.ColumnName" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.OrdinalPosition" class="form-label"><strong>@Localizer["Column Order In Result Set"] :</strong></label>
			<input asp-for="@Model.OrdinalPosition" class="form-control text-end"   readonly/>
			<span asp-validation-for="@Model.OrdinalPosition" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.SqlDataType" class="form-label"><strong>@Localizer["Native Sql Data Type Returned"] :</strong></label>
			<input asp-for="@Model.SqlDataType" class="form-control" maxlength="50"  readonly/>
			<span asp-validation-for="@Model.SqlDataType" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.InferredRole" class="form-label"><strong>@Localizer["Dimension, Measure, DateAxis, Label, Or Identifier"] :</strong></label>
			<input asp-for="@Model.InferredRole" class="form-control" maxlength="50" />
			<span asp-validation-for="@Model.InferredRole" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.IsAggregatable" class="form-label"><strong>@Localizer["Can Be Summed/Averaged/Counted"] :</strong></label>
			<input asp-for="@Model.IsAggregatable" class="custom-checkbox-label"/>
			<span asp-validation-for="@Model.IsAggregatable" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.DefaultAggregation" class="form-label"><strong>@Localizer["SUM, COUNT, AVG, MIN, Or MAX"] :</strong></label>
			<input asp-for="@Model.DefaultAggregation" class="form-control" maxlength="20" />
			<span asp-validation-for="@Model.DefaultAggregation" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.FormatString" class="form-label"><strong>@Localizer["Display Format, E.g. Currency Or Percent Mask"] :</strong></label>
			<input asp-for="@Model.FormatString" class="form-control" maxlength="50" />
			<span asp-validation-for="@Model.FormatString" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Sequence" class="form-label"><strong>@Localizer["Column Order For Mapping Pickers"] :</strong></label>
			<input asp-for="@Model.Sequence" class="form-control text-end"  />
			<span asp-validation-for="@Model.Sequence" class="text-danger d-block mt-1"></span>
			
	</div>
</div>

</div>
