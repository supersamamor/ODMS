@page
@model IndexModel

@section Styles {
    <partial name="_DataTableStyles" />
}
@{
    ViewData["Title"] = Localizer["Dashboard Query Result Column List"];
    ViewData["ActiveMainPage"] = "DashboardQueryResultColumn";
    ViewData["Level1"] = "ODMS";
	IEnumerable<dynamic> breadCrumbs = [new { Title = "Dashboard Query Result Column List", Url = "", IsActive = true }];
}
<partial name="_BreadcrumbPartial" model=@(breadCrumbs) />
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <table id="dashboardQueryResultColumn" class="table table-hover table-bordered table-striped responsive nowrap fills-table" width="100%">
                    <thead>
                        <tr>
                            <th>
								@Localizer["Dashboard Query"]
							</th>
							<th>
								@Localizer["Column Name As Returned By The Query"]
							</th>
							<th>
								@Localizer["Column Order In Result Set"]
							</th>
							<th>
								@Localizer["Native Sql Data Type Returned"]
							</th>
							<th>
								@Localizer["Dimension, Measure, DateAxis, Label, Or Identifier"]
							</th>
							<th>
								@Localizer["Can Be Summed/Averaged/Counted"]
							</th>
							<th>
								@Localizer["SUM, COUNT, AVG, MIN, Or MAX"]
							</th>
							<th>
								@Localizer["Display Format, E.g. Currency Or Percent Mask"]
							</th>
							<th>
								@Localizer["Column Order For Mapping Pickers"]
							</th>
							  
							
                            <th>
                                @Localizer["Actions"]
                            </th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>


<div id="BatchUploadPartialContainer">
    <partial name="_BatchUpload" model="Model.BatchUpload" />
</div>
@section Scripts {
    <partial name="_DataTableScripts" />
    <script asp-add-nonce>
        $(document).ready(function () {
            var table = $('#dashboardQueryResultColumn').DataTable({
                select: false,
                serverSide: true,
                responsive: true,
                order: [[9, 'desc']],
                dom: '@Html.Raw(FBSC.ODMS.Web.WebConstants.DataTableDOMLayOut)',
                ajax:
                {
                    url: '@Url.Page("/DashboardQueryResultColumn/Index", new { area = "ODMS", handler = "ListAll" })',
                    type: "POST",
                    headers: {
                        RequestVerificationToken:
                            $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                },
                initComplete: function (settings, json) {
                    BindTableRowCollapseEvent();
                },
                columns: [
                    { data: "dashboardQueryId", name: "DashboardQueryId", responsivePriority: 1, title: '@Localizer["Dashboard Query"]', searchable: false, className: "text-start" },
				{ data: "columnName", name: "ColumnName", responsivePriority: 1, title: '@Localizer["Column Name As Returned By The Query"]', searchable: true, className: "text-start" },
				{ data: "ordinalPositionFormatted", name: "OrdinalPosition", responsivePriority: 1, title: '@Localizer["Column Order In Result Set"]', searchable: false, className: "fills-text-end" },
				{ data: "sqlDataType", name: "SqlDataType", responsivePriority: 2, title: '@Localizer["Native Sql Data Type Returned"]', searchable: false, className: "text-start" },
				{ data: "inferredRole", name: "InferredRole", responsivePriority: 2, title: '@Localizer["Dimension, Measure, DateAxis, Label, Or Identifier"]', searchable: false, className: "text-start" },
				{ data: "isAggregatableFormatted", name: "IsAggregatable", responsivePriority: 2, title: '@Localizer["Can Be Summed/Averaged/Counted"]', searchable: false, className: "fills-text-center" },
				{ data: "defaultAggregation", name: "DefaultAggregation", responsivePriority: 2, title: '@Localizer["SUM, COUNT, AVG, MIN, Or MAX"]', searchable: false, className: "text-start" },
				{ data: "formatString", name: "FormatString", responsivePriority: 2, title: '@Localizer["Display Format, E.g. Currency Or Percent Mask"]', searchable: false, className: "text-start" },
				{ data: "sequenceFormatted", name: "Sequence", responsivePriority: 2, title: '@Localizer["Column Order For Mapping Pickers"]', searchable: false, className: "fills-text-end" },
				   
					
                    {
                        data: null,
                        searchable: false,
                        orderable: false,
                        responsivePriority: 1,
                        width: "10%",
                        className: "fills-text-center",
                        render: function (data, type, row, meta) {
                            var url = '@Url.Page("/DashboardQueryResultColumn/Details", new { area = "ODMS" })' + '?id=' + row.id;
							var button = '<a href="' + url + '" class="btn btnFills btn-outline-success btnInfoIcon btnViewDashboardQueryResultColumn" title="@Localizer["View"]"></a>';
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQueryResultColumn.Edit)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DashboardQueryResultColumn/Edit", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnEditIcon btnEditDashboardQueryResultColumn" title="@Localizer["Edit"]"></a>';
							</text>
						}
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQueryResultColumn.Delete)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DashboardQueryResultColumn/Delete", new { area = "ODMS" })' + '?id=' + row.id;
												button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-danger btnDeleteIcon btnDeleteDashboardQueryResultColumn" title="@Localizer["Delete"]"></a>';
							</text>
						}
						
						@if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQueryResultColumn.History)).Succeeded)
						{
							<text>
											url = '@Url.Page("/DashboardQueryResultColumn/History", new { area = "ODMS" })' + '?id=' + row.id;
											button = button + '&nbsp;<a href="' + url + '" class="btn btnFills btn-outline-primary btnHistoryIcon" title="@Localizer["History"]"></a>';
							</text>
						}
							return button;
                        },
                    },
                    { data: "lastModifiedDate", name: "LastModifiedDate", title: '@Localizer["Last Modified Date"]', visible: false, searchable: false },
                    { data: "id", name: "Id", visible: false },
                ],
                buttons: [
        @* Add Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQueryResultColumn.Create)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-plus"></i>',
                        className: 'btn btn-success btnAddDashboardQueryResultColumn text-light',
                        titleAttr: '@Localizer["Add"]',
                        action: function (e, dt, node, config) {
                            window.location.href = '@Url.Page("/DashboardQueryResultColumn/Add", new { area = "ODMS" })';
                        }
                    },
            </text>
        }

        @* Download Template Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQueryResultColumn.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-download"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Download Template"]',
                        action: function (e, dt, node, config) {
                            $('#download-template-form').submit();
                        }
                    },
            </text>
        }

        @* Upload Button *@
        @if ((await AuthorizationService.AuthorizeAsync(User, Permission.DashboardQueryResultColumn.Upload)).Succeeded)
        {
            <text>
                    {
                        text: '<i class="fas fa-upload"></i>',
                        className: 'btn btn-primary',
                        titleAttr: '@Localizer["Upload"]',
                        action: function (e, dt, node, config) {
                            $('#btnBatchUpload').click();
                        }
                    },
            </text>
        }

        @* Page Length Button *@
            {
                extend: 'pageLength',
                className: 'btn btn-primary',
                titleAttr: '@Localizer["Rows per page"]'
            }
        ],
            });
            var debounce = new $.fn.dataTable.Debounce(table); // Add delay to search

            $('.btn-table_filter').on('click', function (e) {
                table.ajax.reload(null, false);
            });
            function BindTableRowCollapseEvent() {
                $('#dashboardQueryResultColumn tbody').on('click', 'td.dtr-control', function () {
                    $.showAjaxLoaderOnClick([".btnAddDashboardQueryResultColumn", ".btnEditDashboardQueryResultColumn", ".btnViewDashboardQueryResultColumn", ".btnDeleteDashboardQueryResultColumn"]);
                });
            }
            $.showAjaxLoaderOnClick([".btnAddDashboardQueryResultColumn", ".btnEditDashboardQueryResultColumn", ".btnViewDashboardQueryResultColumn", ".btnDeleteDashboardQueryResultColumn"]);
            $.InitializeSearchKeyCookies(table);
            $('#btnBatchUpload').on('change', function (e) {
                $('#batch-upload-form').submit();
            });           
        @if (!string.IsNullOrEmpty(Model.BatchUpload.BatchUploadFileName))
        {
            <text>
                    $('#btnDownloadBatchUploadTemplateLink')[0].click();
            </text>
        }
        });
    </script>
}