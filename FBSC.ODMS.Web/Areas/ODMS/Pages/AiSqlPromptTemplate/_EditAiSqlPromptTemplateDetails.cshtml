@using Models
@model AiSqlPromptTemplateViewModel

<div class="row row-cols-1 row-cols-sm-1 row-cols-md-1 row-cols-lg-1 row-cols-xl-1 row-cols-xxl-1">
    <div class="col">
	<div class="mb-3">
		<label asp-for="@Model.SystemType" class="form-label"><strong>@Localizer["HRIS, Accounting, CRM, Or Generic"] :</strong></label>
			<input asp-for="@Model.SystemType" class="form-control" maxlength="50" />
			<span asp-validation-for="@Model.SystemType" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.PromptTemplate" class="form-label"><strong>@Localizer["Instructions Steering Natural-Language-To-Sql Generation"] :</strong></label>
			<input asp-for="@Model.PromptTemplate" class="form-control"  />
			<span asp-validation-for="@Model.PromptTemplate" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Sequence" class="form-label"><strong>@Localizer["Evaluation Order When Multiple Templates Apply"] :</strong></label>
			<input asp-for="@Model.Sequence" class="form-control text-end"  />
			<span asp-validation-for="@Model.Sequence" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.IsActive" class="form-label"><strong>@Localizer["Is Active"] :</strong></label>
			<input asp-for="@Model.IsActive" class="custom-checkbox-label"/>
			<span asp-validation-for="@Model.IsActive" class="text-danger d-block mt-1"></span>
			
	</div>
</div>

</div>
