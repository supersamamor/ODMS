@using Models
@model ReportTypeViewModel

<div class="row row-cols-1 row-cols-sm-1 row-cols-md-1 row-cols-lg-1 row-cols-xl-1 row-cols-xxl-1">
    <div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Code" class="form-label"><strong>@Localizer["Code"] :</strong></label>
			<input asp-for="@Model.Code" class="form-control" maxlength="30" />
			<span asp-validation-for="@Model.Code" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Name" class="form-label"><strong>@Localizer["Name"] :</strong></label>
			<input asp-for="@Model.Name" class="form-control" maxlength="100" />
			<span asp-validation-for="@Model.Name" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.ChartRenderer" class="form-label"><strong>@Localizer["Underlying Chart.js Type Or Widget Renderer Key"] :</strong></label>
			<input asp-for="@Model.ChartRenderer" class="form-control" maxlength="50" />
			<span asp-validation-for="@Model.ChartRenderer" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.MinColumnsRequired" class="form-label"><strong>@Localizer["Minimum Result Columns Needed"] :</strong></label>
			<input asp-for="@Model.MinColumnsRequired" class="form-control text-end"  />
			<span asp-validation-for="@Model.MinColumnsRequired" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.MaxColumnsRequired" class="form-label"><strong>@Localizer["Maximum Result Columns Supported"] :</strong></label>
			<input asp-for="@Model.MaxColumnsRequired" class="form-control text-end"  />
			<span asp-validation-for="@Model.MaxColumnsRequired" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.RequiresXAxis" class="form-label"><strong>@Localizer["Requires X-Axis / Category Column"] :</strong></label>
			<input asp-for="@Model.RequiresXAxis" class="custom-checkbox-label"/>
			<span asp-validation-for="@Model.RequiresXAxis" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.RequiresYAxis" class="form-label"><strong>@Localizer["Requires Y-Axis / Measure Column"] :</strong></label>
			<input asp-for="@Model.RequiresYAxis" class="custom-checkbox-label"/>
			<span asp-validation-for="@Model.RequiresYAxis" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.RequiresSeriesGrouping" class="form-label"><strong>@Localizer["Requires Series / Grouping Column"] :</strong></label>
			<input asp-for="@Model.RequiresSeriesGrouping" class="custom-checkbox-label"/>
			<span asp-validation-for="@Model.RequiresSeriesGrouping" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.IconClass" class="form-label"><strong>@Localizer["Icon Class For Picker UI"] :</strong></label>
			<input asp-for="@Model.IconClass" class="form-control" maxlength="100" />
			<span asp-validation-for="@Model.IconClass" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.IsActive" class="form-label"><strong>@Localizer["Is Active"] :</strong></label>
			<input asp-for="@Model.IsActive" class="custom-checkbox-label"/>
			<span asp-validation-for="@Model.IsActive" class="text-danger d-block mt-1"></span>
			
	</div>
</div>

</div>
