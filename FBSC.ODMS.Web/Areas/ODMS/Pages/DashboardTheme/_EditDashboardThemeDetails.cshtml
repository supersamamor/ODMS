@using Models
@model DashboardThemeViewModel

<div class="row row-cols-1 row-cols-sm-1 row-cols-md-1 row-cols-lg-1 row-cols-xl-1 row-cols-xxl-1">
    <div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Code" class="form-label"><strong>@Localizer["Code"] :</strong></label>
			<input asp-for="@Model.Code" class="form-control" maxlength="30" />
			<span asp-validation-for="@Model.Code" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Name" class="form-label"><strong>@Localizer["Name"] :</strong></label>
			<input asp-for="@Model.Name" class="form-control" maxlength="100" />
			<span asp-validation-for="@Model.Name" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.IsDarkMode" class="form-label"><strong>@Localizer["Is Dark Mode"] :</strong></label>
			<input asp-for="@Model.IsDarkMode" class="custom-checkbox-label"/>
			<span asp-validation-for="@Model.IsDarkMode" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.PrimaryColorHex" class="form-label"><strong>@Localizer["Primary Seed Color"] :</strong></label>
			<input asp-for="@Model.PrimaryColorHex" class="form-control" maxlength="10" />
			<span asp-validation-for="@Model.PrimaryColorHex" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.ColorPaletteJson" class="form-label"><strong>@Localizer["Generated Palette As Json Array Of Hex Values"] :</strong></label>
			<input asp-for="@Model.ColorPaletteJson" class="form-control"   readonly/>
			<span asp-validation-for="@Model.ColorPaletteJson" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.GenerationAlgorithm" class="form-label"><strong>@Localizer["Sequential, Categorical, Or Diverging"] :</strong></label>
			<input asp-for="@Model.GenerationAlgorithm" class="form-control" maxlength="50" />
			<span asp-validation-for="@Model.GenerationAlgorithm" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.IsSystemDefault" class="form-label"><strong>@Localizer["Is System Default"] :</strong></label>
			<input asp-for="@Model.IsSystemDefault" class="custom-checkbox-label"/>
			<span asp-validation-for="@Model.IsSystemDefault" class="text-danger d-block mt-1"></span>
			
	</div>
</div>

</div>
