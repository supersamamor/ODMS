@using Models
@model FBSC.ODMS.Web.Areas.ODMS.Models.ChangeHistoryMainModel
@{
    var userHelper = new FBSC.ODMS.Web.Helper.UserHelper(Mediator);
}

<div class="timeline-panel">
    <div class="timeline-heading">
        <h6 class="timeline-title"><i class="fas fa-calendar-alt"></i>@Model.DateTimeFormatted</h6>
        <p class="timeline-history">
            <small class="text-muted">
                <i class="fas fa-history"></i>@(string.IsNullOrEmpty(Model.DateTimeDuration) ? "Just now" : Model.DateTimeDuration + " ago") by @Html.Raw(await userHelper.GetUserName(Model.UserId!))
            </small>
        </p>
    </div>
</div>

@foreach (var item in Model.ChangeHistoryList.OrderBy(l => l.Sequence))
{
    <div class="card mb-3">
        <h5 class="card-header"><span class="card-header-custom">@Html.Raw(item.AuditTypeBadge) @item.TableName</span></h5>
        <div class="card-body history-details">

            <table class="table table-hover table-bordered table-striped responsive fills-table auditlogs">
                <tbody>
                    @foreach (var property in item.MergedChanges.Properties())
                    {
                        <tr>
                            <td class="timeline-changes-propertyname" style="width: 30%; overflow-wrap: break-word;">
                                @property.Name
                            </td>

                            <td class="padding-left-10 timeline-changes-details" style="overflow-wrap: break-word; word-wrap: break-word; hyphens: auto;">
                                @Html.Raw(property.Value)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
}