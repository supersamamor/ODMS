@using Models
@model DashboardRefreshJobViewModel

<div class="row row-cols-1 row-cols-sm-1 row-cols-md-1 row-cols-lg-1 row-cols-xl-1 row-cols-xxl-1">
    <div class="col">
	<div class="mb-3">
		<label asp-for="@Model.DashboardQueryId" class="form-label"><strong>@Localizer["Dashboard Query"] :</strong></label>
			<select asp-for="@Model.DashboardQueryId" class="form-control" asp-items="@(dropdownService.GetDashboardQueryList(Model.DashboardQueryId))"><option value="">- Select Dashboard Query -</option></select>
			<span asp-validation-for="@Model.DashboardQueryId" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.TriggerType" class="form-label"><strong>@Localizer["Manual Or Schedule"] :</strong></label>
			<input asp-for="@Model.TriggerType" class="form-control" maxlength="20" />
			<span asp-validation-for="@Model.TriggerType" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.Status" class="form-label"><strong>@Localizer["Status"] :</strong></label>
			<input asp-for="@Model.Status" class="form-control" maxlength="50" />
			<span asp-validation-for="@Model.Status" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.QueuedAt" class="form-label"><strong>@Localizer["Queued At"] :</strong></label>
			<input asp-for="@Model.QueuedAt" class="form-control"   readonly/>
			<span asp-validation-for="@Model.QueuedAt" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.StartedAt" class="form-label"><strong>@Localizer["Started At"] :</strong></label>
			<input asp-for="@Model.StartedAt" class="form-control"   readonly/>
			<span asp-validation-for="@Model.StartedAt" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.CompletedAt" class="form-label"><strong>@Localizer["Completed At"] :</strong></label>
			<input asp-for="@Model.CompletedAt" class="form-control"   readonly/>
			<span asp-validation-for="@Model.CompletedAt" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.DurationMs" class="form-label"><strong>@Localizer["Duration In Milliseconds"] :</strong></label>
			<input asp-for="@Model.DurationMs" class="form-control text-end"   readonly/>
			<span asp-validation-for="@Model.DurationMs" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.RowsCached" class="form-label"><strong>@Localizer["Rows Written To Result Cache"] :</strong></label>
			<input asp-for="@Model.RowsCached" class="form-control text-end"   readonly/>
			<span asp-validation-for="@Model.RowsCached" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.RetryCount" class="form-label"><strong>@Localizer["Retry Count"] :</strong></label>
			<input asp-for="@Model.RetryCount" class="form-control text-end"   readonly/>
			<span asp-validation-for="@Model.RetryCount" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.MaxRetries" class="form-label"><strong>@Localizer["Max Retries"] :</strong></label>
			<input asp-for="@Model.MaxRetries" class="form-control text-end"  />
			<span asp-validation-for="@Model.MaxRetries" class="text-danger d-block mt-1"></span>
			
	</div>
</div>
<div class="col">
	<div class="mb-3">
		<label asp-for="@Model.ErrorRemarks" class="form-label"><strong>@Localizer["Error Remarks"] :</strong></label>
			<input asp-for="@Model.ErrorRemarks" class="form-control" maxlength="450"  readonly/>
			<span asp-validation-for="@Model.ErrorRemarks" class="text-danger d-block mt-1"></span>
			
	</div>
</div>

</div>
